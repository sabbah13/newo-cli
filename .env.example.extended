# NEWO CLI Configuration - Extended with Rate Limiting & Performance Options
# Copy this to .env and configure as needed

# Required: Your NEWO API configuration
NEWO_BASE_URL=https://app.newo.ai
NEWO_API_KEY=your_api_key_here

# Optional: Specific project (if not set, pulls all accessible projects)
NEWO_PROJECT_ID=

# Optional: Token configuration (usually managed automatically)
NEWO_ACCESS_TOKEN=
NEWO_REFRESH_TOKEN=
NEWO_REFRESH_URL=

# Environment
NODE_ENV=development

# ============================================================================
# PERFORMANCE & RATE LIMITING CONFIGURATION
# ============================================================================

# Rate Limiting Configuration
# ----------------------------
# Maximum requests allowed per time window (default: 1000, relaxed from 100)
NEWO_RATE_LIMIT_MAX_REQUESTS=1000

# Time window for rate limiting in milliseconds (default: 60000 = 1 minute)
NEWO_RATE_LIMIT_WINDOW=60000

# Request Timing Configuration  
# -----------------------------
# Delay between individual API requests in milliseconds (default: 100)
# Set to 0 to disable delays, increase for gentler API usage
NEWO_REQUEST_DELAY=100

# Maximum concurrent requests (default: 20, increased from 10)
NEWO_CONCURRENT_REQUESTS=20

# API timeout per request in milliseconds (default: 60000 = 1 minute)
NEWO_API_TIMEOUT=60000

# Retry Configuration
# -------------------
# Maximum number of retry attempts (default: 5, increased from 3)
NEWO_RETRY_MAX_ATTEMPTS=5

# Initial delay before first retry in milliseconds (default: 2000 = 2 seconds)
NEWO_RETRY_INITIAL_DELAY=2000

# Maximum delay between retries in milliseconds (default: 30000 = 30 seconds) 
NEWO_RETRY_MAX_DELAY=30000

# Backoff multiplier for exponential backoff (default: 1.5, gentler than 2.0)
NEWO_RETRY_BACKOFF_MULTIPLIER=1.5

# ============================================================================
# USAGE EXAMPLES
# ============================================================================

# For aggressive API usage (faster but may hit limits):
# NEWO_RATE_LIMIT_MAX_REQUESTS=500
# NEWO_REQUEST_DELAY=0
# NEWO_RETRY_MAX_ATTEMPTS=3
# NEWO_RETRY_INITIAL_DELAY=1000

# For conservative API usage (slower but very reliable):
# NEWO_RATE_LIMIT_MAX_REQUESTS=2000
# NEWO_REQUEST_DELAY=500
# NEWO_RETRY_MAX_ATTEMPTS=8
# NEWO_RETRY_INITIAL_DELAY=5000

# For high-volume production usage:
# NEWO_RATE_LIMIT_MAX_REQUESTS=5000
# NEWO_CONCURRENT_REQUESTS=50
# NEWO_REQUEST_DELAY=50
# NEWO_RETRY_MAX_ATTEMPTS=6