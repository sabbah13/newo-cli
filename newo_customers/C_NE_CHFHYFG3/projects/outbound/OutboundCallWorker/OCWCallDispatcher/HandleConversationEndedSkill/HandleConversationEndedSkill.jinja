{% set user_id = GetUser().id | string %}

{% set outbound_call = GetPersonaAttribute(id=user_id, field="outbound_call") %}

{% if outbound_call != "True" %}
    {{Return()}}
{% endif %}

{% set arguments = GetTriggeredAct().arguments %}

{% set attempts_number = (GetState(name="attempts_number") | int + 1) | string %}
{{SetState(name="attempts_number", value=attempts_number)}}

{{SendSystemEvent(eventIdn="outbound_call_finished", connectorIdn="system", reason=arguments.reason, recording=arguments.recordingUrl, global="True", actorId=GetActor().id | string, userId=user_id, attemptNumber=attempts_number, taskId=GetState(name="task_id"), voicemail_detected=GetState(name="voicemail_detected"))}}
