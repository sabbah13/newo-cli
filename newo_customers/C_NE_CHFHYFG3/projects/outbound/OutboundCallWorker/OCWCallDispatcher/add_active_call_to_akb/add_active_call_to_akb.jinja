{# Add an active call entry to AKB when a call starts #}
{% set agent_persona_id = GetAgentPersona().id | string %}
{% set timestamp = datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S') %}
{{SetManualAkb(
    personaId=agent_persona_id,
    summary="Active call for task " ~ task_id,
    facts=["Call started at " ~ timestamp],
    name="active_call_" ~ task_id,
    source="OCWCallDispatcher",
    labels=["active_call"]
)}}

