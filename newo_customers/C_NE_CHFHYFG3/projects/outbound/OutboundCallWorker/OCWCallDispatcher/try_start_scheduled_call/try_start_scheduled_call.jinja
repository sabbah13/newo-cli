{% set max_active_calls = get_customer_attribute_or_default(field="project_attributes_setting_outbound_max_active_calls", default="50") | int %}

{# Check if we can start the next queued call from AKB #}
{% set active_call_count = get_active_calls_count() | int %}
{% if active_call_count < max_active_calls %}
    {% set queued_task = get_next_queued_call_from_akb() %}
    {% if queued_task %}
        {{_setupCallSkill(task=queued_task)}}
    {% endif %}
{% endif %}
