{# Get the next queued call from AKB and remove it, returning the task object #}
{% set agent_persona_id = GetAgentPersona().id | string %}
{% set queued_calls = SearchFuzzyAkb(
    query="queued_calls",
    searchFields=["name"],
    numberTopics=1,
    scoreThreshold=1,
    labels=["queued_calls"],
    filterByPersonaIds=[agent_persona_id]
) %}
{% if queued_calls %}
    {% set queue = json.loads(queued_calls[0].summary) %}
    {% if not queue %}
        {{Return(val="")}}
    {% endif %}
    {% set next_call = queue.pop() %}
    {{UpdateAkb(id=queued_calls[0].topicId|string, summary=json.dumps(queue, ensure_ascii=False, indent=2))}}
    {{Return(val=json.dumps(next_call, ensure_ascii=False, indent=2))}}
{% else %}
    {{SetManualAkb(
        personaId=agent_persona_id,
        summary="[]",
        facts=[],
        name="queued_calls",
        source="OCWCallDispatcher",
        labels=["queued_calls"]
    )}}
    {{Return(val="")}}
{% endif %}
