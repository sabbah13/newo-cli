{% set task = json.loads(GetPersonaAttribute(id=userId, field="outbound_call_context"))[taskId] %}
{% set primary_task = task.content %}

{% set summary = _summarizeConversation(conversation=conversation, primaryTask=primary_task) %}

{{_updateTaskManagerStatusSkill(taskId=taskId, status="analyzing", comment=summary)}}

{% set payload = {"recording": recording, "call_ended_reason": call_ended_reason, "status": "finished"} %}

{% set outbound_schema = GetCustomerAttribute(field="project_attributes_setting_outbound_payload_schema") %}

{% if outbound_schema.strip() and (not outbound_schema == "{}") %}
    {{payload.update(json.loads(_getValuesFromConversationSkill(conversation=conversation, schema=outbound_schema)))}}
{% endif %}

{{_sendWebhookResultSkill(taskId=taskId, userId=userId, payload=json.dumps(payload, ensure_ascii=False, indent=2))}}

{{_updateCallTableSkill(recording=recording, userId=userId, summary=summary, taskId=taskId, reason="customer-answered")}}

{{_cleanUpSkill(userId=userId)}}

{{_updateTaskManagerStatusSkill(taskId=taskId, status="done", comment="Task finished.")}}
