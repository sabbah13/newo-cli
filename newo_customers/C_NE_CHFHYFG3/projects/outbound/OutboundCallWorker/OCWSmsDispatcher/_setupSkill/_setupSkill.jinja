{% set task = json.loads(task) %}

{% set user_id = task.user_id %}
{% set message_reason = task.arguments.content %}

{% set task_outbound_sms_context = "" %}

{% set current_outbound_context = GetPersonaAttribute(id=user_id, field="outbound_sms_context").strip() %}
{% if current_outbound_context %}
    {% set current_outbound_context = json.loads(current_outbound_context) %}
    {% set task_outbound_sms_context = current_outbound_context.get(task.id, "") %}
{% endif %}

{% if task_outbound_sms_context %}
    {% set greeting_phrase = task_outbound_sms_context.greeting_phrase %}
    {% set retry = "True" %}
{% else %}
    {% set greeting_phrase = _generateGreetingPhraseSkill(messageReason=message_reason) %}
    {% set outbound_sms_context = {"content": message_reason, "greeting_phrase": greeting_phrase, "task": task} %}

    {% if not current_outbound_context %}
        {% set current_outbound_context = {} %}
    {% endif %}

    {{current_outbound_context.update({task.id: outbound_sms_context})}}

    {{SetPersonaAttribute(id=user_id, field="outbound_sms_context", value=json.dumps(current_outbound_context, ensure_ascii=False, indent=2))}}
    {% set retry = "False" %}
{% endif %}

{% set phone_number = task.arguments.get("phoneNumber", None) %}
{% if not phone_number or phone_number == "null" %}
    {{DUMMY("Phone number is required to send SMS via `outbound` project.")}}
    {{Return()}}
{% else %}
    {% set phone_number_without_plus = phone_number.replace("+", "") %}
{% endif %}

{{SetPersonaAttribute(id=user_id, field="outbound_sms", value="True")}}
{{SetPersonaAttribute(id=user_id, field="outbound_content", value=message_reason)}}

{{SetPersonaAttribute(id=user_id, field="sms_outbound_original_phone_number", value=phone_number_without_plus)}}

{% set sms_actor = GetActors(personaId=user_id, externalId=phone_number_without_plus, integrationIdn="twilio_messenger", connectorIdn="sms_connector")[0].id | string %}

{{_prepareOutboundContextSkill(messageReason=message_reason, actorId=sms_actor, userId=user_id)}}

{{SendSystemEvent(
    eventIdn="outbound_send_sms_from_person",
    connectorIdn="system",
    actorIds=[sms_actor],
    messageText=greeting_phrase,
    taskId=task.id,
    phone_number=phone_number_without_plus
)}}
