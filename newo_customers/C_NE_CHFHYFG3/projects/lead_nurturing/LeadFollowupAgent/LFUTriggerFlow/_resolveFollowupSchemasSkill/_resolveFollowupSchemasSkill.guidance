{{#system~}}
{
    "type": "object",
    "properties": {
        "analysis": {
            "type": "string",
            "description": "Analysis of the <ConversationHistory> from a perspective of CTAs achieved."
        },
        "action_needed": {
            "type": "boolean",
            "description": "Set to true only if <ConversationHistory> achieved the CTA listed in <LeadNurturingInstruction>"
        },
        "contact_data": {
            "type": "string",
            "description": "Include all the contact data available about the user. For phone numbers, use E.164 format with country code provided in <UserInformation>."
        },
        "actions": {
            "type": "array",
            "description": "Array of actions needs to be done due to <LeadNurturingInstruction> for the CTA described in 'analysis'",
            "items": {
                "type": "object",
                "properties": {
                    "action_type": {
                        "type": "string",
                        "enum": ["send_email", "send_sms", "make_call", "create_meeting"]
                    },
                    "action_time": {
                        "type": "string",
                        "description": "Using time of the CTA and <ConversationMeta>, calculate relative date and time for the action to be completed. Format is YYYY-MM-DD HH:mm. If the action needs to be executed immediately, add a minute to the conversation time."
                    },
                    "action_description": {
                        "type": "string",
                        "description": "Describe what exactly needs to be done according to 'action_type', provide comprehensive information. For phone numbers, use E.164 format with country code provided in <UserInformation>."
                    }
                },
                "required": ["action_type", "action_time", "action_description"]
            }
        }
    },
    "required": ["analysis", "action_needed"]
}
{{~/system}}
{{Return(val=GetCurrentPrompt())}}
