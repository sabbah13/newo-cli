      "type": "string",
      "description": "Short explanation detailing why the row is considered a header or not."
    },
    "is_header": {
      "type": "boolean",
      "description": "Indicates whether the first row is a header row."
    }
  },
  "required": ["analysis", "is_header"]
} %}

{{Return(val="true" if json.loads(structured_generation(schema=schema, prompt=prompt)).is_header else "false")}}