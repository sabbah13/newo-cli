{{#if GetCustomerAttribute(field="project_attributes_private_feature_flag_multi_location") == "False"}}
    {{Return()}}
{{/if}}

{{Set(name="user_id", value=GetUser(field="id"))}}
{{Set(name="memory", value=GetTriggeredAct(fields=["memory"]))}}
{{Set(name="agent_answer", value=GetTriggeredAct(fields=["convoAgentAnswer"]))}}
{{Set(name="locations_description", value=GetCustomerAttribute(field="project_attributes_private_dynamic_business_locations_object"))}}
{{Set(name="locations_indexes", value=GetCustomerAttribute(field="project_attributes_private_dynamic_business_locations_indexes"))}}
{{#if IsEmpty(text=locations_indexes)}}
    {{Return()}}
{{/if}}
{{#if IsEmpty(text=locations_description)}}
    {{Return()}}
{{/if}}
{{Set(name="current_location", value=GetPersonaAttribute(id=user_id, field="multi_location_current_location"))}}
{{#system~}}
You are an AI agent that switches the business location for another AI agent.
Please, analyze the conversation between **ConvoAgent** and the **User** and figure out the target location listed in <LocationIndexes> for the <Conversation>. The User may inquire about multiple locations per conversation, so pay special attention to the latest messages and select latest location mentioned.

<LocationIndexes>
{{locations_description}}
</LocationIndexes>

<Conversation>
{{memory}}
ConvoAgent answers: {{agent_answer}}
</Conversation>
{{~/system}}
{{Set(name="location", value=Gen(temperature=0.1, topP=0, skipFilter=True, jsonSchema=_locationSelectSchemaSkill(indexes=locations_indexes), validateSchema=True, thinkingBudget=85))}}
{{Set(name="known", value=GetValueJSON(obj=location, key="location_known"))}}
{{#if known == "false"}}
    {{Return()}}
{{/if}}
{{Set(name="index", value=Stringify(GetValueJSON(obj=location, key="location_index")))}}
{{#if index == current_location}}
    {{Return()}}
{{/if}}
{{_locationSwitch(location=index, userId=user_id)}}
