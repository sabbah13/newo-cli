{{#system~}}
{
  "type": "object",
  "properties": {
    "location_known": {
      "type": "boolean",
      "description": "Some location from <LocationIndexes> is mentioned or inquired in the <Conversation> by the user."
    },
    "location_index": {
      "type": "string",
      "description": "JSON property name from <LocationIndexes> most relevant to the <Conversation>. Set to `default` if no specific location could be acquired.",
      "enum": {{indexes}}
    }
  },
  "required": [
    "location_index",
    "location_known"
  ]
}
{{~/system}}
{{Return(val=GetCurrentPrompt())}}