{% set arguments = GetTriggeredAct().arguments %}

{% set item = json.loads(arguments.body) %}
{% set type_idn = arguments.type_idn %}

{% set new_item = action_save_item(item=item, type_idn=type_idn) %}

{{SendCommand(
   commandIdn="update_item",
   integrationIdn="newo_chat",
   connectorIdn="workflow_builder",
   user_actor_id=GetActor().id|string,
   body=json.dumps(new_item, ensure_ascii=False, indent=2),
   type_idn=type_idn
)}}

{{prepare_instructions_update_from_library()}}
{{prepare_instructions_from_canvas()}}
