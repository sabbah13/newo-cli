{% set pattern = "\\[\\[([a-zA-Z_][a-zA-Z0-9_]*)\\]\\]" %}

{% set text = GetCustomerAttribute(field=template_attribute_name) %}

{% set attributes = re.findall(pattern, text) | unique %}

{% for attribute in attributes %}
    {% if not (attribute == template_attribute_name) %}
        {% set text = text.replace("[["~attribute~"]]", GetCustomerAttribute(field=attribute)) %}
    {% endif %}
{% endfor %}

{{SetCustomerAttribute(field=compiled_attribute_name, value=text)}}
