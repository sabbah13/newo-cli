{% set current_canvas = json.loads(GetCustomerAttribute(field="project_attributes_private_dynamic_workflow_builder_canvas_library_custom")) %}

{% set type_index = utils_get_object_index_by_key_value(obj=current_canvas, key="idn", value=type_idn).strip() %}

{% set items = current_canvas[type_index | int]["items"] %}
{% set old_item_index = utils_get_object_index_by_key_value(obj=items, key="idn", value=item_idn).strip() %}

{% if old_item_index %}
    {{items.pop(old_item_index | int)}}
{% endif %}

{{SetCustomerAttribute(field="project_attributes_private_dynamic_workflow_builder_canvas_library_custom", value=json.dumps(current_canvas, ensure_ascii=False, indent=2))}}
