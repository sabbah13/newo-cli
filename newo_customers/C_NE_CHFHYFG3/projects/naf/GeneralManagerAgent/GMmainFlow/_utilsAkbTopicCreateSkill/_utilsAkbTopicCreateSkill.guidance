{{!-- Creates AKB Topic if not exists --}}

{{!-- ! Important note: filtration by labels is used - be careful with adding and removing labels --}}

{{Set(
    name="existing_topic_id",
    value=SearchFuzzyAkb(
        query=name,
        searchFields=["name"],
        numberTopics=1,
        fields=["id"],
        labels=labels,
        filterByPersonaIds=personaId,
        scoreThreshold=1.0
    )
)}}

{{!-- If `overwrite` is not `True`, do not delete an existing AKB Topic --}}
{{#if overwrite != "True"}}
    {{#if not IsEmpty(text=existing_topic_id)}}
        {{Return()}}
    {{/if}}
{{else}}
    {{#if not IsEmpty(text=existing_topic_id)}}
        {{DeleteAkb(ids=existing_topic_id)}}
    {{/if}}
{{/if}}

{{!-- If Topic (template) does not exist, create it --}}
{{SetManualAkb(
    personaId=personaId,
    summary=summary,
    facts=facts,
    name=name,
    confidence=confidence,
    source=source,
    labels=labels
)}}
