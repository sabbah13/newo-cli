{{!-- Setting common Customer Attributes and AKB --}}
{{!--
    ! Important: current solution has a design flaw:
    common AKB topics will have default scenario label while industry might potentially have another "default" scenario
    TODO: potentially re-design setting default scenario label on common AKB topics
--}}

{{SendSystemEvent(eventIdn="set_sa_version", connectorIdn="system", global="True")}}

{{prepare_connectors()}}

{{_prepareAttributesCommonSkill()}}

{{_prepareMultiLocationFeaturesSkill()}}

{{!-- Setting industry-specific Customer Attributes and AKB --}}
{{Set(name="industry", value=GetCustomerAttribute(field="project_business_industry") )}}

{{#if industry == "catering_industry"}}
    {{_prepareAttributesCateringSkill()}}
{{/if}}

{{#if industry == "cleaning_industry"}}
    {{_prepareAttributesCleaningSkill()}}
{{/if}}

{{#if industry == "dental_industry"}}
    {{_prepareAttributesDentalSkill()}}
{{/if}}

{{#if industry == "home_service_industry"}}
    {{_prepareAttributesHomeServiceSkill()}}
{{/if}}

{{#if industry == "hospitality_industry"}}
    {{_prepareAttributesHospitalitySkill()}}
{{/if}}

{{#if industry == "restaurant_industry"}}
    {{_prepareAttributesRestaurantSkill()}}
    {{!-- This was left due to configuring the necessary reservation task–related topics. --}}
    {{_prepareAkbRestaurantSkill()}}
    {{!-- Building AKB from AKB Template (injecting Customer Attribute values into AKB Topics) --}}
    {{!-- TODO: Remove in the future --}}
    {{CopyAndBuildAkb(
        sourcePersonaId=GetAgent(idn="GeneralManagerAgent", field="personaId"),
        targetPersonaId=GetAgent(idn="ConvoAgent", field="personaId")
    )}}
{{/if}}

{{#if industry == "sales_industry"}}
    {{_prepareAttributesSalesSkill()}}
{{/if}}

{{#if industry == "beauty_industry"}}
    {{_prepareAttributesBeautySkill()}}
{{/if}}

{{#if industry == "technology_industry"}}
    {{_prepareAttributesTechnologySkill()}}
{{/if}}

{{! Applying dynamic Attributes (are being overwritten each time) }}
{{! TODO: Discuss why we can't call _prepareAttributesCommonSkill after setting industry specific attributes }}
{{_prepareAttributesCommonPrivateDynamicGreetingPhraseVoiceSkill()}}

{{SendSystemEvent(eventIdn="gm_prepare_instructions", connectorIdn="system", global="True")}}

{{_updateConnectorSettingsNewoVoiceSkill()}}
{{_updateConnectorSettingsNewoChatSkill()}}
