  {{SetState(name="previous_restaurant_googlemaps_reservation_url", value=" ")}}
  {{Return()}}
{{/if}}

{{!-- Exit if `Google Maps Reservation URL` was not changed --}}
{{Set(name="previous_restaurant_googlemaps_reservation_url", value=GetState(name="previous_restaurant_googlemaps_reservation_url"))}}
{{#if current_restaurant_googlemaps_reservation_url == previous_restaurant_googlemaps_reservation_url}}
  {{Set(name="dynamic_restaurant_google_restaurant_id", value=GetCustomerAttribute(field="project_attributes_private_dynamic_restaurant_google_restaurant_id"))}}
  {{Set(name="task_context_w1s3_reserve_table_task", value=GetCustomerAttribute(field="project_attributes_task_context_w1s3_reserve_table_task"))}}

  {{#if not IsEmpty(text=dynamic_restaurant_google_restaurant_id)}}
    {{#if not IsEmpty(text=task_context_w1s3_reserve_table_task)}}
      {{Return()}}
    {{/if}}
  {{/if}}

  {{#if not IsEmpty(text=task_context_w1s3_reserve_table_task)}}
    {{#if not IsEmpty(text=dynamic_restaurant_google_restaurant_id)}}
      {{Return()}}
    {{/if}}
  {{/if}}
{{/if}}

