{{!-- Important note: setting Attributes Metadata is a heavy operation so it is performed only one time when it was enabled explicitly --}}
{{SetProjectAttribute(field="project_attributes_setting_init_attributes_metadata_enabled", value="False")}}

{{rag_append_from_text()}}

{{rag_append_from_websites()}}

{{!-- Being triggered after setting up metadata because this Skill is not stable at the moment (generation fails in some cases --}}
{{_prepareAttributesCommonPrivateDynamicWorkScheduleObjectSkill()}}

{{!-- TODO: Move to a separate skill --}}
{{!-- Set `bypass / emergency phone number` Attribute if not set --}}
{{Set(name="bypass_phone_number", value=GetCustomerAttribute(field="project_attributes_setting_voice_integration_service_bypass_phone_number"))}}
{{#if IsEmpty(text=bypass_phone_number)}}
  {{Set(name="agent_voice_phone_number", value=GetCustomerAttribute(field="project_representative_agent_voice_phone_number"))}}
  {{Set(name="public_phone", value=GetCustomerAttribute(field="project_business_public_phone"))}}
  {{Set(name="working_hour_escalation_phone", value=GetCustomerAttribute(field="project_business_working_hour_escalation_phone"))}}

  {{Set(name="asr_redirection_type_working_hours", value=GetCustomerAttribute(field="project_attributes_setting_asr_redirection_type_working_hours"))}}
  {{!-- If `non-overflow`, recursion might happen in case of public phone usage --}}
  {{!-- (our system transfers to public phone, while call is being redirected back to Agent) --}}
  {{!-- So it is better to use escalation phone number instead of public phone --}}
  {{!-- If escalation phone number is the same as agent phone, we must not set any number at all --}}
  {{#if asr_redirection_type_working_hours == "non-overflow"}}
    {{!-- If escalation phone number is the same as agent phone, we must not set any number at all --}}
    {{#if agent_voice_phone_number == working_hour_escalation_phone}}
      {{Return()}}
    {{/if}}
    {{#if not IsEmpty(text=working_hour_escalation_phone)}}
      {{SetCustomerAttribute(field="project_attributes_setting_voice_integration_service_bypass_phone_number", value=working_hour_escalation_phone)}}
    {{/if}}
  {{/if}}

  {{!-- If `overflow`, there is a possibility of recursion but it is less probable so we can use public phone --}}
  {{!-- We need to check that public phone is not agent phone and use escalation phone number as a fallback --}}
  {{#if asr_redirection_type_working_hours == "overflow"}}
    {{#if agent_voice_phone_number == public_phone}}
      {{!-- If escalation phone number is the same as agent phone, we must not set any number at all --}}
      {{#if agent_voice_phone_number == working_hour_escalation_phone}}
        {{Return()}}
      {{/if}}
      {{#if not IsEmpty(text=working_hour_escalation_phone)}}
        {{SetCustomerAttribute(field="project_attributes_setting_voice_integration_service_bypass_phone_number", value=working_hour_escalation_phone)}}
      {{/if}}
    {{else}}
      {{#if not IsEmpty(text=public_phone)}}
        {{SetCustomerAttribute(field="project_attributes_setting_voice_integration_service_bypass_phone_number", value=public_phone)}}
      {{/if}}
    {{/if}}
  {{/if}}
{{/if}}
