{% if not utils_customer_attribute_exists(idn="project_attributes_setting_session_ended_webhook_auth_token") %}
    {{Return()}}
{% endif %}

{{utils_customer_attribute_rename(
    old_idn="project_attributes_setting_session_ended_webhook_auth_token",
    new_idn="project_attributes_setting_session_ended_webhook_auth_header"
)}}

{% set old_auth_value = GetCustomerAttribute(field="project_attributes_setting_session_ended_webhook_auth_header") %}

{% set scheme_pattern = re.compile("^[A-Za-z]+\\s+") %}

{% if scheme_pattern.match(old_auth_value) or not old_auth_value.strip() %}
    {# Has scheme, use as-is #}
    {{SetCustomerAttribute(
        field="project_attributes_setting_session_ended_webhook_auth_header",
        value=old_auth_value
    )}}
{% else %}
    {# No scheme, add Bearer #}
    {{SetCustomerAttribute(
        field="project_attributes_setting_session_ended_webhook_auth_header",
        value="Bearer " ~ old_auth_value
    )}}
{% endif %}
