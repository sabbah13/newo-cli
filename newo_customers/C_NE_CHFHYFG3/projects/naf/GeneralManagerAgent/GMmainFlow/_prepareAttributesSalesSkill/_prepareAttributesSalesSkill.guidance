{
  "tools": {
    "check_timezone_tool": {
      "description": "This tool checks and identifies timezones mismatches to help agent to correct its answer.",
      "conditions": {
        "timeZoneQuestioning": {
          "type": "boolean",
          "description": "The user's last message is **questioning** time **zone** / time **difference** (not just stating time/timezone). (it means that `tool` must be called to double-check whether Agent provided valid date and time conversion)."
        },
        "userInterestAboutTimeDifferenceActive": {
          "type": "boolean",
          "description": "If the user’s last message **changes topic**, **confirms understanding**, or **asks about something else**, this flag becomes `false`."
        },
        "redundantTimeClarificationsAbsent": {
          "type": "boolean",
          "description": "This flag is `true` only if the total count of agent messages in `<Conversation>` and `<LatestConvoAgentAnswer>` that mention **last** **related time** or **related timezones** is 0 or 1. If there are more than 1 mentions, tool must NOT be called."
        }
      },
      "useConversationHistory": true
    }
  }
}
