{{#system~}}
{
  "task_idn": "w1s3_reserve_table_task",
  "receiver_worker_idn": "SmsWorker",
  "receiver_task_idn": "w1s4_send_sms_user_task",
  "second_receiver_worker_idn": "NO_WORKER",
  "second_receiver_task_idn": "NO_TASK",
  "task_description": "Here MW books the slot at Opentable and sends the result to CW",
  "owner_send_due": "ASAP",
  "owner_task_start_user_message": " ",
  "owner_task_send_user_message": " ",
  "info": {
    "schema": {
      "type": "object",
      "properties": {
        "task_idn": {
          "type": "string",
          "enum": ["w1s3_reserve_table_task"],
          "description": "AF, always set this field to w1s3_reserve_table_task"
        },
        "user_phone": {
          "type": "string",
          "description": "AF, Set to user_phone from the TASK_CONTEXT"
        },
        "user_name": {
          "type": "string",
          "description": "AF, Set to user_name from the TASK_CONTEXT"
        },
        "time_slots_booked": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": {
                "type": "string",
                "format": "date"
              },
              "time_slot": {
                "type": "string"
              },
              "location": {
                "type": "string",
                "description": "Try to know location of the slot from BOT RESPONSE. Otherwise it should be optional missing."
              },
              "number_of_guests": {
                "type": "string"
              }
            },
            "required": [
              "date",
              "time_slot",
              "number_of_guests"
            ]
          }
        }
      }
    }
  }
}
{{~/system}}

{{Return(val=GetCurrentPrompt())}}
