{# 2. Parse previous_version and current_version into comparable tuples #}
{% set p_parts = previous_version.split('-')[0].split('.') | default(['0','0','0']) %}
{% set p_version_tuple = (p_parts[0] | int, p_parts[1] | int, p_parts[2] | int) %}

{% set c_parts = current_version.split('-')[0].split('.') | default(['999','999','999']) %}
{% set c_version_tuple = (c_parts[0] | int, c_parts[1] | int, c_parts[2] | int) %}

{# 3. Loop through the master skill list #}
{% for migration_skill_name in all_migration_skills %}
    {# a. Parse the version from the skill name string #}
    {% set name_parts = migration_skill_name.split('_') %}
    {# e.g., "_migration_3_4_0" -> ["", "migration", "3", "4", "0"] #}
    {% set m_version_tuple = (name_parts[2] | int, name_parts[3] | int, name_parts[4] | int) %}

    {# b. Check if the migration is within the required upgrade range #}
    {% if m_version_tuple > p_version_tuple and m_version_tuple <= c_version_tuple %}
        {# Handle special cases with extra conditions #}
        {% if migration_skill_name == "_migration_3_0_0" %}
            {% if not GetCustomerAttribute(field="project_attributes_private_dynamic_workflow_builder_canvas").strip() %}
                {{Do(actionName=migration_skill_name)}}
                {{ProjectImportSkill()}}
                {{Sleep(duration=30, interruptible="n")}}
            {% endif %}
        {% elif migration_skill_name == "_migration_3_0_4" %}
            {% if GetCustomerAttribute(field="project_attributes_private_dynamic_workflow_builder_canvas").strip() %}
                {{Do(actionName=migration_skill_name)}}
            {% endif %}
        {% else %}
            {# c. For all other standard migrations, just call them #}
            {{Do(actionName=migration_skill_name)}}
        {% endif %}
    {% endif %}
{% endfor %}
