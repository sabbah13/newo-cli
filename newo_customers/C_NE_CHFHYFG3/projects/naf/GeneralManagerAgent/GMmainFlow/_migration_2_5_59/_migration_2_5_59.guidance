{{Set(name="industry", value=GetCustomerAttribute(field="project_business_industry"))}}

{{!-- Update default value --}}
{{#if industry == "sales_industry"}}
  {{#if GetCustomerAttribute(field="project_attributes_sales_after_appointment_notes") == "*(No specific notes provided. Proceed with scheduling steps.)*"}}
      {{SetCustomerAttribute(field="project_attributes_sales_after_appointment_notes", value="*(No specific notes provided. Proceed with the next step.)*")}}
  {{/if}}
{{/if}}

{{!-- Remove redundant dot in `agent style` attribute --}}
{{Set(name="agent_style", value=GetCustomerAttribute(field="project_representative_agent_style"))}}
{{Set(name="agent_style", value=agent_style.replace("You can switch to other languages only if the User asks you to switch.", "You can switch to other languages only if the User asks you to switch"))}}
{{SetCustomerAttribute(field="project_representative_agent_style", value=agent_style)}}

{{!-- Reset to default value --}}
{{SetCustomerAttribute(field="project_attributes_setting_voice_integration_service_voice_to_voice_provider_genai_functions", value=" ")}}
{{SetCustomerAttribute(field="project_attributes_setting_voice_integration_service_voice_to_voice_provider_genai_functions_description", value=" ")}}
