{# Handle case where `project_attributes_rag_knowledge_base_append_websites_reset` is set to `True` #}
{% set rag_knowledge_base_append_websites_reset = GetCustomerAttribute(field="project_attributes_rag_knowledge_base_append_websites_reset") %}
{% if rag_knowledge_base_append_websites_reset.strip() == "True" %}
    {{rag_append_reset(label="rag_autogenerated_from_websites")}}
    {{SetCustomerAttribute(field="project_attributes_private_dynamic_rag_knowledge_base_append_websites_text", value="")}}
    {{SetCustomerAttribute(field="project_attributes_private_dynamic_rag_knowledge_base_append_websites_text_structured", value="")}}
    {{SetCustomerAttribute(field="project_attributes_rag_knowledge_base_append_websites_reset", value="False")}}
{% endif %}

{# Handle case where `project_attributes_rag_knowledge_base_append_websites` is not empty #}
{% set rag_knowledge_base_append_websites = GetCustomerAttribute(field="project_attributes_rag_knowledge_base_append_websites") %}
{# Check if not empty AND different from the last requested value to prevent loops #}
{% set previous_rag_knowledge_base_append_websites = GetState(name="previous_rag_knowledge_base_append_websites") %}
{% if rag_knowledge_base_append_websites.strip() and rag_knowledge_base_append_websites.strip() != previous_rag_knowledge_base_append_websites.strip() %}
    {{rag_append_website_search_request(objective=rag_knowledge_base_append_websites)}}
    {{SetState(name="previous_rag_knowledge_base_append_websites", value=rag_knowledge_base_append_websites)}}
    {{Return()}}
{# Handle case where it was cleared externally (after success) #}
{% elif not rag_knowledge_base_append_websites.strip() and previous_rag_knowledge_base_append_websites.strip() %}
    {{SetState(name="previous_rag_knowledge_base_append_websites", value="")}}
{% endif %}

{# Handle case where `project_attributes_private_dynamic_rag_knowledge_base_append_websites_text` is not empty (e.g. - was set manually) #}
{% set rag_knowledge_base_append_websites_text = GetCustomerAttribute(field="project_attributes_private_dynamic_rag_knowledge_base_append_websites_text") %}
{% if rag_knowledge_base_append_websites_text.strip() %}
    {{rag_append_convert_to_structured_text(
        input_unstructured_text=rag_knowledge_base_append_websites_text,
        output_structured_attribute_name="project_attributes_private_dynamic_rag_knowledge_base_append_websites_text_structured",
    )}}
    {{SetCustomerAttribute(field="project_attributes_private_dynamic_rag_knowledge_base_append_websites_text", value="")}}
{% endif %}

{# Handle case where `project_attributes_private_dynamic_rag_knowledge_base_append_websites_text_structured` is not empty (e.g. - was set manually) #}
{% set rag_knowledge_base_append_websites_text_structured = GetCustomerAttribute(field="project_attributes_private_dynamic_rag_knowledge_base_append_websites_text_structured") %}
{% if rag_knowledge_base_append_websites_text_structured.strip() %}
    {{rag_append_create_akb_topics(
        label="rag_autogenerated_from_websites",
        id_prefix="afw_",
        input_structured_text=rag_knowledge_base_append_websites_text_structured
    )}}
    {{SetCustomerAttribute(field="project_attributes_private_dynamic_rag_knowledge_base_append_websites_text_structured", value="")}}
{% endif %}
