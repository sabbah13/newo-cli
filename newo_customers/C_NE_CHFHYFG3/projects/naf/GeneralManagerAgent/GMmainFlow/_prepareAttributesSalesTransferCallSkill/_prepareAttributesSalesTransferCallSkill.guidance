{{Set(name="default_criteria", value="- Speak with the manager or co-worker (including returning or continuing a previous conversation);")}}

{{#if GetCustomerAttribute(field="project_attributes_setting_sms_send_information_enabled") == "True"}}
    {{Set(name="default_criteria", value=_utilsAppendRowSkill(rows=default_criteria, newRow="- Report that they have not received the information via SMS;"))}}
{{/if}}

{{_utilsCustomerAttributeSetIfEmptySkill(field="project_attributes_setting_transfer_call_enabled", value="True")}}

{{_utilsCustomerAttributeSetIfEmptySkill(field="project_attributes_setting_transfer_call_criteria", value=default_criteria)}}

{{_utilsCustomerAttributeSetIfEmptySkill(field="project_attributes_setting_transfer_call_confirmation_phrase", value="Would you like me to connect you with a co-worker now?")}}

{{_utilsCustomerAttributeSetIfEmptySkill(field="project_attributes_setting_transfer_call_additional_statement", value=" ")}}
