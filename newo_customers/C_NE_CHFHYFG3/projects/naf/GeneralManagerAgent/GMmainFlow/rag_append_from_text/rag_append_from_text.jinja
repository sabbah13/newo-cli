{# Handle case where `project_attributes_rag_knowledge_base_append_text_reset` is set to `True` #}
{% set rag_knowledge_base_append_text_reset = GetCustomerAttribute(field="project_attributes_rag_knowledge_base_append_text_reset") %}
{% if rag_knowledge_base_append_text_reset.strip() == "True" %}
    {{rag_append_reset(label="rag_autogenerated_from_text")}}
    {{SetCustomerAttribute(field="project_attributes_private_dynamic_rag_knowledge_base_append_text_structured", value="")}}
    {{SetCustomerAttribute(field="project_attributes_rag_knowledge_base_append_text_reset", value="False")}}
{% endif %}

{# Handle case where `project_attributes_rag_knowledge_base_append_text` is not empty #}
{% set rag_knowledge_base_append_text = GetCustomerAttribute(field="project_attributes_rag_knowledge_base_append_text") %}
{# Check if not empty AND different from the last requested value to prevent loops #}
{% set previous_rag_knowledge_base_append_text = GetState(name="previous_rag_knowledge_base_append_text") %}
{% if rag_knowledge_base_append_text.strip() and rag_knowledge_base_append_text.strip() != previous_rag_knowledge_base_append_text.strip() %}
    {{SetState(name="previous_rag_knowledge_base_append_text", value=rag_knowledge_base_append_text)}}
    {{rag_append_convert_to_structured_text(
        input_unstructured_text=rag_knowledge_base_append_text,
        output_structured_attribute_name="project_attributes_private_dynamic_rag_knowledge_base_append_text_structured"
    )}}
    {{rag_append_extend_log(
        input_unstructured_text=rag_knowledge_base_append_text,
        output_log_attribute_name="project_attributes_rag_knowledge_base_append_text_log"
    )}}
    {{SetCustomerAttribute(field="project_attributes_rag_knowledge_base_append_text", value="")}}
{# Handle case where it was cleared externally (after success) #}
{% elif not rag_knowledge_base_append_text.strip() and previous_rag_knowledge_base_append_text.strip() %}
    {{SetState(name="previous_rag_knowledge_base_append_text", value="")}}
{% endif %}

{# Handle case where `project_attributes_private_dynamic_rag_knowledge_base_append_text_structured` is not empty (e.g. - was set manually) #}
{% set rag_knowledge_base_append_text_structured = GetCustomerAttribute(field="project_attributes_private_dynamic_rag_knowledge_base_append_text_structured") %}
{% if rag_knowledge_base_append_text_structured.strip() %}
    {{rag_append_create_akb_topics(
        label="rag_autogenerated_from_text",
        id_prefix="aft_",
        input_structured_text=rag_knowledge_base_append_text_structured
    )}}
    {{SetCustomerAttribute(field="project_attributes_private_dynamic_rag_knowledge_base_append_text_structured", value="")}}
{% endif %}
