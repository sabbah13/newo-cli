{{_utilsCustomerAttributeSetIfEmptySkill(field="project_attributes_setting_transfer_call_enabled", value="True")}}

{{_utilsCustomerAttributeSetIfEmptySkill(field="project_attributes_setting_transfer_call_confirmation_phrase", value="Would you like me to connect you with a co-worker now?")}}

{{_utilsCustomerAttributeSetIfEmptySkill(field="project_attributes_setting_transfer_call_additional_statement", value=" ")}}

{{Set(name="instruction_make_reservation", value="- Make a reservation for less than `hospitality.large_group_reservation_minimum_party_size` people;")}}
{{Set(name="instruction_change_reservation", value="- Change/reschedule their reservation;")}}

{{Set(name="current_transfer_call_criteria", value=GetCustomerAttribute(field="project_attributes_setting_transfer_call_criteria"))}}
{{#if not IsEmpty(text=current_transfer_call_criteria)}}
    {{#if not IsEmpty(text=GetCustomerAttribute(field="project_attributes_hospitality_reservation_url"))}}
        {{Set(name="current_transfer_call_criteria", value=_utilsRemoveRowSkill(rows=current_transfer_call_criteria, rowToRemove=instruction_make_reservation))}}
        {{Set(name="current_transfer_call_criteria", value=_utilsRemoveRowSkill(rows=current_transfer_call_criteria, rowToRemove=instruction_change_reservation))}}
    {{else}}
        {{Set(name="current_transfer_call_criteria", value=_utilsAppendRowIfNotExistsSkill(rows=current_transfer_call_criteria, newRow=instruction_make_reservation))}}
        {{Set(name="current_transfer_call_criteria", value=_utilsAppendRowIfNotExistsSkill(rows=current_transfer_call_criteria, newRow=instruction_change_reservation))}}
    {{/if}}
    {{SetCustomerAttribute(field="project_attributes_setting_transfer_call_criteria", value=current_transfer_call_criteria)}}

{{else}}

{{#system~}}
- Confirm that their booking reservation is secured;
- Notify that they will be late for an existing reservation;
- Report a forgotten or lost item at the restaurant;
- Speak with customer service;
- Speak with the manager or co-worker (including returning or continuing a previous conversation);
- "customer service";
- "representative";
{{~/system}}
    {{Set(name="default_criteria", value=GetCurrentPrompt())}}
    {{#if IsEmpty(text=GetCustomerAttribute(field="project_attributes_hospitality_reservation_url"))}}
        {{Set(name="default_criteria", value=_utilsAppendRowSkill(rows=default_criteria, newRow=instruction_make_reservation))}}
        {{Set(name="default_criteria", value=_utilsAppendRowSkill(rows=default_criteria, newRow=instruction_change_reservation))}}
    {{/if}}
    {{SetCustomerAttribute(field="project_attributes_setting_transfer_call_criteria", value=default_criteria)}}
{{/if}}
