{{Set(name="previous_multilocation_locations", value=GetState(name="previous_multilocation_locations"))}}
{{Set(name="current_multilocation_locations", value=GetCustomerAttribute(field="project_business_locations"))}}

{{Set(name="previous_feature_flag", value=GetState(name="previous_multilocation_flag"))}}
{{Set(name="current_feature_flag", value=GetCustomerAttribute(field="project_attributes_private_feature_flag_multi_location"))}}

{{Set(name="current_dynamic_business_locations_indexes", value=GetCustomerAttribute(field="project_attributes_private_dynamic_business_locations_indexes"))}}
{{Set(name="current_dynamic_business_locations_object", value=GetCustomerAttribute(field="project_attributes_private_dynamic_business_locations_object"))}}

{{! Redefine private attributes if they are empty while locations are specified and feature flag is enabled }}
{{#if current_feature_flag == "True"}}
  {{#if not IsEmpty(text=current_multilocation_locations)}}
    {{Set(name="rebuild_private_attributes", value="False")}}
    {{#if IsEmpty(text=current_dynamic_business_locations_indexes)}}
      {{Set(name="rebuild_private_attributes", value="True")}}
    {{/if}}
    {{#if IsEmpty(text=current_dynamic_business_locations_object)}}
      {{Set(name="rebuild_private_attributes", value="True")}}
    {{/if}}
    {{#if rebuild_private_attributes == "True"}}
      {{_prepareMultiLocationLocationsAttributesSkill(baseLocations=current_multilocation_locations)}}
    {{/if}}
  {{/if}}
{{/if}}

{{! Quit if nothing changed }}
{{#if current_feature_flag == previous_feature_flag}}
  {{#if previous_multilocation_locations == current_multilocation_locations}}
    {{#if not IsEmpty(text=GetCustomerAttribute(field="project_attributes_private_dynamic_booking_check_availability_schema_template"))}}
      {{#if not IsEmpty(text=GetCustomerAttribute(field="project_attributes_private_dynamic_booking_schema_template"))}}
        {{Return()}}
      {{/if}}
    {{/if}}
  {{/if}}
{{/if}}

{{#if previous_multilocation_locations != current_multilocation_locations}}
  {{_prepareMultiLocationLocationsAttributesSkill(baseLocations=current_multilocation_locations)}}
  {{SetState(name="previous_multilocation_locations", value=current_multilocation_locations)}}
{{/if}}

{{! Feature flag state changed, we need to adjust attributes metadata }}
{{!--
TODO: Implement dynamic attribute metadata management.
If non-multilocation attribute value type is string,
then it should turn into json in case of multi-location.
But then if multi-location ff is off, we need to turn it back to normal (default state)
This is not required now as all multilocation attributes are json
--}}
{{#if current_feature_flag != previous_feature_flag}}
  {{#if current_feature_flag == "False"}}
    {{! Force restore default metadata }}
    {{! SetProjectAttribute(field="project_attributes_setting_init_attributes_metadata_enabled", value="True")}}
    {{! Reinitialize selected attributes }}
    {{_prepareMultiLocationFeaturesReinitializeAttributeSkill(attributeName="project_attributes_setting_booking_check_availability_payload_schema_template", side="to_normal")}}
    {{_prepareMultiLocationFeaturesReinitializeAttributeSkill(attributeName="project_attributes_setting_booking_check_availability_validation_schema_template", side="to_normal")}}
    {{_prepareMultiLocationFeaturesReinitializeAttributeSkill(attributeName="project_attributes_setting_booking_payload_schema_template", side="to_normal")}}
    {{_prepareMultiLocationFeaturesReinitializeAttributeSkill(attributeName="project_attributes_setting_booking_meta_fields_schema_template", side="to_normal")}}
  {{else}}
    {{! Prevent default metadata setup }}
    {{! SetProjectAttribute(field="project_attributes_setting_init_attributes_metadata_enabled", value="False")}}
    {{! Reinitialize selected attributes }}
    {{_prepareMultiLocationFeaturesReinitializeAttributeSkill(attributeName="project_attributes_setting_booking_check_availability_payload_schema_template", side="to_json")}}
    {{_prepareMultiLocationFeaturesReinitializeAttributeSkill(attributeName="project_attributes_setting_booking_check_availability_validation_schema_template", side="to_json")}}
    {{_prepareMultiLocationFeaturesReinitializeAttributeSkill(attributeName="project_attributes_setting_booking_payload_schema_template", side="to_json")}}
    {{_prepareMultiLocationFeaturesReinitializeAttributeSkill(attributeName="project_attributes_setting_booking_meta_fields_schema_template", side="to_json")}}
  {{/if}}
  {{SetState(name="previous_multilocation_flag", value=current_feature_flag)}}
{{/if}}
