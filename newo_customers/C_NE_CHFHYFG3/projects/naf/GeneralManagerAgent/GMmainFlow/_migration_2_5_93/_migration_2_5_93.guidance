{{!-- Move newly added Customer Attributes to Project Attributes --}}
{{!-- `project_description` --}}
{{Set(name="project_description_value", value=GetCustomerAttribute(field="project_description"))}}
{{DeleteCustomerAttribute(field="project_description")}}
{{SetProjectAttribute(field="project_description", value=project_description_value)}}

{{!-- `project_is_auto_update_enabled` --}}
{{Set(name="project_is_auto_update_enabled_value", value=GetCustomerAttribute(field="project_is_auto_update_enabled"))}}
{{DeleteCustomerAttribute(field="project_is_auto_update_enabled")}}
{{SetProjectAttribute(field="project_is_auto_update_enabled", value=project_is_auto_update_enabled_value)}}

{{!-- `project_name` --}}
{{Set(name="project_name_value", value=GetCustomerAttribute(field="project_name"))}}
{{DeleteCustomerAttribute(field="project_name")}}
{{SetProjectAttribute(field="project_name", value=project_name_value)}}

{{!-- `project_registry_idn` --}}
{{Set(name="project_registry_idn_value", value=GetCustomerAttribute(field="project_registry_idn"))}}
{{DeleteCustomerAttribute(field="project_registry_idn")}}
{{SetProjectAttribute(field="project_registry_idn", value=project_registry_idn_value)}}

{{!-- `project_registry_item_idn` --}}
{{Set(name="project_registry_item_idn_value", value=GetCustomerAttribute(field="project_registry_item_idn"))}}
{{DeleteCustomerAttribute(field="project_registry_item_idn")}}
{{SetProjectAttribute(field="project_registry_item_idn", value=project_registry_item_idn_value)}}

{{!-- `Demo_newo_chat_link` --}}
{{Set(name="demo_newo_chat_link_value", value=GetCustomerAttribute(field="Demo_newo_chat_link"))}}
{{DeleteCustomerAttribute(field="Demo_newo_chat_link")}}
{{SetProjectAttribute(field="project_attributes_newo_chat_link_demo", value=demo_newo_chat_link_value)}}


{{Set(name="industry", value=GetCustomerAttribute(field="project_business_industry"))}}

{{!-- Remove redundant attributes --}}
{{DeleteCustomerAttribute(field="project_attributes_setting_think_skill_enabled")}}
{{#if industry == "restaurant_industry"}}
  {{DeleteCustomerAttribute(field="project_attributes_restaurant_time_constraints")}}
{{/if}}

{{!-- Set a new default value --}}
{{#if industry == "sales_industry"}}
  {{SetCustomerAttribute(field="project_attributes_setting_timezone_reasoning_enabled", value="True")}}
{{/if}}
