{% set current_intent_type_map = GetCustomerAttribute(field="project_attributes_itm") %}
{% set current_intent_type_map = _utilsBuildIntentTypeMapFixHeadingSkill(intentTypeMap=current_intent_type_map) %}

{% set fixed_headers = {
    "Guest Support": "[T] Guest Support",
    "Contractor Support": "[T] Contractor Support",
    "Manager or Human Request": "[T] Manager or Human Request",
    "Reschedule or Modification": "[T] Reschedule or Modification",
    "Cancellation": "[T] Cancellation",
