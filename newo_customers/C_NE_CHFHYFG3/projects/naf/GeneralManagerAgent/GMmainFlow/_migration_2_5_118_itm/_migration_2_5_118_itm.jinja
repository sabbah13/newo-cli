    "Contractor Support": "[T] Contractor Support",
    "Existing Patient Appointment": "[T] Existing Patient Appointment",
    "Emergency Call": "[T] Emergency Call",
    "Patient Support": "[T] Patient Support",
    "Contractor Support": "[T] Contractor Support",
    "Other Services Request": "[L] Other Services Request",
    "Complaints": "[T] Complaints",
    "Emergency": "[T] Emergency",
    "Private Dining": "[L] Private Dining",
} %}

{% for header, fixed_header in fixed_headers.items() %}
    {% if fixed_header not in current_intent_type_map and header in current_intent_type_map %}
        {% set current_intent_type_map = current_intent_type_map.replace(header, fixed_header) %}
    {% endif %}
{% endfor %}

{{SetCustomerAttribute(field="project_attributes_itm", value=current_intent_type_map)}}
