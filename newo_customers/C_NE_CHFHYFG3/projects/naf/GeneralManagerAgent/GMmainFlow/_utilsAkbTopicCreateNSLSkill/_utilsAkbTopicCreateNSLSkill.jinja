{# Creates AKB Topic if not exists #}

{# ! Important note: filtration by labels is used - be careful with adding and removing labels #}
{% set labels = json.loads(labels) %}
{% set facts = json.loads(facts) %}

{% set existing_topic_id = "" %}

{% set existing_topics = SearchFuzzyAkb(
        query=name,
        searchFields=["name"],
        numberTopics=1,
        fields=["id"],
        labels=labels,
        filterByPersonaIds=[personaId],
        scoreThreshold=1.0
)%}

{% if existing_topics %}
    {% set existing_topic_id = existing_topics[0].topicId | string %}
{% endif %}

{# If `overwrite` is not `True`, do not delete an existing AKB Topic #}
{% if overwrite != "True" %}
    {% if existing_topic_id %}
        {{Return()}}
    {% endif %}
{% else %}
    {% if existing_topic_id %}
        {{DeleteAkb(ids=[existing_topic_id])}}
    {% endif %}
{% endif %}

{# If Topic (template) does not exist, create it #}
{{SetManualAkb(
    personaId=personaId,
    summary=summary,
    facts=facts,
    name=name,
    confidence=confidence,
    source=source,
    labels=labels
)}}
