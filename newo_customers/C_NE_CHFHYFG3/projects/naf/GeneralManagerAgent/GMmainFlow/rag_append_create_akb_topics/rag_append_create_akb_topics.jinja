{# Handle case where `label` is empty #}
{% if not label.strip() %}
    {{Return()}}
{% endif %}

{# Handle case where `id_prefix` is empty #}
{% if not id_prefix.strip() %}
    {{Return()}}
{% endif %}

{# Find existing AKB topics to determine the next index #}
{% set persona_id = GetAgentPersona().id %}
{% set found_topics = SearchFuzzyAkb(
    query="",
    searchFields=["name"],
    numberTopics=99999,
    labels=[label],
    filterByPersonaIds=[persona_id],
    scoreThreshold=0.0
) %}

{# Calculate the maximum index from existing topics matching the `id_prefix` in their source field #}
{% set max_index = 0 %}
{% for topic in found_topics %}
    {# Check if topic has a source field and if it starts with the expected prefix #}
    {% if topic.source and topic.source.startswith(id_prefix) %}
        {# Extract the numeric part after the prefix #}
        {% set suffix = topic.source[id_prefix|length:] %}
        {# Attempt to convert to integer. We use -1 as default to ignore non-numeric suffixes #}
        {% set idx = suffix | int(-1) %}
        {% if idx > -1 %}
            {% if idx > max_index %}
                {% set max_index = idx %}
            {% endif %}
        {% endif %}
    {% endif %}
{% endfor %}

{# Handle case where input text is empty #}
{% if not input_structured_text.strip() %}
    {{Return()}}
{% endif %}

{# Handle case where input text is not empty #}
{% set industry = GetCustomerAttribute(field="project_business_industry") %}
{% set scenario = GetCustomerAttribute(field="project_attributes_scenario") %}
{% set labels_base = [industry, scenario, "rag_context", label] %}

{# ============================================================
    Jinja2 template: Parse structured Markdown into RAG topics (Append Mode)
    INPUT:
        - input_structured_text: a single string that may contain one or more topics
            separated by '<<<RAG_TOPIC_SEPARATOR>>>'.
    OUTPUT:
        - For each topic, invokes SetManualAkb(...) with fields mapped as:
            H1 (#)                      -> name
            First H2 (##)               -> facts        (Markdown "summary")
            Second H2 (##)              -> labels       (comma/semicolon separated)
            All content after 2nd H2    -> summary      (Markdown "content")

    Additional notes:
        - Append Mode: Does NOT delete existing topics.
        - Calculates the next available `source` index based on the max index of existing
            topics that match the `id_prefix` in their `source` field.
        - Labels may be quoted and delimited by ',' or ';' (quotes are stripped).
        - Any extra H2 beyond the second is preserved as part of "content".
        - If a section is missing, an empty string/list is used to stay robust.
        - Topic IDs (source) are generated as 'id_prefix' + a zero-padded index.

    Assumptions:
        - The Markdown is "structured" as specified; however, the template
            defensively handles missing headers and stray lines.
============================================================ #}

{# 1) Normalize newlines and trim whitespace #}
{% set text_normalized = input_structured_text
    | replace('\r\n', '\n')
    | replace('\r', '\n')
    | trim
%}

{% set start_fence_removed = false %}

{# 2) Remove "```md" or "```" only from the beginning #}
{% if text_normalized.startswith('```md') %}
    {% set text_normalized = text_normalized[5:] %}
    {% set start_fence_removed = true %}
{% elif text_normalized.startswith('```') %}
    {% set text_normalized = text_normalized[3:] %}
    {% set start_fence_removed = true %}
{% endif %}

{# 3) Remove "```" from the end only if a start fence was removed #}
{% if start_fence_removed and text_normalized.endswith('```') %}
    {% set text_normalized = text_normalized[:-3] %}
{% endif %}

{% set input_structured_text_normalized = text_normalized %}

{# 2) Collect topic blocks once to know the total count #}
{% set blocks = [] %}
{% for raw in input_structured_text_normalized.split('<<<RAG_TOPIC_SEPARATOR>>>') %}
    {% set blk = raw.strip() %}
    {% if blk %}
        {% set _ = blocks.append(blk) %}
    {% endif %}
{% endfor %}

{# 3) Compute padding width based on the final total count (existing + new) #}
{% set total_new = blocks | length %}
{% set final_total = max_index + total_new %}
{% set width = (final_total | string) | length %}

{# 4) Process each topic block #}
{% for block in blocks %}
    {# Calculate current index starting from max_index + 1 #}
    {% set current_index = max_index + loop.index %}

    {# Split current block into lines for parsing #}
    {% set lines = block.split('\n') %}

    {# Namespace fields:
        - title: H1 text -> SetManualAkb.name
        - facts: first H2 text -> SetManualAkb.facts
        - labels_line: second H2 raw text (to be split)
        - content: lines after the 2nd H2 -> SetManualAkb.summary
        - h2: counter of encountered '##' headers #}
    {% set ns = namespace(title='', facts='', labels_line='', content=[], h2=0) %}

    {# Parse the block structure #}
    {% for _line in lines %}
        {% set line = _line.strip() %}

        {# Capture title exactly once, on the first H1 #}
        {% if line.startswith('# ') and ns.title == '' %}
            {% set ns.title = line[2:] | trim %}

        {# Handle H2 sections #}
        {% elif line.startswith('## ') %}
            {% set ns.h2 = ns.h2 + 1 %}

            {# First H2 -> "facts" (Markdown "summary") #}
            {% if ns.h2 == 1 %}
                {% set ns.facts = line[3:] | trim %}

            {# Second H2 -> "labels" (raw, to be split later) #}
            {% elif ns.h2 == 2 %}
                {% set ns.labels_line = line[3:] | trim %}

            {# Any H2 beyond the second is considered part of content #}
            {% else %}
                {% set _ = ns.content.append(_line) %}
            {% endif %}

        {# Non-header lines: only considered as content after the second H2 #}
        {% else %}
            {% if ns.h2 >= 2 %}
                {% set _ = ns.content.append(_line) %}
            {% endif %}
        {% endif %}
    {% endfor %}

    {# Join collected content lines and trim outer whitespace #}
    {% set content = (ns.content | join('\n')) | trim %}

    {# Build the labels list:
        - Support both ';' and ',' as delimiters
        - Strip quotes and whitespace
        - Drop empty tokens #}
    {% set labels_raw = (ns.labels_line | replace(';', ',')).split(',') %}
    {% set labels = [] %}
    {% for tok in labels_raw %}
        {% set t = tok
            | trim
            | replace('"', '')
            | replace("'", '')
        %}
        {% if t %}
            {% set _ = labels.append(t) %}
        {% endif %}
    {% endfor %}

    {# Zero-padded source index #}
    {% set index_padded = '%0*d' | format(width, current_index) %}
    {% set source_id = id_prefix ~ index_padded %}

    {# Emit the RAG topic with the required mapping:
            - summary  <- content (Markdown body after 2nd H2)
            - facts    <- first H2 (Markdown "summary")
            - name     <- H1 (Markdown title)
            - labels   <- predefined static labels + parsed list
            - source   <- id_prefix<index> #}
    {{ SetManualAkb(
        personaId = persona_id,
        summary = content,
        facts = [ns.facts],
        name = ns.title,
        source = source_id,
        labels = labels_base + labels
    ) }}

{% endfor %}
