{{!-- Set new recommended NEWO Voice Connector settings --}}
{{!-- Checking Connector presence before setting --}}
{{Set(name="top_p", value=GetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_top_p"))}}
{{#if not IsEmpty(text=top_p)}}
    {{SetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_top_p", value="0.6")}}
{{/if}}

{{!-- Enable `tools` for NEWO Voice --}}
{{SetCustomerAttribute(field="project_attributes_setting_voice_integration_service_voice_to_voice_provider_genai_functions_enabled", value="True")}}
