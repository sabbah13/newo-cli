{{Set(name="current_work_schedule", value=GetCustomerAttribute(field="project_business_working_hours"))}}

{{#if IsEmpty(text=current_work_schedule)}}
  {{SetCustomerAttribute(field="project_attributes_private_dynamic_schedule_non_working_days", value=" ")}}
  {{SetCustomerAttribute(field="project_attributes_private_dynamic_schedule_working_days", value=" ")}}
  {{SetCustomerAttribute(field="project_attributes_private_dynamic_schedule_working_hours", value=" ")}}
  {{SetCustomerAttribute(field="project_attributes_private_dynamic_schedule_working_days_hours_exceptions", value=" ")}}
  {{Return()}}
{{/if}}

{{Set(name="previous_work_schedule", value=GetState(name="previous_work_schedule"))}}

{{#if current_work_schedule == previous_work_schedule}}
  {{!-- TODO: Refactor --}}

  {{Set(name="current_working_days", value=GetCustomerAttribute(field="project_attributes_private_dynamic_schedule_working_days"))}}
  {{Set(name="current_working_hours", value=GetCustomerAttribute(field="project_attributes_private_dynamic_schedule_working_hours"))}}

  {{!-- TODO: Add `current_non_working_days` and `working_days_hours_exceptions` --}}

  {{#if not IsEmpty(text=current_working_hours)}}
    {{#if not IsEmpty(text=current_working_days)}}
      {{Return()}}
    {{/if}}
  {{/if}}

  {{#if not IsEmpty(text=current_working_days)}}
    {{#if not IsEmpty(text=current_working_hours)}}
      {{Return()}}
    {{/if}}
  {{/if}}

{{/if}}

{{Set(name="schema", value=_prepareAttributesCommonPrivateDynamicWorkScheduleSchemaSkill())}}

{{#system~}}
You will be provided with the work schedule of a business specified in <BusinessWorkSchedule>.
Your goal is to build a JSON object according to the schema.

Important: in the "working_days_hours_exceptions" property, explicitly mention how holidays are handled, even if they simply follow the normal schedule:
- Do NOT set "working_days_hours_exceptions" to "null" if there is information about how holidays are handled.
- If all holidays follow the normal working schedule, explicitly state something like "All holidays follow the normal schedule."

<BusinessWorkSchedule alt="business work schedule" role="context">
{{current_work_schedule}}
</BusinessWorkSchedule>

JSON object: {{~/system}}{{#assistant~}}{{Set(name="work_schedule_json", value=Gen(jsonSchema=schema, validateSchema="True", temperature=0.2, topP=0, skipFilter=True, maxTokens=4000, thinkingBudget=1020), expose=True)}}{{~/assistant}}

{{SetCustomerAttribute(field="project_attributes_private_dynamic_schedule_working_days", value=Stringify(GetValueJSON(obj=work_schedule_json, key="working_days")))}}
{{SetCustomerAttribute(field="project_attributes_private_dynamic_schedule_working_hours", value=Stringify(GetValueJSON(obj=work_schedule_json, key="working_hours")))}}

{{Set(name="non_working_days", value=Stringify(GetValueJSON(obj=work_schedule_json, key="non_working_days")))}}
{{#if not IsSimilar(val1=non_working_days, val2="null", threshold=0.7)}}
    {{SetCustomerAttribute(field="project_attributes_private_dynamic_schedule_non_working_days", value=non_working_days)}}
{{else}}
    {{SetCustomerAttribute(field="project_attributes_private_dynamic_schedule_non_working_days", value=" ")}}
{{/if}}

{{Set(name="working_days_hours_exceptions", value=Stringify(GetValueJSON(obj=work_schedule_json, key="working_days_hours_exceptions")))}}
{{#if not IsSimilar(val1=working_days_hours_exceptions, val2="null", threshold=0.7)}}
    {{SetCustomerAttribute(field="project_attributes_private_dynamic_schedule_working_days_hours_exceptions", value=working_days_hours_exceptions)}}
{{else}}
    {{SetCustomerAttribute(field="project_attributes_private_dynamic_schedule_working_days_hours_exceptions", value=" ")}}
{{/if}}

{{SetState(name="previous_work_schedule", value=current_work_schedule)}}
