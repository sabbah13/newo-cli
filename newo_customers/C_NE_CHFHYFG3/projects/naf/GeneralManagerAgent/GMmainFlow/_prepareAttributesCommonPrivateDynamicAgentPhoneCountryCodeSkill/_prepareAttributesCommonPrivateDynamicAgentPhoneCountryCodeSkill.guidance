{{Set(name="country", value=GetCustomerAttribute(field="project_representative_agent_voice_phone_alpha2_code"))}}

{{Set(name="country_codes_map", value=_prepareAttributesCommonPrivateDynamicAgentPhoneCountryCodeMappingSkill())}}

{{Set(name="country_code", value=Stringify(GetValueJSON(obj=country_codes_map, key=country)))}}

{{#if not IsEmpty(text=country_code)}}
    {{SetCustomerAttribute(field="project_representative_agent_voice_phone_country_code", value=country_code)}}
{{else}}
    {{SetCustomerAttribute(field="project_representative_agent_voice_phone_country_code", value="null")}}
{{/if}}
