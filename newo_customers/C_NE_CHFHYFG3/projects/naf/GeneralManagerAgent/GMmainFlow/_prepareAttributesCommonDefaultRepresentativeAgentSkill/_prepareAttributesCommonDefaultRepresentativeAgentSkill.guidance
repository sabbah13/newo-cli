{{Set(name="is_first_init_done", value=GetCustomerAttribute(field="project_attributes_private_account_initialized_first_time"))}}
{{!-- All `representative agent` common Customer Attributes must be specified here with default values --}}
{{!-- (must be sorted alphabetically) --}}

{{! Is being set in each industry independently }}
{{_utilsCustomerAttributeSetIfEmptySkill(field="project_representative_agent_chat_greeting_phrase", value=" ")}}

{{set_customer_attribute_from_ac_if_first_init_and_empty(is_first_init_done=is_first_init_done, naf_field="project_representative_agent_name", ac_field="agent_creator_agent_info_name")}}

{{_utilsCustomerAttributeSetIfEmptySkill(field="project_representative_agent_chat_formatting_style", value="- Do not use any lists (numbered or bulleted) when communicating information.
- Summarize all details in a single sentence where appropriate.
- Do not use markdown formatting.
- Do not use hashtags.
- Do not use emojis.")}}

{{_utilsCustomerAttributeSetIfEmptySkill(field="project_representative_agent_chat_speaking_style", value="Friendly professional, super welcoming.")}}

{{_utilsCustomerAttributeSetIfEmptySkill(field="project_representative_agent_providing_prices_explicit_constraint", value=" ")}}

{{_utilsCustomerAttributeSetIfEmptySkill(field="project_representative_agent_voicemail_detection_behavior_instruction", value="Leave a clear, meaningful message. State your name, company, the reason for your call, and what you need from them. Then explicitly say goodbye. Keep it brief but clear.")}}

{{_utilsCustomerAttributeSetIfEmptySkill(field="project_representative_agent_voice_speaking_style", value=_prepareAgentStyleSkill())}}

{{set_customer_attribute_from_ac_if_first_init_and_empty(is_first_init_done=is_first_init_done, naf_field="project_representative_agent_title", ac_field="agent_creator_agent_info_title")}}

{{!-- TODO: Potentially, translate disclaimer phrase in `agent_creator_voice_channel_disclaimer_phrase` (on the Agent Creator side) --}}
{{Set(name="language_primary", value=GetCustomerAttribute(field="project_business_language_primary"))}}
{{utils_customer_attribute_set_if_empty_depending_on_language(
    attribute_idn="project_representative_agent_voice_disclaimer_phrase",
    input_text="This call may be recorded.",
    input_text_language="English",
    target_language=language_primary
)}}

{{Set(name="agent_gender", value=_prepareAgentGenderSkill())}}
{{_utilsCustomerAttributeSetIfEmptySkill(field="project_representative_agent_gender", value=agent_gender)}}

