{{Set(name="industry", value=GetCustomerAttribute(field="project_business_industry"))}}

{{!-- Rename existing scenario name in Sales BOI --}}
{{#if industry == "sales_industry"}}
  {{Set(name="boi", value=GetCustomerAttribute(field="project_attributes_boi"))}}
  {{Set(name="boi", value=boi.replace("Appointment Setting via Calendar", "Appointment Setting via Calendar Invite"))}}
  {{SetCustomerAttribute(field="project_attributes_boi", value=boi)}}
{{/if}}

{{#if industry == "restaurant_industry"}}
  {{!-- Reset attributes in case of default booking settings to deliver fix for `isWithinBookingWindow` --}}
  {{#if GetCustomerAttribute(field="project_attributes_setting_booking_check_availability_type") == "default"}}
      {{SetCustomerAttribute(field="project_attributes_setting_booking_check_availability_validation_schema_template", value=" ")}}
      {{SetCustomerAttribute(field="project_attributes_private_dynamic_booking_check_availability_schema_template", value=" ")}}
  {{/if}}
{{/if}}

{{!-- Set new recommended NEWO Voice Connector settings --}}
{{!-- Checking Connector presence before setting --}}
{{Set(name="top_p", value=GetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_top_p"))}}
{{#if not IsEmpty(text=top_p)}}
  {{SetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_top_p", value="0.95")}}
{{/if}}

{{Set(name="temperature", value=GetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_temperature"))}}
{{#if not IsEmpty(text=temperature)}}
  {{SetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_temperature", value="1.0")}}
{{/if}}

{{!-- Regenerate or edit value in some cases --}}
{{Set(name="agent_style", value=GetCustomerAttribute(field="project_representative_agent_style"))}}
{{Set(name="regenerate_value", value="False")}}
{{#if agent_style == "friendly professional"}}
  {{Set(name="regenerate_value", value="True")}}
{{/if}}
{{#if agent_style == "Friendly professional"}}
  {{Set(name="regenerate_value", value="True")}}
{{/if}}
{{#if regenerate_value == "True"}}
  {{SetCustomerAttribute(field="project_representative_agent_style", value=" ")}}
{{else}}
  {{Set(name="agent_style", value=agent_style.replace(", a super cheerful person", Stringify(" ")))}}
  {{SetCustomerAttribute(field="project_representative_agent_style", value=agent_style)}}
{{/if}}
