{{Set(name="persona_id", value=GetAgentPersona(field="id"))}}
{{Set(name="industry", value=GetCustomerAttribute(field="project_business_industry"))}}
{{Set(name="scenario", value=GetCustomerAttribute(field="project_attributes_scenario"))}}
{{Set(
    name="default_labels",
    value=CreateArray(
        industry,
        scenario
    )
)}}

{{!-- Scenario: `Custom Scenario` --}}
{{#if scenario == "Custom Scenario"}}
    {{Return()}}
{{/if}}

