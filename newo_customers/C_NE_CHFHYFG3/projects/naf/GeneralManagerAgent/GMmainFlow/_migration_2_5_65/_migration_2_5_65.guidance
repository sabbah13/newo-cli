{{Set(name="industry", value=GetCustomerAttribute(field="project_business_industry"))}}

{{#if industry == "sales_industry"}}
  {{Set(name="boi", value=GetCustomerAttribute(field="project_attributes_boi"))}}
  {{Set(name="boi", value=boi.replace("Invite Invite Invite Invite Invite", "Invite"))}}
  {{Set(name="boi", value=boi.replace("Invite Invite Invite Invite", "Invite"))}}
  {{Set(name="boi", value=boi.replace("Invite Invite Invite", "Invite"))}}
  {{Set(name="boi", value=boi.replace("Invite Invite", "Invite"))}}
  {{Set(name="boi", value=boi.replace("Appointment Setting Via Calendar Invite", "Appointment Setting via Calendar Invite"))}}
  {{SetCustomerAttribute(field="project_attributes_boi", value=boi)}}

  {{Set(name="custom_scenarios", value=GetCustomerAttribute(field="project_attributes_custom_scenarios"))}}
  {{Set(name="custom_scenarios", value=custom_scenarios.replace("Appointment Setting via Calendar", "Appointment Setting via Calendar Invite"))}}
  {{Set(name="custom_scenarios", value=custom_scenarios.replace("Invite Invite Invite Invite Invite", "Invite"))}}
  {{Set(name="custom_scenarios", value=custom_scenarios.replace("Invite Invite Invite Invite", "Invite"))}}
  {{Set(name="custom_scenarios", value=custom_scenarios.replace("Invite Invite Invite", "Invite"))}}
  {{Set(name="custom_scenarios", value=custom_scenarios.replace("Invite Invite", "Invite"))}}
  {{Set(name="custom_scenarios", value=custom_scenarios.replace("Appointment Setting Via Calendar Invite", "Appointment Setting via Calendar Invite"))}}
  {{SetCustomerAttribute(field="project_attributes_custom_scenarios", value=custom_scenarios)}}
{{/if}}

{{#if industry == "cleaning_industry"}}
  {{Set(name="boi", value=GetCustomerAttribute(field="project_attributes_boi"))}}
  {{Set(name="boi", value=boi.replace("Relay Cleaning Request", "Relay Cleaning Appointment Request"))}}
  {{SetCustomerAttribute(field="project_attributes_boi", value=boi)}}
{{/if}}


{{!-- Reset to new default value --}}
{{SetCustomerAttribute(field="project_attributes_setting_voice_integration_service_voice_to_voice_provider_genai_functions_enabled", value="True")}}

{{!-- Enable V2V for NEWO Voice --}}
{{SetCustomerAttribute(field="project_attributes_setting_voice_integration_service_voice_mode", value="voice-to-voice")}}

{{!-- Set new recommended NEWO Voice Connector settings --}}
{{!-- Checking Connector presence before setting --}}
{{Set(name="tokens_sliding_window", value=GetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_tokens_sliding_window"))}}
{{#if not IsEmpty(text=tokens_sliding_window)}}
  {{SetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_tokens_sliding_window", value="65536")}}
{{/if}}

{{Set(name="top_p", value=GetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_top_p"))}}
{{#if not IsEmpty(text=top_p)}}
  {{SetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_top_p", value="1.0")}}
{{/if}}

{{Set(name="temperature", value=GetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_temperature"))}}
{{#if not IsEmpty(text=temperature)}}
  {{SetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_temperature", value="0.75")}}
{{/if}}

{{Set(name="speech_activity_start_sensitivity", value=GetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_speech_activity_start_sensitivity"))}}
{{#if not IsEmpty(text=speech_activity_start_sensitivity)}}
  {{SetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_speech_activity_start_sensitivity", value="high")}}
{{/if}}

{{Set(name="speech_activity_stop_sensitivity", value=GetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_speech_activity_stop_sensitivity"))}}
{{#if not IsEmpty(text=speech_activity_stop_sensitivity)}}
  {{SetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_speech_activity_stop_sensitivity", value="high")}}
{{/if}}

{{Set(name="turn_coverage", value=GetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_turn_coverage"))}}
{{#if not IsEmpty(text=turn_coverage)}}
  {{SetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_turn_coverage", value="only_activity")}}
{{/if}}

{{Set(name="model", value=GetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_model"))}}
{{#if not IsEmpty(text=model)}}
  {{SetConnectorInfo(integrationIdn="newo_voice", connectorIdn="newo_voice_connector", field="genai_v2v_model", value="gemini-live-2.5-flash-preview-native-audio")}}
{{/if}}
