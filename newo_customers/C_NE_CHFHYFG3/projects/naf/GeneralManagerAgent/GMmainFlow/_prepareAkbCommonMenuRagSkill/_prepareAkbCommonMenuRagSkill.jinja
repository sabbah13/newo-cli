{% set result = json.loads(Gen(temperature=0.1, jsonSchema=_prepareAkbCommonMenuRagSchemaSkill(), validateSchema=True, topP=0, skipFilter=True, max_tokens=65536, thinkingBudget=8192)) %}

{% set general_manager_persona_id = GetAgentPersona(field="id").id|string %}
{# delete existing menu rag #}
{% set current_menu_rag = SearchFuzzyAkb(
    query=" ",
    searchFields=["name"],
    labels=["rag_context_menu"],
    filterByPersonaIds=[general_manager_persona_id],
    scoreThreshold=0,
    numberTopics=500
) %}
{% set topicIds = [] %}
{% for topic in current_menu_rag %}
    {{topicIds.append(topic.topicId|string)}}
{% endfor %}
{% if topicIds %}
    {{DeleteAkb(ids=topicIds)}}
{% endif %}

{# add new menu rag #}
{% set index = 0 %}
{% for topic in result.chunks %}
    {{SetManualAkb(
        personaId=general_manager_persona_id,
        summary=topic.value,
        facts=[topic.facts],
        name=topic.name,
        confidence=100,
        source="menu" ~ index | string,
        labels=["rag_context", "rag_context_menu"]
    )}}
    {% set index = index + 1 %}
{% endfor %}
