{{Set(name="current_catering_menu", value=GetCustomerAttribute(field="project_attributes_catering_menu"))}}

{{!-- Exit if `Catering Menu` is empty --}}
{{#if IsEmpty(text=current_catering_menu)}}
    {{!-- TODO: Delete `AKB` item --}}
    {{Return()}}
{{/if}}

{{!-- Exit if `Catering Menu` was not changed --}}
{{Set(name="previous_catering_menu", value=GetState(name="previous_catering_menu"))}}
{{#if current_catering_menu == previous_catering_menu}}
    {{!-- TODO: Check if `AKB` topic exists --}}
    {{Return()}}
{{/if}}

{{!-- Validate, transform and set `Restaurant Menu Overview` --}}
{{Set(name="menu_overview", value=_prepareAkbCommonMenuOverviewSkill(currentMenu=current_catering_menu))}}
{{SetCustomerAttribute(field="project_attributes_catering_menu_overview", value=menu_overview)}}
{{_prepareAkbCommonMenuRagSkill(currentMenu=current_catering_menu)}}
{{SetState(name="previous_catering_menu", value=current_catering_menu)}}
