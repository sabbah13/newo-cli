{{Set(name="instruction_food_order", value="- Order food, pickup order, or order to go;")}}
{{Set(name="instruction_table_booking", value="- Book a table for less than `restaurant.large_group_reservation_minimum_party_size` people;")}}
{{Set(name="instruction_change_reservation", value="- Change/reschedule their reservation;")}}

{{Set(name="current_additional_limitations_and_restrictions", value=GetCustomerAttribute(field="project_attributes_setting_additional_limitations_and_restrictions"))}}
{{#if not IsEmpty(text=current_additional_limitations_and_restrictions)}}
    {{#if not IsEmpty(text=GetCustomerAttribute(field="project_attributes_restaurant_order_url"))}}
        {{Set(name="current_additional_limitations_and_restrictions", value=_utilsRemoveRowSkill(rows=current_additional_limitations_and_restrictions, rowToRemove=instruction_food_order))}}
    {{else}}
        {{Set(name="current_additional_limitations_and_restrictions", value=_utilsAppendRowIfNotExistsSkill(rows=current_additional_limitations_and_restrictions, newRow=instruction_food_order))}}
    {{/if}}

    {{#if not IsEmpty(text=GetCustomerAttribute(field="project_attributes_restaurant_googlemaps_reservation_url"))}}
        {{Set(name="current_additional_limitations_and_restrictions", value=_utilsRemoveRowSkill(rows=current_additional_limitations_and_restrictions, rowToRemove=instruction_table_booking))}}
        {{Set(name="current_additional_limitations_and_restrictions", value=_utilsRemoveRowSkill(rows=current_additional_limitations_and_restrictions, rowToRemove=instruction_change_reservation))}}
    {{else}}
        {{Set(name="current_additional_limitations_and_restrictions", value=_utilsAppendRowIfNotExistsSkill(rows=current_additional_limitations_and_restrictions, newRow=instruction_table_booking))}}
        {{Set(name="current_additional_limitations_and_restrictions", value=_utilsAppendRowIfNotExistsSkill(rows=current_additional_limitations_and_restrictions, newRow=instruction_change_reservation))}}
    {{/if}}
    {{SetCustomerAttribute(field="project_attributes_setting_additional_limitations_and_restrictions", value=current_additional_limitations_and_restrictions)}}

{{else}}

{{#system~}}
- Confirm that their table reservation is secured;
- Notify that they will be late for an existing reservation;
- Participate in or book a table for a special event mentioned in the context;
- Order catering;
- Report a forgotten or lost item at the restaurant;
- Speak with customer service;
{{~/system}}
    {{Set(name="default_criteria", value=GetCurrentPrompt())}}
    {{#if IsEmpty(text=GetCustomerAttribute(field="project_attributes_restaurant_order_url"))}}
        {{Set(name="default_criteria", value=_utilsAppendRowSkill(rows=default_criteria, newRow=instruction_food_order))}}
    {{/if}}

    {{#if IsEmpty(text=GetCustomerAttribute(field="project_attributes_restaurant_googlemaps_reservation_url"))}}
        {{Set(name="default_criteria", value=_utilsAppendRowSkill(rows=default_criteria, newRow=instruction_table_booking))}}
        {{Set(name="default_criteria", value=_utilsAppendRowSkill(rows=default_criteria, newRow=instruction_change_reservation))}}
    {{/if}}
    {{SetCustomerAttribute(field="project_attributes_setting_additional_limitations_and_restrictions", value=default_criteria)}}
{{/if}}
