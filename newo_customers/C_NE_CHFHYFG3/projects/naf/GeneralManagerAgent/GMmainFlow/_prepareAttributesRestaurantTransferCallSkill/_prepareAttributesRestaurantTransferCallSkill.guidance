{{_utilsCustomerAttributeSetIfEmptySkill(field="project_attributes_setting_transfer_call_enabled", value="True")}}

{{_utilsCustomerAttributeSetIfEmptySkill(field="project_attributes_setting_transfer_call_confirmation_phrase", value="Would you like me to connect you with a co-worker now?")}}

{{_utilsCustomerAttributeSetIfEmptySkill(field="project_attributes_setting_transfer_call_additional_statement", value=" ")}}

{{Set(name="instruction_food_order", value="- Order food, pickup order, or order to go;")}}
{{Set(name="instruction_table_booking", value="- Book a table for less than `restaurant.large_group_reservation_minimum_party_size` people;")}}
{{Set(name="instruction_change_reservation", value="- Change/reschedule their reservation;")}}

{{Set(name="current_transfer_call_criteria", value=GetCustomerAttribute(field="project_attributes_setting_transfer_call_criteria"))}}
{{#if not IsEmpty(text=current_transfer_call_criteria)}}
    {{#if not IsEmpty(text=GetCustomerAttribute(field="project_attributes_restaurant_order_url"))}}
        {{Set(name="current_transfer_call_criteria", value=_utilsRemoveRowSkill(rows=current_transfer_call_criteria, rowToRemove=instruction_food_order))}}
    {{else}}
        {{Set(name="current_transfer_call_criteria", value=_utilsAppendRowIfNotExistsSkill(rows=current_transfer_call_criteria, newRow=instruction_food_order))}}
    {{/if}}

    {{#if not IsEmpty(text=GetCustomerAttribute(field="project_attributes_restaurant_googlemaps_reservation_url"))}}
        {{Set(name="current_transfer_call_criteria", value=_utilsRemoveRowSkill(rows=current_transfer_call_criteria, rowToRemove=instruction_table_booking))}}
        {{Set(name="current_transfer_call_criteria", value=_utilsRemoveRowSkill(rows=current_transfer_call_criteria, rowToRemove=instruction_change_reservation))}}
    {{else}}
        {{Set(name="current_transfer_call_criteria", value=_utilsAppendRowIfNotExistsSkill(rows=current_transfer_call_criteria, newRow=instruction_table_booking))}}
        {{Set(name="current_transfer_call_criteria", value=_utilsAppendRowIfNotExistsSkill(rows=current_transfer_call_criteria, newRow=instruction_change_reservation))}}
    {{/if}}
    {{SetCustomerAttribute(field="project_attributes_setting_transfer_call_criteria", value=current_transfer_call_criteria)}}

{{else}}

{{#system~}}
- Confirm that their table reservation is secured;
- Notify that they will be late for an existing reservation;
- Participate in or book a table for a special event mentioned in the context;
- Order catering;
- Report a forgotten or lost item at the restaurant;
- Speak with customer service;
- Speak with the manager or co-worker (including returning or continuing a previous conversation);
- "customer service";
- "representative";
{{~/system}}
    {{Set(name="default_criteria", value=GetCurrentPrompt())}}
    {{#if IsEmpty(text=GetCustomerAttribute(field="project_attributes_restaurant_order_url"))}}
        {{Set(name="default_criteria", value=_utilsAppendRowSkill(rows=default_criteria, newRow=instruction_food_order))}}
    {{/if}}

    {{#if IsEmpty(text=GetCustomerAttribute(field="project_attributes_restaurant_googlemaps_reservation_url"))}}
        {{Set(name="default_criteria", value=_utilsAppendRowSkill(rows=default_criteria, newRow=instruction_table_booking))}}
        {{Set(name="default_criteria", value=_utilsAppendRowSkill(rows=default_criteria, newRow=instruction_change_reservation))}}
    {{/if}}
    {{SetCustomerAttribute(field="project_attributes_setting_transfer_call_criteria", value=default_criteria)}}
{{/if}}
