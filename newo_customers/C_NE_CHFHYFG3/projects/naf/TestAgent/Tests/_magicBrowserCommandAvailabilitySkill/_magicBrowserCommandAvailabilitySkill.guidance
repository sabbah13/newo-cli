{{#system~}}
{
  "date": "2025-07-12",
  "time": "13:30",
  "dateTime": "2025-07-12 13:30",
  "partySize": "4",
  "timeZone": "America/Los_Angeles",
  "restaurantId": "5tHzSy086ZM",
  "timeFormat": "12",
