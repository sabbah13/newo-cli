}
{{~/system}}
{{Set(name="payload", value=" ")}}

{{Set(name="user_id", value=GetUser(field="id"))}}
{{Set(name="user_name", value=GetUser(field="name"))}}

{{SendCommand(
    commandIdn="get_restaurant_availability",
    integrationIdn="magic_browser",
    connectorIdn="magic_browser_connector",
    persona_id=user_id,
    persona_name=user_name,
    session_name=Concat(user_id, "_", _utilsGetRandomPostfixSkill(), "_", _utilsGetRandomPostfixSkill()),
    payload=payload,
    targetAction="test_check_availability"
)}}
