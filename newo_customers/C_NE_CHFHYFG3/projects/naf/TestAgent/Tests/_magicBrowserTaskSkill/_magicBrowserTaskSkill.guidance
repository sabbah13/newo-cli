{{Set(name="convo_agent_persona", value=GetAgent(idn="ConvoAgent", field="personaId"))}}
{{Set(name="industry", value=GetCustomerAttribute(field="project_business_industry"))}}
{{Set(name="scenario", value=GetCustomerAttribute(field="project_attributes_scenario"))}}
{{Set(name="project_business_time_zone", value=GetCustomerAttribute(field="project_business_time_zone"))}}

{{Set(name="mb_session_name", value=_magicBrowserTaskGetRandomUUIDSkill())}}

{{Set(name="task_idn", value="w1s3_reserve_table_task")}}

{{Set(name="task_script", value=Stringify(SearchFuzzyAkb(
    query=Concat("MagicWorker", "_", task_idn),
    searchFields=["name"],
    fromPerson="Agent",
    numberTopics = 1,
    fields = ["summary"],
    scoreThreshold=0.9,
    labels=["scripts"],
    filterByPersonaIds=convo_agent_persona
)))}}

{{SendCommand(
    commandIdn="magic_browser_command",
    integrationIdn="magic_browser",
    connectorIdn="magic_browser_connector",
    objective=_magicBrowserTaskObjectiveSkill(
        timeZone=project_business_time_zone,
        taskIdn=task_idn,
        personaId=convo_agent_persona,
        scenario=scenario,
        industry=industry
    ),
    script=task_script,
    persona_id=GetUser(field="id"),
    persona_name=GetUser(),
    session_name=mb_session_name
)}}
