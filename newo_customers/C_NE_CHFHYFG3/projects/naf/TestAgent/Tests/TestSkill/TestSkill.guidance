{{Set(name="user_message", value=GetTriggeredAct(fields=["text"]))}}

{{!-- `End Session` will be triggered on sending "es" message --}}
{{#if IsSimilar(val1=user_message, val2="es", threshold=0.85)}}
    {{SendMessage(message=Concat("`End Session` was triggered."))}}
    {{_endSessionSkill()}}
    {{Return()}}
{{/if}}

