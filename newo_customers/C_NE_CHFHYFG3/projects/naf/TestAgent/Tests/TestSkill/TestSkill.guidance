{{!-- `Playground NSL` will be triggered on sending "pgn" message --}}
{{#if IsSimilar(val1=user_message, val2="pgn", threshold=0.85)}}
    {{SendMessage(message=Concat("`Playground NSL` was triggered."))}}
    {{_playgroundNSLSkill()}}
    {{Return()}}
{{/if}}

{{!-- `Run Tests` will be triggered on sending "rt" message --}}
{{#if IsSimilar(val1=user_message, val2="rt", threshold=0.85)}}
    {{SendMessage(message=Concat("`Run Tests` was triggered."))}}
    {{SendSystemEvent(
        eventIdn="run_tests",
        connectorIdn="system",
        global="True"
    )}}
    {{Return()}}
{{/if}}

{{!-- `Upgrade Project` will be triggered on sending "up" message --}}
{{#if IsSimilar(val1=user_message, val2="up", threshold=0.85)}}
    {{SendMessage(message=Concat("`Upgrade Project` was triggered."))}}
    {{!-- Type versions here - e.g. `3.4.0` and `4.2.0` --}}
    {{Set(name="previous_version", value="")}}
    {{Set(name="current_version", value="")}}
    {{SendSystemEvent(
        eventIdn="project_publish_finish",
        connectorIdn="project",
        global="True",
        triggered_by="auto_update",
        project_previous_version=previous_version,
        registry_item_idn="naf",
        registry_item_version=current_version
    )}}
    {{Return()}}
{{/if}}

{{!-- `Agent Creator Event` will be triggered on sending "ace" message --}}
{{!-- ! Warning: Customer Attributes, Twilio Connector and NEWO Voice Connector will be deleted. Do not test in PROD accounts! --}}
{{!--
{{#if IsSimilar(val1=user_message, val2="ace", threshold=0.85)}}
    {{SendMessage(message=Concat("`Agent Creator Event` was triggered."))}}
{{#system~}}
[
  {
    "idn": "agent_creator_business_info_industry",
    "value": "sales_industry",
    "is_hidden": "true",
    "group": "0. Agent Creator"
  },
  {
    "idn": "agent_creator_voice_channel_phone",
    "value": "{'area_code': '650', 'country_code': 'US', 'fallback_area_code': '408'}",
    "is_hidden": "true",
    "group": "0. Agent Creator"
  }
]
{{~/system}}
    {{SendSystemEvent(
        eventIdn="agent_creator_event",
        connectorIdn="system",
        global="True",
        attributes=GetCurrentPrompt()
    )}}
    {{Return()}}
{{/if}}
--}}
