{{#if workingStatus == "True" }}
{{#system~}}
{
  "type": "object",
  "properties": {
    "status": {
      "type": "boolean",
      "description": "Set to `true` if business is working during date and time specified in <ConversationMeta>"
    },
    "status_details": {
      "type": "string",
      "enum": ["Non working day", "Non working hours", "Working hours"],
      "description": "Business working status details during date and time specified in <ConversationMeta>"
    }
  },
  "required": [
    "status",
    "status_details"
  ]
}
{{~/system}}

    {{Return(val=GetCurrentPrompt())}}
{{/if}}

{{#if conversationQuality == "True"}}

{{#system~}}
{
  "type": "object",
  "properties": {
    "conversation_quality_score": {
      "type": "number",
      "description": "Set the field as integer value from 0 to 10 depending on conversation quality according to <ConversationQualityMethodology>."
    }
  },
  "required": [
    "conversation_quality_score"
  ]
}
{{~/system}}

    {{Return(val=GetCurrentPrompt())}}
{{/if}}

{{#if extractInformation == "True"}}
{{#system~}}
{
  "type": "object",
  "properties": {
    "notes": {
      "type": "object",
      "description": "Internal notes about phone number extraction from the conversation.",
      "properties": {
        "spelled_phone_number": {
          "type": "string",
          "description": "The exact phone number as it was spoken by the user or agent, including words. Set to string \"null\" if not provided."
        },
        "spelled_phone_number_corrected": {
          "type": "string",
          "description": "The spoken phone number converted into a pure numeric string. Set to string \"null\" if not applicable."
        },
        "spelled_phone_number_contains_country_code": {
          "type": "boolean",
          "description": "Set to `true` if the spoken number explicitly included a country code."
        }
      },
      "required": [
        "spelled_phone_number",
        "spelled_phone_number_corrected",
        "spelled_phone_number_contains_country_code"
      ]
    },
    "user_name": {
      "type": "string",
      "description": "The user's full name. Set to string \"null\" if not provided."
    },
    "user_email": {
      "type": "string",
      "description": "The user's email address. Set to string \"null\" if not provided."
    },
    "user_preferred_language": {
      "type": "string",
      "description": "The user's preferred language, based on the last message's language. Default to `{{GetCustomerAttribute(field="project_business_language_primary")}}` if unknown."
    },
    "user_phone_number_with_country_code": {
      "type": "string",
      "description": "The user's full phone number including the country code. Set to string \"null\" if not provided."
    },
    "user_phone_number_country_code": {
      "type": "string",
      "description": "The user's phone number country code, determined according to the rules in the prompt. Set to string \"null\" if not provided."
    },
    "user_phone_number_without_country_code": {
      "type": "string",
      "description": "The user's phone number without the country code. Set to string \"null\" if not provided."
    },
    "sms_opt_in": {
      "type": "boolean",
      "description": "Set to `false` only if the user explicitly declines to receive SMS. Defaults to `true`."
    },
    "email_opt_in": {
      "type": "boolean",
      "description": "Set to `false` only if the user explicitly declines to receive emails. Defaults to `true`."
    }
  },
  "required": [
    "notes",
    "user_name",
    "user_email",
    "user_preferred_language",
    "user_phone_number_with_country_code",
    "user_phone_number_country_code",
    "user_phone_number_without_country_code",
    "sms_opt_in",
    "email_opt_in"
  ]
}
{{~/system}}

{{Return(val=GetCurrentPrompt())}}
{{/if}}
