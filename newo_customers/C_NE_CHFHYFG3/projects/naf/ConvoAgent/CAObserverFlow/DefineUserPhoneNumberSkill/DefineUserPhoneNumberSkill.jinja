{#
    PURPOSE:
    This skill parses the user's phone number to identify the international country code and removes it.

    It handles common formatting issues, international exit codes, and ensures that
    internal or incomplete numbers are preserved safely without incorrect parsing.
#}

{# Define user's phone number information #}

{% set user_id = GetTriggeredAct().arguments.user_id %}

{% set user_phone_number = GetTriggeredAct().arguments.user_phone_number_with_country_code %}

{% if user_phone_number %}
    {#
        CLEANING & NORMALIZATION:
        Standardize the input by removing common formatting characters
        (+, -, spaces, parentheses). This allows for consistent digit-based matching.
    #}
    {% set user_phone_number = user_phone_number | replace("+", "") | replace(" ", "") | replace("-", "") | replace("(", "") | replace(")", "") | trim %}

    {#
        INTERNATIONAL PREFIX HANDLING:
        Standard international exit codes ('00' or '011') are identified and removed from
        a 'candidate_number' used for matching.

        The original 'user_phone_number' is preserved to ensure that if matching fails
        (e.g., for short codes or internal numbers starting with these digits),
        the data is not corrupted in the fallback case.
    #}
    {% set candidate_number = user_phone_number %}
    {% if candidate_number.startswith("00") %}
        {% set candidate_number = candidate_number[2:] %}
    {% elif candidate_number.startswith("011") %}
        {% set candidate_number = candidate_number[3:] %}
    {% endif %}

