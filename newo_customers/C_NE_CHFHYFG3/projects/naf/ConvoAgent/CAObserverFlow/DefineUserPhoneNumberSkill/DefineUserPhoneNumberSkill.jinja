    {% set ns = namespace(found_match=false, code="null", rest="null") %}

    {#
        MATCHING LOGIC:
        Iterate through the known country codes to check if the candidate number starts with one.

        ALGORITHM DETAILS:
        1. SORTING (Greedy Matching):
            The 'country_codes' list is statically PRE-SORTED by length (descending) to prioritize
            the longest possible match. This prevents "Partial Matching" bugs where a shorter
            country code is a prefix of a longer one (e.g., ensuring '+1 242' is correctly
            identified as the Bahamas [+1242] rather than USA [+1] with an extra '242').

        2. Check if 'candidate_number' starts with a 'code' from the list.
        3. Validate the remaining digits ('diff') and the TOTAL length of the number:
            - Country Code '1' (NANP/US): Requires at least 10 remaining digits (diff >= 10).
            - All other codes: Require the TOTAL length of the candidate number to be >= 10.

        DESIGN DECISION & TRADE-OFFS:
        We enforce a strict minimum TOTAL length of 10 digits for most of the world to filter out
        incomplete 8-9 digit numbers that accidentally start with a country code (e.g., '624456022'
        should not be parsed as Indonesia +62).

        This design intentionally sacrifices support for extremely rare, short international
        numbers from tiny regions (e.g., St. Helena +290 xxxx, Niue +683 xxxx) in favor of
        robustly handling the much more common case of incomplete/local 9-digit numbers.
    #}
    {% for code in country_codes %}
        {% if not ns.found_match and candidate_number.startswith(code) %}
            {% set diff = candidate_number|length - code|length %}

            {#
                For non-US/NANP numbers, we verify the TOTAL length is >= 10.
                This ensures we do not falsely match short local numbers.
            #}
            {% if (code == "1" and diff >= 10) or (code != "1" and candidate_number|length >= 10) %}
                {% set ns.code = code %}
                {% set ns.rest = candidate_number[code|length:] %}
                {% set ns.found_match = true %}
            {% endif %}
        {% endif %}
    {% endfor %}

    {#
        FALLBACK LOGIC:
        If no valid country code match is identified (due to internal numbers,
        short codes, or missing map entries), the original cleaned number
        is preserved as 'rest' and the country code is set to "null".
    #}
    {% if not ns.found_match %}
        {% set ns.code = "null" %}
        {% set ns.rest = user_phone_number %}
    {% endif %}

    {% set user_phone_number_country_code = ns.code %}
    {% set user_phone_number_without_country_code = ns.rest %}
{% else %}
    {% set user_phone_number = "null" %}
    {% set user_phone_number_country_code = "null" %}
    {% set user_phone_number_without_country_code = "null" %}
{% endif %}

{{SetPersonaAttribute(id=user_id, field="detected_phone_number_with_country_code", value=user_phone_number)}}
{{SetPersonaAttribute(id=user_id, field="detected_phone_number_country_code", value=user_phone_number_country_code)}}
{{SetPersonaAttribute(id=user_id, field="detected_phone_number_without_country_code", value=user_phone_number_without_country_code)}}

