          "type": "object",
          "properties": {
            "is_price_discussed" : {
                "type": "boolean",
                "description": "Check the <ConversationHistory> context. Set to true if the ConvoAgent and / or User discussed some pricing. (Not all numbers are prices)"
            },
            "discussed_price": {
              "type": "integer",
              "description": "Enter here the price of any product or service if it was explicitly discussed during the conversation. If the price was not discussed, enter 0. Do not include random numbers mentioned in the conversation."
            }
          },
          "required": [
            "discussed_price"
          ]
        },
        "potential_revenue_formula": "discussed_price * pr_lead_conversion_rate",
        "constants": {
          "pr_lead_conversion_rate": "1"
        },
        "min_value": pr_average_lead_value
      }
    } %}

