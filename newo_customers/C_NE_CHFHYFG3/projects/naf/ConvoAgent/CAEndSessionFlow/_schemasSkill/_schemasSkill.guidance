{{#if reportDisaster == "True"}}
{{#system~}}
{
  "type": "object",
  "properties": {
    "user_inquiry": {
      "type": "string",
      "description": "Based on <ConversationHistory>, identify the initial user's inquiry in simple terms."
    },
    "session": {
      "type": "object",
      "properties": {
        "session_name": {
          "type": "string",
          "description": "Based on the `userInquiry` choose one of session types mentioned in <IntentTypeMap> (types are marked as headers with `##`)."
        },
        "session_verbose_name": {
          "type": "string",
          "description": "The same as `session_name` but without leading prefix \"[L]\" or other similar prefixes."
        },
        "is_lead": {
          "type": "boolean",
          "description": "Set to `true` if the `sessionType` is starts with \"[L]\" in <IntentTypeMap>. Otherwise set to false."
        },
        "is_todo": {
          "type": "boolean",
          "description": "Set to `true` if the `sessionType` is starts with \"[T]\" in <IntentTypeMap>. Otherwise set to false."
        }
      },
      "required": ["session_name", "session_verbose_name", "is_lead", "is_todo"]
    },
    "scenario": {
      "type": "object",
      "properties": {
        "scenario_name": {
          "type": "string",
          "description": "Based on the `user_inquiry`, choose one of session types mentioned in <IntentTypeMap> (marked with header `##`)."
        },
        "scenario_task": {
          "type": "string",
          "description": "Based on the `session_name`, outline the general task/action the agent needs to complete (e.g. perform booking, send an sms, relay message...)."
        }
      },
      "required": ["scenario_name", "scenario_task"]
    },
    "analysis": {
      "type": "object",
      "properties": {
        "report_sent": {
          "type": "boolean",
          "description": "Set true if <SystemLogs> indicates that either email or sms report has been sent."
        },
        "should_send_report": {
          "type": "boolean",
          "description": "Set true if the <EndSessionReportCriteria> requires to send a report about this conversation, described in <ConversationHistory>"
        },
        "destination_correct": {
          "type": "boolean",
          "description": "Set true if <SystemLogs> information about report sent is valid according to <EndSessionReportCriteria>."
        }
      },
      "required": [
        "report_sent",
        "should_send_report",
        "destination_correct"
      ]
    },
    "is_success": {
      "type": "boolean",
      "description": "Set to result of this condition: `(should_send_report && report_sent && destination_correct) || (!should_send_report && !report_sent)`"
    },
    "issue_description": {
      "type": "string",
      "description": "Brief issue description if `is_success` is set to false. Otherwise, set to \"no reporting issues\""
    }
  },
  "required": ["user_inquiry", "session", "scenario", "analysis", "is_success", "issue_description"]
}
{{~/system}}

{{Return(val=GetCurrentPrompt())}}
{{/if}}

{{#if conversationCategory == "True"}}
{{#system~}}
{
  "type": "object",
  "properties": {
    "revenue_model_key": {
      "type": "string",
      "description": "Key of the revenue model that best fits the SessionType. If there is no category that clearly fits best, set this field to `default`."
    }
  },
  "required": ["revenue_model_key"]
}
{{~/system}}

    {{Return(val=GetCurrentPrompt())}}
{{/if}}
