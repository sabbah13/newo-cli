{{Set(name="api_channel", value=GetPersonaAttribute(id=userId, field="api_channel"))}}
{{#if not IsEmpty(text=api_channel)}}
    {{#if api_channel == "ig"}}
        {{Return(val="Instagram")}}
    {{/if}}
    {{#if api_channel == "fb"}}
        {{Return(val="Facebook")}}
    {{/if}}
    {{Return(val=api_channel)}}
{{/if}}

{{Set(name="integration_idn", value=GetPersonaAttribute(id=userId, field="initial_integration_idn"))}}

{{#if integration_idn == "vapi"}}
    {{#if outboundCall == "True"}}
        {{Return(val="Outgoing Phone")}}
    {{/if}}
    {{Return(val="Incoming Phone")}}
{{/if}}

{{#if integration_idn == "newo_voice"}}
    {{#if outboundCall == "True"}}
        {{Return(val="Outgoing Phone")}}
    {{/if}}
    {{#if session_get_current_connector_idn(user_id=userId) == "newo_voice_connector_web"}}
        {{Return(val="Incoming WebCall")}}
    {{/if}}
    {{Return(val="Incoming Phone")}}
{{/if}}

{{#if integration_idn == "newo_chat"}}
    {{Return(val="Newo Chat")}}
{{/if}}

{{#if integration_idn == "twilio_messenger"}}
    {{Return(val="SMS")}}
{{/if}}

{{#if integration_idn == "telegram"}}
    {{Return(val="Telegram")}}
{{/if}}

{{#if integration_idn == "sandbox"}}
    {{Return(val="Sandbox")}}
{{/if}}

{{Return(val="Unknown")}}
