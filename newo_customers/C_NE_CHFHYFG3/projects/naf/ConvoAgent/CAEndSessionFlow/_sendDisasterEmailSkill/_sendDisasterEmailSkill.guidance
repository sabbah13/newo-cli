{{SendSystemEvent(
    eventIdn="email_worker_send_email",
    connectorIdn="system",
    email=email,
    cc=cc,
    subject=subject,
    body=_sendDisasterEmailBodyTextSkill(transcript=transcript, userId=userId, issueDescription=issueDescription, workingHourStatus=workingHourStatus, actualResult=actualResult, reportDisaster=reportDisaster),
    ignore_opt_out="true"
)}}

{{SendMessage(
    message=Concat("System log: Disaster report email is sent to ", email, " and cc to ", cc, ".", "

Issue: ", issueDescription),
    actorIds=_utilsGetFootnoteSkill(userId=userId, system="True")
)}}
