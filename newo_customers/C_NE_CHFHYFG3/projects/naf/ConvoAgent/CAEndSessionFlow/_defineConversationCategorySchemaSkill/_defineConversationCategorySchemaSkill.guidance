{{Set(name="categories_enum", value=AppendItemsArrayJSON(array=categories, items=AsStringJSON(val="other")))}}

{{#system~}}
{
  "type": "object",
  "properties": {
    "conversation_category": {
      "type": "string",
      "description": "The one of the conversation categories the conversation belongs to",
      "enum": {{categories_enum}}
    },
    "request_category": {
      "type": "string",
      "description": "The request category depending on the `category` according to mapping in <CategoriesMapping>"
    }
  },
  "required": [
    "conversation_category",
    "request_category"
  ]
}
{{~/system}}

