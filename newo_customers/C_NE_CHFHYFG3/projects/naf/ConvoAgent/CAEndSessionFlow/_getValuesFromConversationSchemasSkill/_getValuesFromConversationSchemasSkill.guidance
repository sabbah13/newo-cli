{{#if commonValuesSchema == "True"}}
    {{Set(name="country_code", value=GetCustomerAttribute(field="project_representative_agent_voice_phone_country_code"))}}
{{#system~}}
{
    "type": "object",
    "properties": {
        "user_name": {
            "type": "string",
            "description": "Set to the user's full name provided in the <ConversationHistory>. If not provided in the conversation history - use `user.full_name` from the <UserInformation> if it's not \"null\", otherwise set it to \"Not Provided\"."
        },
        "user_phone": {
            "type": "string",
            "description": "Set to the user's phone number provided in the <ConversationHistory>. If not provided in the conversation history - use `user.provided_phone_number_with_country_code` from the <UserInformation> if it's not \"null\", otherwise set it to \"Not Provided\". Make sure user's phone number is specified in a full format with country code ({{country_code}} is a default country code but it may be different). Always strip the \"+\" at the beginning of the phone number if it's present."
        },
        "user_email": {
            "type": "string",
            "description": "Set to the user's email provided in the <ConversationHistory>. If not provided in the conversation history - use `user.email` from the <UserInformation> if it's not \"null\", otherwise set it to \"Not Provided\"."
        },
        "call_reason": {
            "type": "string",
            "description": "The reason for the call in ~6 words."
        },
        "requested_date": {
            "type": "string",
            "description": "The date requested by the user in the format `YYYY-MM-DD`. Set it to \"Not Requested\" if user didn't request a specific date."
        },
        "requested_time": {
            "type": "string",
            "description": "The time requested by the user in the format `HH:MM`. Set it to \"Not Requested\" if user didn't request a specific time."
        },
        "is_emergency": {
            "type": "boolean",
            "description": "Indicates whether the request is an emergency."
        },
        "user_wanted_to_pass_information": {
            "type": "boolean",
            "description": "Do you see in the <ConversationHistory> that the user explicitly asked to pass information to a co-worker, and also the ConvoAgent agreed to pass the information to the co-worker?"
        },
        "user_message_to_manager": {
            "type": "string",
            "description": "Write a message up to 40 words in length that you will pass on to an employee from the user. Include the user’s name, the user’s phone number, and all key information the user asked to convey.",
            "default": ""
        },
        "conversation_ended_date_time": {
            "type": "string",
            "description": "Current date time in format: YYYY-MM-DD, HH:MM"
        }
    },
    "required": [
        "user_name",
        "user_phone",
        "user_email",
        "call_reason",
        "requested_date",
        "requested_time",
        "is_emergency",
        "user_wanted_to_pass_information",
        "user_message_to_manager",
        "conversation_ended_date_time"
    ]
}
{{~/system}}

{{Return(val=GetCurrentPrompt())}}
{{/if}}

{{#if customValuesSchema == "True"}}
    {{Return(val=GetCustomerAttribute(field="project_attributes_private_custom_schema_inbound_call_report"))}}
{{/if}}

{{#if webhookValuesSchema == "True"}}
    {{Return(val=GetCustomerAttribute(field="project_attributes_setting_session_ended_webhook_schema"))}}
{{/if}}
