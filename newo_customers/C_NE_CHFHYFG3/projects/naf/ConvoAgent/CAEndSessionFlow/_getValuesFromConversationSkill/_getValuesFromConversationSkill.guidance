{{Set(name="common_values", value=_getValuesFromConversationExtractSkill(schema=_getValuesFromConversationSchemasSkill(commonValuesSchema="True"), transcript=transcript, userId=userId))}}

{{Set(name="custom_schema", value=_getValuesFromConversationSchemasSkill(customValuesSchema="True"))}}
{{#if not IsEmpty(text=custom_schema)}}
    {{Set(name="custom_values", value=_getValuesFromConversationExtractSkill(schema=custom_schema, transcript=transcript, userId=userId))}}
{{else}}
    {{Set(name="custom_values", value="{}")}}
{{/if}}

{{Set(name="webhook_values", value="{}")}}
{{Set(name="webhook_schema", value=_getValuesFromConversationSchemasSkill(webhookValuesSchema="True"))}}
{{#if not IsEmpty(text=webhook_schema)}}
    {{#if webhook_schema != "{}"}}
        {{Set(name="webhook_values", value=_getValuesFromConversationExtractSkill(schema=webhook_schema, transcript=transcript, userId=userId))}}
    {{/if}}
{{/if}}

{{Set(name="conversation_values", value=UpdateValueJSON(obj="{}", key="common_values", value=common_values))}}
{{Set(name="conversation_values", value=UpdateValueJSON(obj=conversation_values, key="custom_values", value=custom_values))}}
{{Set(name="conversation_values", value=UpdateValueJSON(obj=conversation_values, key="webhook_values", value=webhook_values))}}

{{Return(val=conversation_values)}}
