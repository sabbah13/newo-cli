{{Set(name="schema", value=_identifyDisasterSchemaSkill())}}
{{Set(name="technical_owners", value=GetCustomerAttribute(field="project_attributes_private_technical_owners"))}}

{{#if IsEmpty(text=technical_owners)}}
    {{Return()}}
{{/if}}

{{#if IsSimilar(val1=technical_owners, val2="[]", threshold=0.8)}}
    {{Return()}}
{{/if}}

{{#system~}}
You are AI supervisor of the call center. Your goal is to identify issues and troubles happened during conversations and build an email report based on given <ConversationMeta>, <ConversationHistory> and <Report>.

---

<TechnicalOwners>
{{technical_owners}}
</TechnicalOwners>

<ConversationMeta>
# Working Hours Status
{{workingHours}}

# Brief Summary
{{summary}}
</ConversationMeta>

<ConversationHistory>
{{transcript}}
</ConversationHistory>

<Report>
# During conversation report
```json
{{semaphore}}
```

---

# After conversation report
```json
{{reportDisaster}}
```
</Report>
{{~/system}}
{{#assistant~}}
{{Set(name="result", value=Gen(jsonSchema=schema, validateSchema="True", temperature=0.2, topP=0, thinkingBudget=1020))}}
{{~/assistant}}

{{Set(name="actual_result", value=GetValueJSON(obj=semaphore, key="actualResult"))}}
{{Set(name="issue_description", value=GetValueJSON(obj=result, key="errorExplanation"))}}
{{Set(name="subject", value=GetValueJSON(obj=result, key="subject"))}}
{{Set(name="target_email", value=GetValueJSON(obj=result, key="targetEmail"))}}
{{Set(name="copy_email", value=GetValueJSON(obj=result, key="copyEmail"))}}

{{_sendDisasterEmailSkill(
    email=Stringify(target_email),
    cc=copy_email,
    subject=Stringify(subject),
    issueDescription=Stringify(issue_description),
    userId=userId,
    workingHourStatus=workingHours,
    actualResult=Stringify(actual_result),
    reportDisaster=reportDisaster
)}}
