{{#system~}}
{
  "type": "object",
  "title": "Your Schema",
  "properties": {
    "errorExplanation": {
      "type": "string",
      "default": "no errors",
      "description": "Based on given `analysis` described in <Report> and <ConversationHistory> build an explanation of what went wrong and how it should be."
    },
    "targetEmail": {
      "type": "string",
      "default": "N/A",
      "description": "Set to the first email provided in <TechnicalOwners>. If not provided set to `N/A`."
    },
    "copyEmail": {
      "type": "array",
      "description": "The list of all other emails specified in <TechnicalOwners> section. May be empty if no more emails except `targetEmail` is specified.",
      "items": {
        "type": "string"
      }
    },
    "subject": {
      "type": "string",
      "description": "Explain in short for email subject, what went wrong (which particular feature from `checklist` were broken)."
    }
  },
  "required": [
    "errorExplanation",
    "targetEmail",
    "copyEmail",
    "subject"
  ]
}
{{~/system}}


{{Return(val=GetCurrentPrompt())}}
