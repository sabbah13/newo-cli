{% set business_email = GetCustomerAttribute(field="project_business_manager_email") %}
{% set business_name = GetCustomerAttribute(field="project_business_name") %}

{% set common_values = json.dumps(conversationValues.common_values, ensure_ascii=False, indent=2) %}
{% set custom_values = conversationValues.custom_values %}
{# Update custom values with conversation source #}
{{custom_values.update({"conversation_source": GetPersonaAttribute(id=userId, field="conversation_source")})}}
{% set custom_values = json.dumps(custom_values, ensure_ascii=False, indent=2) %}

{% set webhook_values = json.dumps(conversationValues.webhook_values, ensure_ascii=False, indent=2) %}
{% set summary = metrics.summary %}

{% set working_hours_status = _defineConversationWorkingHoursStatusSkill() %}
{% set category = semaphore.sessionName %}
{% set request_category = "New Lead" if semaphore.isLead and semaphore.contactDetailsPresent else "Todo" if semaphore.isTodo and semaphore.contactDetailsPresent else "Archive" %}
{% set success_classification = semaphore.aiResultSuccess %}
{% set potential_revenue = metrics.potential_revenue %}
{% set revenue_generating = json.dumps(semaphore.isLead, ensure_ascii=False, indent=2) %}
{% set recording_urls = GetPersonaAttribute(id=userId, field="recording_urls") %}
{% if not recording_urls.strip() %}
    {% set recording_urls = "[]" %}
    {% set formatted_recording_urls = "" %}
{% else %}
    {% set formatted_recording_urls = _utilsPrepareRecordingUrls(recordingUrls=recording_urls) %}
{% endif %}
{% set url_params = GetPersonaAttribute(id=userId, field="url_params") %}
{% if not url_params.strip() %}
    {% set url_params = "[]" %}
{% endif %}

{% set last_conversation_ended_reason = GetPersonaAttribute(id=userId, field="last_conversation_ended_reason") %}
{% set is_outbound_call = _utilsPersonaAttributeGetWithDefaultsSkill(id=userId, field="outbound_session_global", defaultValue="False") %}
{% set working_hours_status_bool = _defineConversationWorkingHoursStatusSkill(boolValue="True") %}
{# -- ASR Recognition for ‘Off-hours’ and ‘Business hours - overflow type’ is 100%. -- #}
{% if working_hours_status_bool == "false" %}
    {% set asr_recognition = "100" %}
{% else %}
    {% set forward_type = GetCustomerAttribute(field="project_attributes_setting_asr_redirection_type_working_hours") %}
    {% if forward_type == "overflow" %}
        {% set asr_recognition = "100" %}
    {% else %}
        {# -- For ‘Business hours - all calls type’, it will be a percentage between 0 - 100% to be agreed with each customer. -- #}
        {% set asr_recognition = GetCustomerAttribute(field="project_attributes_setting_asr_recognition") %}
    {% endif %}
{% endif %}

{# TODO: Use Platform Action to get list of all modules and their versions when it will be implemented #}
{% set modules = json.dumps({"naf": GetCustomerAttribute(field="project_attributes_private_sa_version").strip()}, ensure_ascii=False, indent=2) %}

{{SendSystemEvent(
    eventIdn="session_ended",
    connectorIdn="system",
    businessEmail=business_email,
    businessLabel=business_name,
    transcript=transcript,
    summary=summary,
    recordingUrls=recording_urls,
    conversationEndedReason=last_conversation_ended_reason,
    workingHours=working_hours_status,
    category=category,
    success=success_classification,
    potentialRevenue=potential_revenue,
    utms=url_params,
    integrationIdn=GetPersonaAttribute(id=userId, field="integrationIdn"),
    connector=GetPersonaAttribute(id=userId, field="connectorIdn"),
    userActor=GetPersonaAttribute(id=userId, field="actorId"),
    externalActorId=GetPersonaAttribute(id=userId, field="externalActorId"),
    sessionType=semaphore.sessionType,
    actualResult=_utilsUnpackJSONStringSkill(source=semaphore.actualResult),
    expectedResult=_utilsUnpackJSONStringSkill(source=semaphore.expectedResult),
    aiResultSuccess=success_classification,
    isLead=semaphore.isLead,
    isTest=json.dumps(semaphore.isTest, ensure_ascii=False, indent=2),
    isTodo=json.dumps(semaphore.isTodo, ensure_ascii=False, indent=2),
    asrRecognition=asr_recognition,
    asrConversationRatio=GetCustomerAttribute(field="project_attributes_setting_asr_conversion_ratio"),
    channel=_getConversationChannelSkill(userId=userId, outboundCall=is_outbound_call),
    isOpportunity=semaphore.isOpportunity,
    agentSuccessCode=semaphore.agentSuccessCode,
    agentSuccessFactor=semaphore.agentSuccessFactor,
    leadValue=potential_revenue,
    defaultLeadValue=GetCustomerAttribute(field="project_attributes_setting_asr_average_lead_value"),
    modules=modules
)}}

{% if GetCustomerAttribute(field="project_attributes_setting_hitl_monitoring_enabled") == "True" %}
    {{_sendHITLEventSkill(
        workingHours=working_hours_status,
        category=category,
        success=success_classification,
        commonValues=common_values,
        userId=userId,
        summary=summary,
        businessLabel=business_name,
        recordingUrl=formatted_recording_urls,
        outboundCall=is_outbound_call,
        potentialRevenue=potential_revenue,
        revenueGenerating=revenue_generating,
        args="",
        semaphore=json.dumps(semaphore, ensure_ascii=False, indent=2)
    )}}
{% endif %}

{% set agent_behavior = quality_metrics.get("agent_behavior", {}) %}
{% set user_behavior = quality_metrics.get("user_behavior", {}) %}

{# -- Reporting disasters -- #}
{% set disaster_identified = False %}
{# New Logic #}
{# Level 1 #}
{% if agent_behavior.get('agent_stopped_responding') or agent_behavior.get('agent_looping_detected') %}
    {% set disaster_identified = True %}
    {% set disaster_reason = "CRITICAL: Agent communication failure" %}
{% endif %}

{# Level 2 #}
{% if agent_behavior.get('agent_reports_technical_issue') %}
    {% set critical_tech_categories = ["booking", "transfer call"] %}
    {% if agent_behavior.get('agent_technical_issue_category') in critical_tech_categories %}
        {% if not semaphore.essential_steps_completed and not semaphore.fail_caused_by_user %}
            {% set disaster_identified = True %}
            {% set disaster_reason = "CRITICAL: " ~ agent_behavior.get('agent_technical_issue_category') ~ " system failure prevented task completion" %}
        {% endif %}
    {% endif %}
{% endif %}

{# Level 3 #}
{% if not disaster_identified %}
    {% set severe_failure_count = 0 %}

    {% if user_behavior.get('user_hung_up_due_to_ai_mistake') %}
        {% set severe_failure_count = severe_failure_count + 1 %}
    {% endif %}

    {% if agent_behavior.get('agent_contradicting_phrases') and user_behavior.get('user_satisfaction_level') == "very dissatisfied" %}
        {% set severe_failure_count = severe_failure_count + 1 %}
    {% endif %}

    {% if user_behavior.get('transfer_to_human_request', 0) >= 3 %}
        {% set severe_failure_count = severe_failure_count + 1 %}
    {% endif %}

    {% if agent_behavior.get('agent_ask_already_answered_questions_count', 0) >= 3 and user_behavior.get('user_satisfaction_level') in ["very dissatisfied", "dissatisfied"] %}
        {% set severe_failure_count = severe_failure_count + 1 %}
    {% endif %}

    {% if severe_failure_count >= 2 %}
        {% set disaster_identified = True %}
        {% set disaster_reason = "SEVERE: Multiple critical failures detected (" ~ severe_failure_count ~ " severe issues)" %}
    {% endif %}
{% endif %}

{% if disaster_identified %}
    {{_identifyDisasterSkill(
        workingHours=working_hours_status,
        userId=userId,
        summary=summary,
        semaphore=json.dumps(semaphore, ensure_ascii=False, indent=2),
        reportDisaster=json.dumps({"disaster_reason": disaster_reason}, ensure_ascii=False, indent=2),
        transcript=transcript
    )}}
{% endif %}

{# -- Write information to the call table -- #}
{{SendCommand(
    commandIdn="update_inbound_record",
    integrationIdn="api",
    connectorIdn="webhook",
    action="update_inbound_record",
    result=common_values,
    summary=summary,
    conversationEndedReason=last_conversation_ended_reason,
    recordingUrls=formatted_recording_urls,
    workingHours=working_hours_status,
    category=category,
    requestCategory=request_category,
    success=success_classification,
    potentialRevenue=potential_revenue,
    customValues=custom_values
)}}

{% set webhook_url = GetCustomerAttribute(field="project_attributes_setting_session_ended_webhook_url").strip() %}

{% if webhook_url %}
    {{SendCommand(
        commandIdn="send_request",
        integrationIdn="http",
        connectorIdn="http_connector",
        userPersonaId=userId,
        method="POST",
        url=webhook_url,
        headers=_getWebhookRequestHeadersSkill(),
        body=webhook_values,
        targetAction="session_ended_webhook"
    )}}
{% endif %}
