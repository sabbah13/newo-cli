{{StartNotInterruptibleBlock()}}
{{Set(name="message_text", value=GetTriggeredAct(fields="messageText"))}}
{{SetState(name="user_reply_buffer", value=Stringify(Concat(GetState(name="user_reply_buffer"), " ", message_text)))}}
{{Set(name="user_id", value=GetUser(field="id"))}}
{{_startNewSessionSkill(user_id=user_id)}}
{{Set(name="user_actor_id", value=GetTriggeredAct(fields="convoActorId"))}}
{{CreateMessageAct(text=message_text, from="user", userPersonaId=user_id, userActorId=user_actor_id)}}
{{StopNotInterruptibleBlock()}}

{{Set(name="integration_idn", value=GetActor(field="integrationIdn", id=user_actor_id))}}
{{#if integration_idn == "api"}}
    {{Set(name="api_event", value="True")}}
{{else}}
    {{Set(name="api_event", value="False")}}
{{/if}}

{{!-- Not sure why it was here, cause in general it breaks logic, when for example the user speaks with the user through the phone, and agent asks to provide something in chat --}}
{{!-- {{SetPersonaAttribute(id=user_id, field="last_convo_actor_id", value=user_actor_id)}} --}}


{{_userMessageFastReplySkill(
  call_analyze_conversation="True",
  set_follow_up_timer="True",
  external_event=api_event,
  user_id=user_id,
  integration_idn=integration_idn
)}}
