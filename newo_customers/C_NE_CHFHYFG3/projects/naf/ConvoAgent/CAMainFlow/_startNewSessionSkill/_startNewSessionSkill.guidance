{{StartNotInterruptibleBlock()}}

{{#if GetPersonaAttribute(id=user_id, field="previous_session_ended") == "False"}}
    {{Return()}}
{{/if}}

{{SendCommand(
    commandIdn="add_phone_to_pool",
    integrationIdn="twilio_messenger",
    connectorIdn="sms_connector"
)}}

{{SetPersonaAttribute(id=user_id, field="previous_session_ended", value="False")}}
{{SetPersonaAttribute(id=user_id, field="thoughts_new_session", value="True")}}
{{Set(name="actor_id", value=GetActor(field="id"))}}

{{UpdateConversationMetaSkill(userId=user_id)}}

{{!-- Reset session state --}}
{{_utilsResetSessionStateSkill(userId=user_id)}}

{{!-- TODO: Remove when `GetMemory` aliasing will be available --}}
{{SetPersonaAttribute(id=user_id, field="initial_integration_idn", value=GetActor(field="integrationIdn"))}}
{{#if IsEmpty(text=GetPersonaAttribute(id=user_id, field="name_was_extracted"))}}
    {{UpdateUser(name="name", value="User")}}
{{/if}}

{{#if GetCustomerAttribute(field="project_attributes_setting_session_ended_reset_persona_attributes") == "True"}}
    {{UpdateUser(name="name", value="User")}}
{{/if}}

{{! Building user's information (getting data up to date) }}
{{Set(name="is_outbound_call", value=_utilsPersonaAttributeGetWithDefaultsSkill(id=user_id, field="outbound_call", defaultValue="False"))}}

{{_utilsSendSystemLogSkill(message="New session started.")}}

{{SetPersonaAttribute(id=user_id, field="convoagent_thoughts", value=GetCustomerAttribute(field="project_attributes_setting_initial_thoughts"))}}

{{StopNotInterruptibleBlock()}}
