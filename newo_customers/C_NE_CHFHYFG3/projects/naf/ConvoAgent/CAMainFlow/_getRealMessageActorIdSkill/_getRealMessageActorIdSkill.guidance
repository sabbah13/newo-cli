{{Set(name="real_message_actor_id", value=GetPersonaAttribute(id=userId, field="real_message_actor_id"))}}

{{#if not IsEmpty(text=real_message_actor_id)}}
    {{Return(val=real_message_actor_id)}}
{{/if}}

{{Set(name="external_id", value=GetActor(field="externalId"))}}
{{Set(name="existed_actors", value=Stringify(GetActors(personaId=userId, externalId=external_id, integrationIdn="system", connectorIdn="real_message")))}}

{{#if IsEmpty(text=existed_actors)}}
    {{Set(name="created_actor", value=CreateActor(integrationIdn="system", connectorIdn="real_message", externalId=external_id, personaId=userId))}}
    {{SetPersonaAttribute(id=userId, field="real_message_actor_id", value=created_actor)}}
    {{Return(val=created_actor)}}
{{/if}}

{{SetPersonaAttribute(id=userId, field="real_message_actor_id", value=existed_actors)}}

{{Return(val=existed_actors)}}
