{{!-- TODO: Implement two options of defining - when conversation started and at the skill call moment --}}

{{Set(name="time_zone", value=GetCustomerAttribute(field="project_business_time_zone"))}}
{{Set(name="current_date", value=GetDatetime(format="date", timezone=time_zone))}}
{{Set(name="current_time", value=GetDatetime(format="time", timezone=time_zone, weekday=False))}}
{{Set(name="current_date_week_day", value=GetDatetime(format="date", timezone=time_zone, weekday=True))}}
{{Set(name="current_week_day", value=Stringify(current_date_week_day.replace(Concat(current_date, ", "), " ")))}}

{{Set(name="am_hours", value=["00", "01", "02", "03", "04", "05", "06", "07", "08", "09", "10", "11"])}}

{{Set(name="current_hour_list", value=current_time.split(":"))}}
{{Set(name="current_time_list_string", value=Stringify(current_hour_list))}}
{{Set(name="current_time_list_string", value=current_time_list_string.replace("'", '"'))}}
{{Set(name="current_hour", value=Stringify(GetItemsArrayByIndexesJSON(array=current_time_list_string, indexes=0)))}}
{{Set(name="current_minute", value=Stringify(GetItemsArrayByIndexesJSON(array=current_time_list_string, indexes=1)))}}
{{Set(name="am_prefix_should_be_set", value=am_hours.count(current_hour))}}

{{#if am_prefix_should_be_set == 0}}
    {{Set(name="am_postfix", value=" ")}}
{{else}}
    {{Set(name="am_postfix", value="AM")}}
{{/if}}

{{!-- TODO: Refactor, move to a separate skill for setting `WorkingSchedule` block --}}
{{Set(name="non_working_days", value=GetCustomerAttribute(field="project_attributes_private_dynamic_schedule_non_working_days"))}}
{{Set(name="working_days_hours_exceptions", value=GetCustomerAttribute(field="project_attributes_private_dynamic_schedule_working_days_hours_exceptions"))}}

{{Set(name="schema", value=_defineConversationIsDuringWorkingHoursStatusSchemaSkill())}}

{{#system~}}
You are an assistant working with time and dates.
Your goal is to build a JSON object representing business working status during date and time specified in <ConversationMeta> based on <WorkingSchedule> and <Calendar>.

<ConversationMeta>
conversation.timezone: {{time_zone}}
conversation.day_of_week: {{current_week_day}}
conversation.time: {{current_hour}}:{{current_minute}} {{am_postfix}}
conversation.date: {{current_date}}
</ConversationMeta>

<WorkingSchedule alt="business working hours" role="context">{{#if not IsEmpty(text=non_working_days)}}
**Non-working days:**
- {{non_working_days}}
{{/if}}
**Working days:**
- {{GetCustomerAttribute(field="project_attributes_private_dynamic_schedule_working_days")}}

**Working hours:**
- {{GetCustomerAttribute(field="project_attributes_private_dynamic_schedule_working_hours")}}
{{#if not IsEmpty(text=working_days_hours_exceptions)}}
**Working days and working hours exceptions:**
- {{working_days_hours_exceptions}}{{/if}}
</WorkingSchedule>

<Calendar>
{{GetCustomerAttribute(field="project_attributes_private_dynamic_prompt_calendar")}}
</Calendar>
{{~/system}}

{{Set(name="object", value=Gen(jsonSchema=schema, validateSchema="True", temperature=0.2, topP=0, thinkingBudget=425), expose="True")}}

{{Return(val=object)}}
