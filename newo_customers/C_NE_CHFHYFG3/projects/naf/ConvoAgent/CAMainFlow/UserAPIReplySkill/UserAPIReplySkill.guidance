{{StartNotInterruptibleBlock()}}
{{SetState(name="user_reply_buffer", value=Stringify(Concat(GetState(name="user_reply_buffer"), " ", GetTriggeredAct(fields="text"))))}}
{{StopNotInterruptibleBlock()}}

{{Set(name="user_id", value=GetUser(field="id"))}}
{{_startNewSessionSkill(user_id=user_id)}}
{{Set(name="source", value=GetTriggeredAct(fields=["source"]))}}
{{Set(name="channel", value=GetTriggeredAct(fields=["channel"]))}}

{{!-- Define integration IDN --}}
{{Set(name="integration_idn", value=_utilsGetCurrentIntegrationIdnSkill(userId=user_id))}}

{{SetPersonaAttribute(id=user_id, field="external_source", value=source)}}
{{SetPersonaAttribute(id=user_id, field="external_channel", value=channel)}}

{{utils_get_and_set_last_convo_actor_id(user_id=user_id)}}

{{_userMessageFastReplySkill(
  call_analyze_conversation="True",
  set_follow_up_timer="True",
  external_event="True",
  user_id=user_id,
  integration_idn=integration_idn
)}}
