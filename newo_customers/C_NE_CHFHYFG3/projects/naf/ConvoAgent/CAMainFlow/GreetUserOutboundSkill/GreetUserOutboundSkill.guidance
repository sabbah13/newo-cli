{{StartNotInterruptibleBlock()}}

{{Set(name="user_id", value=GetUser(field="id"))}}
{{SendMessage(message=GetPersonaAttribute(id=user_id, field="greeting_phrase"))}}
{{SetState(name="phone_reply_skill", value="UserPhoneReplySkill")}}

{{Set(name="interval", value=GetCustomerAttribute(field="project_attributes_setting_follow_up_timer_voice_interval_conversation_started_outbound"))}}
{{SendSystemEvent(
    eventIdn="convoagent_update_followup",
    connectorIdn="system",
    interval=interval,
    personaId=user_id,
    reason="conversation started"
)}}

{{StopNotInterruptibleBlock()}}
