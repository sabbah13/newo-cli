{{Set(name="is_data_injection_enabled", value=GetCustomerAttribute(field="project_attributes_setting_data_injection_is_enabled"))}}

{{Set(name="is_context_empty", value="True")}}
{{Set(name="injecting_data", value=GetCustomerAttribute(field="project_attributes_private_data_injection_retrieved_data"))}}
{{Set(name="static_additional_business_context", value=GetCustomerAttribute(field="project_attributes_static_additional_business_context"))}}

{{#if is_data_injection_enabled == "True"}}
    {{#if IsEmpty(text=injecting_data)}}
        {{Set(name="is_data_injection_enabled", value="False")}}
    {{else}}
        {{Set(name="is_context_empty", value="False")}}
    {{/if}}
{{/if}}

{{#if not IsEmpty(text=static_additional_business_context)}}
    {{Set(name="is_context_empty", value="False")}}
{{/if}}

{{#if IsSimilar(val1=is_context_empty, val2="True", strategy="symbols")}}
    {{Return()}}
{{/if}}

{{#system~}}
<AdditionalBusinessContext alt="business context" role="context">
{{#if not IsEmpty(text=static_additional_business_context)}}
{{static_additional_business_context}}
{{/if}}
{{#if is_data_injection_enabled == "True"}}

{{injecting_data}}
{{/if}}
</AdditionalBusinessContext>
{{~/system}}

{{Return(val=GetCurrentPrompt())}}
