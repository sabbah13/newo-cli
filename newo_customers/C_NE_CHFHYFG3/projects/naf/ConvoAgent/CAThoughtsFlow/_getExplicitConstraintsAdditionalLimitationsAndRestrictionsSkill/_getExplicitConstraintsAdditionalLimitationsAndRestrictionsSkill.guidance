{{!-- Define relay information block --}}
{{#if GetCustomerAttribute(field="project_attributes_setting_session_ended_report_enabled") == "True"}}
    {{Set(name="relay_information_block", value=Concat(
        "- You can relay your message to the team. To do so, ask the user: 'What exactly would you like to convey?'",
        "
"
    ))}}
{{else}}
    {{Set(name="relay_information_block", value=" ")}}
{{/if}}

{{!-- Define phone channel block --}}
{{#if conversationChannel == "phone"}}
    {{Set(name="phone_channel_block", value="- Look at `# CALL TRANSFERRING` section")}}
{{else}}
    {{Set(name="phone_channel_block", value=" ")}}
{{/if}}

{{Set(name="additional_limitations_and_restrictions", value=GetCustomerAttribute(field="project_attributes_setting_additional_limitations_and_restrictions"))}}

{{#if not IsEmpty(text=additional_limitations_and_restrictions)}}
{{#system~}}
# ADDITIONAL LIMITATIONS AND RESTRICTIONS
You have limitations and restrictions if user wants:
```
{{additional_limitations_and_restrictions}}
```
You have the following options for that:
```
{{relay_information_block}}{{phone_channel_block}}
```
{{~/system}}
    {{Return(val=GetCurrentPrompt())}}
{{else}}
    {{Return()}}
{{/if}}
