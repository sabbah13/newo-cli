{% if success %}
    {{SendSystemEvent(
        eventIdn="urgent_message",
        connectorIdn="system",
        baseInstruction="Inform the user: 'Your booking has been successfully canceled.'",
        uninterruptible="True"
    )}}
{% else %}
    {{SendSystemEvent(
        eventIdn="urgent_message",
        connectorIdn="system",
        baseInstruction="Inform the user: 'We encountered a problem canceling your booking.'",
        uninterruptible="True"
    )}}
{% endif %}