{{!-- TODO: Take `project_attributes_private_dynamic_schedule_working_days_hours_exceptions` into account --}}

{{!-- TODO: Use session time instead of current time --}}

{{Set(name="working_hours_object", value=GetCustomerAttribute(field="project_attributes_private_dynamic_schedule_working_hours_object"))}}

{{#if IsEmpty(text=working_hours_object)}}
    {{Set(name="working_hours_status_json", value=_defineConversationIsDuringWorkingHoursStatusSkill())}}
    {{Set(name="working_hours_status_details", value=Stringify(GetValueJSON(obj=working_hours_status_json, key="status_details")))}}
    {{Return(val=working_hours_status_details)}}
{{/if}}

{{Set(name="time_zone", value=GetCustomerAttribute(field="project_business_time_zone"))}}
{{Set(name="current_date", value=GetDatetime(format="date", timezone=time_zone))}}
{{Set(name="current_date_week_day", value=GetDatetime(format="date", timezone=time_zone, weekday=True))}}
{{Set(name="current_week_day", value=Stringify(current_date_week_day.replace(Concat(current_date, ", "), " ")))}}
{{Set(name="day_object", value=GetValueJSON(obj=working_hours_object, key=current_week_day))}}
{{#if GetValueJSON(obj=day_object, key="working_day") == "false"}}
    {{Return(val="Non working hours")}}
{{else}}
    {{Set(name="current_time", value=GetDatetime(format="time", timezone=time_zone))}}
    {{Set(name="working_hours", value=GetValueJSON(obj=day_object, key="working_hours"))}}

    {{Set(name="current_hour_list", value=current_time.split(":"))}}
    {{Set(name="current_hour_list", value=Stringify(current_hour_list))}}
    {{Set(name="current_hour_list", value=current_hour_list.replace("'", '"'))}}

    {{Set(name="current_hour", value=Stringify(GetItemsArrayByIndexesJSON(array=current_hour_list, indexes=0)))}}
    {{Set(name="current_minutes", value=GetItemsArrayByIndexesJSON(array=current_hour_list, indexes=1))}}

    {{Set(name="empty_string", value=" ")}}
    {{Set(name="current_minute_join", value=empty_string.join(current_minutes))}}
    {{Set(name="current_minute_list", value=current_minute_join.split())}}
    {{Set(name="current_minute_list", value=Stringify(current_minute_list))}}
    {{Set(name="current_minute_list", value=current_minute_list.replace("'", '"'))}}
    {{Set(name="current_minute_list", value=current_minute_list.replace('[""", ', "["))}}
    {{Set(name="current_minute_list", value=current_minute_list.replace(', """]', "]"))}}

    {{Set(name="current_minute", value=Stringify(GetItemsArrayByIndexesJSON(array=current_minute_list, indexes=0)))}}

    {{Set(name="current_hour_minute", value=Concat(current_hour, current_minute))}}

    {{Set(name="business_working_hour", value=working_hours.__contains__(current_hour_minute))}}
    {{Set(name="exists", value=Stringify(business_working_hour))}}

    {{#if exists == "True"}}
        {{Return(val="Working hours")}}
    {{else}}
        {{Return(val="Non working hours")}}
    {{/if}}
{{/if}}
