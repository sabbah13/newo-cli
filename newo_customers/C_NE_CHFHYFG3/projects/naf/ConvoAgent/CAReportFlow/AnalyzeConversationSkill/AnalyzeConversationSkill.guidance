{{#if GetCustomerAttribute(field="project_attributes_setting_send_report_during_conversation") == "True"}}
    {{Set(name="user_id", value=GetUser(field="id"))}}
    {{Set(name="memory", value=GetTriggeredAct(fields=["memory"]))}}
    {{Set(name="latest_agent_answer", value=GetTriggeredAct(fields=["convoAgentAnswer"]))}}

    {{_sendReportInitialCheckSkill(
        userId=user_id,
        transcript=memory,
        agentAnswer=latest_agent_answer
    )}}
{{/if}}
