{{Set(name="provided_phone_number_with_country_code", value=GetPersonaAttribute(id=userId, field="provided_phone_number_with_country_code"))}}

{{!-- Defining language instructions --}}
{{Set(name="business_language_primary", value=GetCustomerAttribute(field="project_business_language_primary"))}}
{{#if business_language_primary != "English"}}
    {{Set(name="language_instructions", value=Concat(" Always extract both keys and their values STRICTLY in ", business_language_primary, " language. However, user name must remain UNCHANGED in original language."))}}
{{else}}
    {{Set(name="language_instructions", value=" ")}}
{{/if}}

{{#if hipaaEnabled == "True"}}
    {{Set(name="main_prompt", value="Your goal is to extract values mentioned in `Values to extract` from the conversation and generate rows exactly in the HTML format below. Avoid mentioning any information that can be used to identify person.

# **Rules**
- Instead of name, you have to keep only first name and first letter of the last name: David Yang => David Y.
- You have to anonymize any PII (Personally Identifiable Information) and replace it by placeholders like: [REDACTED EMAIL]
    - information like birth dates, recordings, addresses... must be replaced by placeholders.
- If summary is needed, provide brief summary, without mentioning personally identifiable information.
")}}
    {{Set(name="example", value="<strong>Name:</strong> David Y.<br>
<strong>Phone Number:</strong> [REDACTED PHONE NUMBER]<br>
<strong>Requested date:</strong> 2024.03.04<br>
<strong>Requested time:</strong> 3 PM<br>")}}
{{else}}
    {{Set(name="main_prompt", value="Your goal is to extract values mentioned in `Values to extract` from the conversation and generate rows exactly in the HTML format below.")}}
    {{Set(name="example", value="<strong>Requested date:</strong> 2024.03.04<br>
<strong>Requested time:</strong> 3 PM<br>")}}
{{/if}}


{{#system~}}
{{main_prompt}}{{language_instructions}}

Current date and time: {{GetDatetime(format="datetime", timezone=GetCustomerAttribute(field="project_business_time_zone"), weekday=True)}}
{{#if hipaaEnabled == "False"}}{{#if not IsEmpty(text=provided_phone_number_with_country_code)}}User phone number: {{provided_phone_number_with_country_code}}{{/if}}{{/if}}

# User information
{{GetPersonaAttribute(id=userId, field="_private_dynamic_user_information")}}
{{GetPersonaAttribute(id=userId, field="custom_user_data")}}

# Values to extract
{{_utilsUnpackListIntoRowsSkill(valuesList=fieldsToExtract)}}

# Output format (STRICT)
Return ONLY HTML. Do NOT use Markdown (no **, no backticks), no code fences, and no extra text.
Each line MUST follow exactly:
<strong>{Key}:</strong> {value}<br>

Notes for the summary:
- Always end the summary line with a final <br>.
- If you need line breaks inside the summary, insert additional <br> tags within the summary text as needed (and still end the whole line with a final <br>).

# Example (format only)
{{example}}

# Conversation
{{transcript}}
{{~/system}}
{{Set(name="custom_values", value=Gen(temperature=0.2, topP=0, maxTokens=4000, skipFilter=True, thinkingBudget=1120))}}

{{Return(val=Concat(custom_values, "<br>"))}}