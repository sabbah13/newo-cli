{{GetPersonaAttribute(id=userId, field="_private_dynamic_user_information")}}
{{GetPersonaAttribute(id=userId, field="custom_user_data")}}
</UserInformation>

<AdditionalContextVariables alt="additional context variables" role="context">
{{GetCustomerAttribute(field="project_attributes_private_dynamic_tech_variables")}}
</AdditionalContextVariables>

{{_sendEmailInformationGetInformationAllowedToBeSentSkill(userId=userId)}}

{{_utilsGetConversationMetaSkill(userId=userId)}}

<ConversationHistory alt="conversation history (older messages above, newer messages below)" role="context" date-time="{{current_datetime}}">
{{memory}}
ConvoAgent (recent): {{agentAnswer}}
</ConversationHistory>

<CurrentConversationStateAnalysis alt="analysis of the current conversation state specified in <ConversationHistory>, which may be slightly outdated" role="instructions">
{{GetPersonaAttribute(id=userId, field="convoagent_thoughts")}}
</CurrentConversationStateAnalysis>

<AlreadySentInformation alt="already sent information via email" role="context">
{{#if not IsEmpty(text=email_already_sent_information)}}{{email_already_sent_information}}{{else}}There are no emails that have already been sent.{{/if}}
</AlreadySentInformation>

---

JSON object:{{~/system}}{{#assistant~}}{{Set(name="response", value=Gen(jsonSchema=schema, validateSchema="True", temperature=0.2, topP=0, skipFilter=True, max_tokens=4000, thinkingBudget=425))}}{{~/assistant}}

{{Set(name="email_address", value=_utilsPersonaAttributeGetWithDefaultsSkill(id=userId, field="email"))}}
{{Set(name="agent_must_send_email", value=Stringify(GetValueJSON(obj=response, key="agent_must_send_email")))}}

{{!-- Agent must return with `urgent_message` in the following cases --}}
{{Set(name="convo_agent_promise", value=Stringify(GetValueJSON(obj=response, key="convo_agent_promise")))}}
{{!-- Agent promised to send an email but... --}}
{{#if IsSimilar(val1=convo_agent_promise, val2="true", threshold=0.7)}}
    {{!-- Email address is not defined --}}
    {{#if IsSimilar(val1=email_address, val2="null", threshold=0.7)}}
        {{SendSystemEvent(
            eventIdn="urgent_message",
            connectorIdn="system",
            baseInstruction="You've just noticed that you can not send an email message because you do not know user's email address. Handle it according to your instructions.",
            callAnalyzeConversationSkill="False",
            callManageTaskSkill="False",
            uninterruptible="True"
        )}}
        {{Return()}}
    {{/if}}
    {{!-- Final decision is that Agent must not send an email --}}
    {{#if IsSimilar(val1=agent_must_send_email, val2="false", threshold=0.7)}}
        {{SendSystemEvent(
            eventIdn="urgent_message",
            connectorIdn="system",
            baseInstruction=Concat("You've just noticed that you can not send an email message. Handle it according to your instructions.
Do not mention some internal information which must not be known by the User.
Technical details (pay additional attention on `explanation` field):
```json
", response, "
```"),
            callAnalyzeConversationSkill="False",
            callManageTaskSkill="False",
            uninterruptible="True"
        )}}
        {{Return()}}
    {{/if}}
{{/if}}

{{!-- Exit in the following cases --}}

{{#if IsSimilar(val1=email_address, val2="null", threshold=0.7)}}
    {{Return()}}
{{/if}}

{{#if IsSimilar(val1=agent_must_send_email, val2="false", threshold=0.7)}}
    {{Return()}}
{{/if}}

{{Set(name="information_is_allowed_to_be_sent", value=Stringify(GetValueJSON(obj=response, key="information_is_allowed_to_be_sent")))}}
{{#if IsSimilar(val1=information_is_allowed_to_be_sent, val2="false", threshold=0.7)}}
    {{Return()}}
{{/if}}

{{!-- Send an email --}}

{{Set(name="email_subject", value=Stringify(GetValueJSON(obj=response, key="email_subject")))}}
{{Set(name="email_body", value=GetValueJSON(obj=response, key="email_body"))}}

{{!-- JSON unpack --}}
{{Set(name="email_body", value=email_body.replace("\n", "<br>"))}}
{{Set(name="email_body", value=email_body.replace('\"', '"'))}}
{{Set(name="email_body", value=Stringify(email_body))}}

{{SendSystemEvent(
    eventIdn="email_worker_send_email",
    connectorIdn="system",
    email=email_address,
    cc=" ",
    subject=email_subject,
    body=email_body,
    notify="true"
)}}

{{Set(name="email_already_sent_information", value=_prepareSentMessagesSkill(oldMessages=email_already_sent_information, newMessage=email_body))}}
{{SetPersonaAttribute(id=userId, field="email_already_sent_information", value=email_already_sent_information)}}

{{!-- Extend follow-up timer to prevent Agent speaking after sending an email --}}
{{SendSystemEvent(
    eventIdn="convoagent_update_followup",
    connectorIdn="system",
    interval="60",
    personaId=userId,
    reason="send email",
    delay="10"
)}}
