{{Set(name="conversation_channel", value=GetTriggeredAct(fields=["conversationChannel"]))}}

{{#if conversation_channel == "phone"}}
  {{Set(name="user_id", value=GetUser(field="id"))}}
  {{Set(name="actor_id", value=GetPersonaAttribute(id=user_id, field="last_convo_actor_id"))}}

  {{!-- Exit if the conversation is no longer active --}}
  {{#if IsEmpty(text=actor_id)}}
    {{Return()}}
  {{/if}}

  {{Set(name="memory_without_latest_agent_answer", value=GetTriggeredAct(fields=["memoryWithoutLatestAgentAnswer"]))}}
  {{Set(name="memory_without_latest_agent_answer_latest_turns", value=utils_memory_get_latest_turns(
    amount_of_turns=20,
    memory=memory_without_latest_agent_answer
  ))}}
  {{Set(name="latest_agent_answer", value=GetTriggeredAct(fields=["convoAgentAnswer"]))}}


  {{_sendDialpadDigitsSkill(
      actorId=actor_id,
      memory=memory_without_latest_agent_answer_latest_turns,
      agentAnswer=latest_agent_answer
  )}}
{{/if}}
