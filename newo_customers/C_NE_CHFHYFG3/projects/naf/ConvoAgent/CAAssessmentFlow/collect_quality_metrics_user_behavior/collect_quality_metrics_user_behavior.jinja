{% set schema = {
  "type": "object",
  "properties": {
  "user_hung_up_due_to_ai_mistake": {
      "type": "boolean",
      "description": "Set to `true` if the user hangs up or leaves the conversation because of an AI mistake (explicitly indicated or clearly implied)."
    },
    "user_is_deaf_or_hearing_impaired": {
      "type": "boolean",
      "description": "Set to `true` if the user indicates they are deaf or hearing-impaired, or requires a non-voice communication mode."
    },
    "user_checks_agent_presence": {
      "type": "boolean",
      "description": "Set to `true` if the user asks whether the agent is still there or responsive (e.g. 'Are you still here?')."
    },
    "user_corrects_agent": {
      "type": "boolean",
      "description": "Set to `true` if the user explicitly corrects the agent on factual information (date, name, phone number, etc.)."
    },
    "transfer_to_human_request_count": {
      "type": "integer",
      "description": "Number of times the user asks to transfer to a manager or a human in general."
    },
    "user_uses_obscene_language": {
      "type": "boolean",
      "description": "Set to `true` if the user uses obscene or offensive language (insults, swearing, aggressive exclamations like 'oh my god' used in a hostile way)."
    },
    "user_uses_obscene_language_examples": {
      "type": "array",
      "description": "Examples of user phrases that are considered obscene or offensive.",
      "items": {
        "type": "string"
      }
    },
    "user_reports_no_sms_received": {
      "type": "boolean",
      "description": "Set to `true` if the user says they did not receive an expected SMS."
    },
    "user_says_no_count": {
      "type": "integer",
      "description": "Number of times the user explicitly says 'no' in the conversation."
    },
    "user_interruptions_count": {
      "type": "integer",
      "description": "Number of times the user interrupts the agent (speaks over, cuts off, or stops the agent mid-utterance)."
    },
    "user_interruptions_count_examples": {
      "type": "array",
      "description": "Examples of user phrases used to interrupt or talk over the agent.",
      "items": {
        "type": "string"
      }
    },
    "user_satisfaction_level": {
      "type": "string",
      "enum": [
        "very dissatisfied",
        "dissatisfied",
        "neutral",
        "satisfied",
        "very satisfied"
      ],
      "description": "Overall estimation of the user's emotional state and satisfaction level by the end of the conversation."
    }
  }
} %}

{% set prompt %}

You are a QA analyst. Your goal is to evaluate conversation between ConvoAgent and {{GetUser().name}} (enclosed in <Conversation>...</Conversation>). In this session {{session_short_description}}.

<Conversation>
{{transcript}}
</Conversation>

{% endset %}

{% set result_json = structured_generation(schema=schema, prompt=prompt.strip()) %}

{{ Return(val=result_json) }}