{{#if promise == "True"}}
{{#system~}}
{
  "type": "object",
  "properties": {
    "promised": {
      "type": "boolean",
      "description": "Set the field to true if the agent promised to connect the user with the manager right now. Otherwise set to false"
    }
  },
  "required": [
    "promised"
  ]
}
{{~/system}}

    {{Return(val=GetCurrentPrompt())}}
{{/if}}

{{#if workingStatus == "True" }}
{{#system~}}
{
  "type": "object",
  "properties": {
    "status": {
      "type": "boolean",
      "description": "Set to `true` if business is working during date and time specified in <ConversationMeta>"
    },
    "status_details": {
      "type": "string",
      "enum": ["Non working day", "Non working hours", "Working hours"],
      "description": "Business working status details during date and time specified in <ConversationMeta>"
    }
  },
  "required": [
    "status",
    "status_details"
  ]
}
{{~/system}}

    {{Return(val=GetCurrentPrompt())}}
{{/if}}

{{#if transferPhoneNumber == "True"}}
{{Set(name="country_code", value=GetCustomerAttribute(field="project_representative_agent_voice_phone_country_code"))}}

{{#system~}}
{
  "type": "object",
  "properties": {
    "transfer_call_phone_number": {
      "type": "string",
      "description": "Phone number to be used to transfer call to. Make sure phone number is specified in a full format with country code ({{country_code}} is a default country code but it may be different). Always strip the \"+\" at the beginning of the phone number if it's present. Extension (internal) code might be specified - in such case combine phone number with `#` and extension code itself without spaces. Return \"null\" if phone number can not be determined."
    },
    "works_outside_of_working_hours": {
      "type": "boolean",
      "description": "Set true, if the selected phone number can be used outside of working hours. By default (if not specified): false"
    },
    "clarification_instruction": {
      "type": "string",
      "description": "A question to ask the user to clarify their intent if the phone number cannot be determined directly. This should be populated if \"transfer_call_phone_number\" is \"null\" and a clarifying question can be formulated based on the <TransferCallPhoneNumbersCriteria>. Otherwise, this should be \"null\"."
    }
  },
  "required": ["transfer_call_phone_number", "works_outside_of_working_hours"]
}
{{~/system}}

    {{Return(val=GetCurrentPrompt())}}
{{/if}}
