{{Set(name="availability", value=output)}}
{{Set(name="user_id", value=GetUser(field="id"))}}

{{Set(name="footnote_actor_id", value=_utilsGetFootnoteSkill(userId=user_id, system="True"))}}
{{SendMessage(message=Concat("System log: Available slots received: ", availability), actorIds=footnote_actor_id)}}

{{Set(name="requested_slot", value=GetPersonaAttribute(id=user_id, field="last_availability_requested_datetime"))}}

{{SetPersonaAttribute(id=user_id, field="booking_slots_availability_checking_status", value="False")}}

{{#if IsSimilar(val1="[]", val2=availability, strategy="hamming", threshold=0.7)}}
  {{SetPersonaAttribute(id=user_id, field="booking_slots_availability_checking_status_details", value=Concat("The agent received a response from the booking system: unfortunately, there are no available slots for the requested booking parameters (", requested_slot, "). The booking is not confirmed and has not taken place!"))}}
  {{Set(name="agent_instruction", value=Concat("Tell the user that you have checked and unfortunately, there are no any available slots from. Ask if they would like you to check a different time or another day."))}}
{{else}}
  {{SetPersonaAttribute(id=user_id, field="booking_slots_availability_checking_status_details", value="The agent has received a response from the booking system with available slots. The response is displayed in block `# Slots availability response`. However, the booking is still not confirmed by the booking system and has not taken place!")}}
  {{Set(name="availability_llm", value=_receiveAvailableSlotsBuildAvailabilityContextDefaultLLMSkill(output=availability, userRequestedTime=requested_slot, userId=user_id))}}
  {{Set(name="slot_available_instruction", value=_receiveAvailableSlotsCheckAvailabilitySkill(userRequestedTime=requested_slot, availability=availability_llm, userId=user_id))}}
  {{Set(name="agent_instruction", value=Concat("You have just received available slots for user requested date and time (", requested_slot, "), and ", slot_available_instruction, ". Always provide the time in a 12-hour format. Do not mention year in the date."))}}
{{/if}}

{{SendSystemEvent(eventIdn="urgent_message", connectorIdn="system", baseInstruction=agent_instruction, uninterruptible="True")}}
