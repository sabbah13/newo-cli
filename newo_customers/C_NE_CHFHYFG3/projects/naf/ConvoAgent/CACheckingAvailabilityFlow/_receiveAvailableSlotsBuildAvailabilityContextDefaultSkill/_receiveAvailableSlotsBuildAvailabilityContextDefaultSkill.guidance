{{Set(name="previous_availability", value=GetPersonaAttribute(id=userId, field="restaurant_availability"))}}

{{Set(name="availability", value=GetValueJSON(obj=slotsOutput, key="availability"))}}

{{#if IsEmpty(text=availability)}}
    {{Set(name="availability", value=[])}}
{{/if}}

{{Set(name="first_location_name", value=" ")}}
{{Set(name="first_location_time_slots", value=" ")}}

{{Set(name="second_location_name", value=" ")}}
{{Set(name="second_location_time_slots", value=" ")}}

{{Set(name="third_location_name", value=" ")}}
{{Set(name="third_location_time_slots", value=" ")}}

{{#if not IsSimilar(val1=availability, val2="[]", strategy="hamming", threshold=0.7)}}

{{Set(name="first_location", value=GetItemsArrayByIndexesJSON(array=availability, indexes=0))}}
{{Set(name="first_location_name", value=GetValueJSON(obj=first_location, key="location"))}}
{{Set(name="first_location_availability", value=Stringify(GetValueJSON(obj=first_location, key="availableTimeSlots")))}}

{{Set(name="second_location", value=GetItemsArrayByIndexesJSON(array=availability, indexes=1))}}
{{#if not IsSimilar(val1=second_location, val2="[]", strategy="hamming", threshold=0.7)}}
    {{Set(name="second_location_name", value=GetValueJSON(obj=second_location, key="location"))}}
    {{Set(name="second_location_availability", value=Stringify(GetValueJSON(obj=second_location, key="availableTimeSlots")))}}
{{/if}}

{{Set(name="third_location", value=GetItemsArrayByIndexesJSON(array=availability, indexes=2))}}
{{#if not IsSimilar(val1=third_location, val2="[]", strategy="hamming", threshold=0.7)}}
    {{Set(name="third_location_name", value=GetValueJSON(obj=third_location, key="location"))}}
    {{Set(name="third_location_availability", value=Stringify(GetValueJSON(obj=third_location, key="availableTimeSlots")))}}
{{/if}}

{{/if}}

