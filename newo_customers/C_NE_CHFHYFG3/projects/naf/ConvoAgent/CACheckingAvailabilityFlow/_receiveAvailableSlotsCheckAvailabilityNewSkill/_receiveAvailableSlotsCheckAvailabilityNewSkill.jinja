{% set user_id = GetUser().id | string %}

{% set requested_day_of_week = GetPersonaAttribute(id=user_id, field="requested_day_of_week") %}
{% set requested_date = GetPersonaAttribute(id=user_id, field="requested_date") %}
{% set requested_time_formatted = GetPersonaAttribute(id=user_id, field="requested_time_formatted") %}

{# ============================================ #}
{# STEP 1: Parse inputs and build context       #}
{# ============================================ #}
{% set has_date = requested_date != "null" %}
{% set has_time = requested_time_formatted != "null" %}

{# Build requested slot string (include day if present for display) #}
{% set requested_slot_parts = [] %}
{% if requested_day_of_week != "null" %}{% set _ = requested_slot_parts.append(requested_day_of_week) %}{% endif %}
{% if has_date %}{% set _ = requested_slot_parts.append(requested_date) %}{% endif %}
{% if has_time %}{% set _ = requested_slot_parts.append(requested_time_formatted) %}{% endif %}

{% set has_request_info = has_date or has_time %}
{% set requested_slot = requested_slot_parts|join(', ') if requested_slot_parts|length > 0 else 'requested time' %}

{# Convert 24-hour to 12-hour (keep format as HH:MM AM/PM to match availability) #}
{% set requested_time_12hr = "null" %}
{% if has_time %}
  {% set requested_time_12hr = datetime.datetime.strptime(requested_time_formatted, "%H:%M").strftime("%I:%M %p") %}
{% endif %}

{# ============================================ #}
{# STEP 2: Handle "no date and no time" case - show summary #}
{# ============================================ #}
{% if not has_date and not has_time and availability|length > 0 %}
  {% set all_dates = [] %}
  {% set all_locations = [] %}
  {% set total_slots = 0 %}
  
  {% for item in availability %}
    {% set resource = item.resource|default(item.location)|default('Unknown') %}
    {% set is_date = resource|length == 10 and resource.count('-') == 2 %}
    
    {% if is_date %}
      {% set _ = all_dates.append(resource) %}
    {% else %}
      {% set _ = all_locations.append(resource) %}
    {% endif %}
    {% set total_slots = total_slots + item.availableTimeSlots|length %}
  {% endfor %}
  
  {% if all_dates|length > 0 %}
    {% set sorted_dates = all_dates|sort %}
    {% if sorted_dates|length == 1 %}
      {{Return(val="available slots were checked for " ~ sorted_dates[0] ~ ", inform the user that there are " ~ total_slots ~ " openings available. Ask if the user would you like to know the available times.")}}
    {% else %}
      {{Return(val="available slots were checked from " ~ sorted_dates[0] ~ " to " ~ sorted_dates[-1] ~ ", inform the user that there are " ~ total_slots ~ " openings across " ~ all_dates|length ~ " days. Ask if the user would you like to know the available times.")}}
    {% endif %}
  {% elif all_locations|length > 0 %}
    {{Return(val="available slots were checked at " ~ all_locations|join(', ') ~ ", inform the user that there are " ~ total_slots ~ " openings available. Ask if the user would you like to know the available times.")}}
  {% else %}
    {{Return(val="available slots were checked, inform the user that there are " ~ total_slots ~ " slots available. Ask if the user would you like to know the available times.")}}
  {% endif %}
{% endif %}

{# ============================================ #}
{# STEP 3: Collect all slots and check matches  #}
{# ============================================ #}
{% set matching_locations = [] %}
{% set all_slots_with_locations = [] %}
{% set date_slots = [] %}

{% for item in availability %}
  {% set resource_name = item.resource|default(item.location)|default('Unknown') %}
  {% set location_is_date = resource_name|length == 10 and resource_name.count('-') == 2 %}
  
  {# Collect all slots #}
  {% for slot in item.availableTimeSlots %}
    {% set _ = all_slots_with_locations.append({'location': resource_name, 'time': slot}) %}
  {% endfor %}
  
  {# CASE 1: Both Date AND Time provided #}
  {% if has_date and has_time %}
    {% if requested_time_12hr in item.availableTimeSlots %}
      {% if not location_is_date or resource_name == requested_date %}
        {% set _ = matching_locations.append(resource_name) %}
      {% endif %}
    {% endif %}
  
  {# CASE 2: Only Time provided (suggest locations) #}
  {% elif has_time and not has_date %}
    {% if requested_time_12hr in item.availableTimeSlots %}
      {% if not location_is_date %}
        {% set _ = matching_locations.append(resource_name) %}
      {% endif %}
    {% endif %}
  
  {# CASE 3: Only Date provided (show all slots for that date) #}
  {% elif has_date and not has_time %}
    {% if location_is_date and resource_name == requested_date %}
      {% for slot in item.availableTimeSlots %}
        {% set _ = date_slots.append(slot) %}
      {% endfor %}
    {% endif %}
  
  {# CASE 4: Neither date nor time (handled in STEP 2) #}
  {% endif %}
{% endfor %}

{# ============================================ #}
{# STEP 4: Handle "only date" case              #}
{# ============================================ #}
{% if has_date and not has_time and date_slots|length > 0 %}
  {{Return(val="inform the user that for " ~ requested_slot ~ ", there are " ~ date_slots|length ~ " available time slots: " ~ date_slots|join(', ') ~ ". Ask which time will work best for them.")}}
{% endif %}

{# ============================================ #}
{# STEP 5: Find nearest slots if no exact match #}
{# ============================================ #}
{% set nearest_slots = [] %}
{% if matching_locations|length == 0 and (has_time or has_date) and date_slots|length == 0 %}
  {% set requested_time_obj = datetime.datetime.strptime(requested_time_formatted, "%H:%M") if has_time else none %}
  {% set requested_minutes = (requested_time_obj.hour * 60 + requested_time_obj.minute) if requested_time_obj else 0 %}
  {% set requested_date_obj = datetime.datetime.strptime(requested_date, "%Y-%m-%d") if has_date and requested_date|length == 10 and requested_date.count('-') == 2 else none %}
  
  {% set slots_with_diff = [] %}
  
  {% for slot_info in all_slots_with_locations %}
    {% set location_is_date = slot_info.location|length == 10 and slot_info.location.count('-') == 2 %}
    
    {# Parse slot time #}
    {% set slot_time_obj = datetime.datetime.strptime(slot_info.time, "%I:%M %p") %}
    {% set slot_minutes = slot_time_obj.hour * 60 + slot_time_obj.minute %}
    
    {# Calculate time difference #}
    {% set time_diff = (slot_minutes - requested_minutes)|abs if has_time else 0 %}
    
    {# Calculate date difference #}
    {% set date_diff = 0 %}
    {% if location_is_date and requested_date_obj %}
      {% set slot_date_obj = datetime.datetime.strptime(slot_info.location, "%Y-%m-%d") %}
      {% set date_diff = ((slot_date_obj - requested_date_obj).days|abs) * 1440 %}
    {% elif location_is_date and not requested_date_obj %}
      {% set date_diff = 999999 %}
    {% endif %}
    
    {% set combined_diff = date_diff + time_diff %}
    
    {% set _ = slots_with_diff.append({
      'location': slot_info.location,
      'time': slot_info.time,
      'diff': combined_diff
    }) %}
  {% endfor %}
  
  {% set sorted_slots = slots_with_diff|sort(attribute='diff') %}
  {% if sorted_slots|length > 0 %}{% set _ = nearest_slots.append(sorted_slots[0]) %}{% endif %}
  {% if sorted_slots|length > 1 %}{% set _ = nearest_slots.append(sorted_slots[1]) %}{% endif %}
{% endif %}

{# ============================================ #}
{# STEP 6: Build output message                 #}
{# ============================================ #}
{% set integration_idn = session_get_current_integration_idn(user_id=user_id) %}
{% set conversation_channel = session_get_conversation_channel(user_id=user_id, integration_idn=integration_idn) %}
{% set transfer_msg = "Refer to the `# CALL TRANSFERRING` section" if conversation_channel in ("phone", "webcall") else "Refer to the `# CONNECT THE USER WITH THE MANAGER OR CO-WORKER` section" %}

{% if matching_locations|length > 0 %}
  {# Exact match found #}
  {% if matching_locations|length > 1 %}
    {{Return(val="user requested slot " ~ requested_slot ~ " is available in the " ~ matching_locations|join(', ') ~ ". Inform the user about the slots and ask which option they prefer.")}}
  {% else %}
    {{Return(val="user requested slot " ~ requested_slot ~ " is available in the " ~ matching_locations[0] ~ ". Do not tell reservation is confirmed. Just inform the user about the availability and ask if the option works for them.")}}
  {% endif %}

{% elif nearest_slots|length == 0 and has_request_info %}
  {# No slots available #}
  {{Return(val="user requested slot " ~ requested_slot ~ " is not available, and there are no any available slots. " ~ transfer_msg ~ " in **<ExplicitConstraints>** block for instructions on how to proceed.")}}

{% elif nearest_slots|length > 0 %}
  {# Check if we should group by time or by date #}
  {% set all_same_time = true %}
  {% set all_same_location = true %}
  {% set first_time = nearest_slots[0].time %}
  {% set first_location = nearest_slots[0].location %}
  
  {% for slot in nearest_slots %}
    {% if slot.time != first_time %}
      {% set all_same_time = false %}
    {% endif %}
    {% if slot.location != first_location %}
      {% set all_same_location = false %}
    {% endif %}
  {% endfor %}
  
  {# Determine grouping strategy #}
  {% set formatted_options = [] %}
  
  {% if all_same_time and not all_same_location %}
    {# Same time, different locations/dates - group by time #}
    {% set locations = [] %}
    {% for slot in nearest_slots %}
      {% set _ = locations.append(slot.location) %}
    {% endfor %}
    {% set _ = formatted_options.append("inform the user that for " ~ first_time ~ ", we have availability on: " ~ locations|join(', ')) %}
  
  {% elif all_same_location and not all_same_time %}
    {# Same location/date, different times - group by location #}
    {% set times = [] %}
    {% for slot in nearest_slots %}
      {% set _ = times.append(slot.time) %}
    {% endfor %}
    {% set location_is_date = first_location|length == 10 and first_location.count('-') == 2 %}
    {% if location_is_date %}
      {% set _ = formatted_options.append("inform the user that for " ~ first_location ~ ", we have availability at: " ~ times|join(', ')) %}
    {% else %}
      {% set _ = formatted_options.append("inform the user that at " ~ first_location ~ ", we have availability at: " ~ times|join(', ')) %}
    {% endif %}
  
  {% else %}
    {# Mixed - list individually #}
    {% for slot in nearest_slots %}
      {% set _ = formatted_options.append(slot.time ~ " at " ~ slot.location) %}
    {% endfor %}
  {% endif %}
  
  {{Return(val="inform the user that their requested slot " ~ requested_slot ~ " is not available, but here are the nearest available options: " ~ formatted_options|join('. ') ~ ". Tell the user about the slots and ask which option works best for them.")}}

{% elif not has_request_info %}
  {# Neither date nor time with no availability #}
  {{Return(val="there are no available slots at this time. " ~ transfer_msg ~ " in **<ExplicitConstraints>** block for instructions on how to proceed.")}}
{% endif %}