{{Set(name="api_channel", value=GetPersonaAttribute(id=userId, field="external_channel"))}}

{{#if IsEmpty(text=GetCustomerAttribute(field="project_attributes_setting_manychat_api_token"))}}
    {{_utilsSendSystemLogSkill(message="ManyChat API key is not set. Set API key first. Use project_attributes_setting_manychat_api_token customer attribute. Skip sending message.")}}
    {{Return()}}
{{/if}}

{{SendCommand(
    commandIdn="send_request",
    integrationIdn="http",
    connectorIdn="http_connector",
    userPersonaId=userId,
    method="POST",
    url="https://api.manychat.com/fb/sending/sendContent",
    headers=_getManyChatReplyRequestHeadersSkill(),
    body=_getManyChatReplyRequestBodySkill(externalId=externalId, message=message, channel=api_channel)
)}}
