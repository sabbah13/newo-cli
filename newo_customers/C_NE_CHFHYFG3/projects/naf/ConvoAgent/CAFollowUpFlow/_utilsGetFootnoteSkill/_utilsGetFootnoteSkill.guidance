{{Set(name="prefix", value="_")}}

{{#if thoughts == "True"}}
    {{Set(name="prefix", value="thoughts_")}}
{{/if}}

{{#if system == "True"}}
    {{Set(name="prefix", value="system_")}}
{{/if}}

{{#if debug == "True"}}
    {{Set(name="prefix", value="debug_")}}
{{/if}}

{{Set(name="footnote_actor_id", value=GetPersonaAttribute(id=userId, field=Concat(prefix, "footnote_actor_id")))}}

{{#if not IsEmpty(text=footnote_actor_id)}}
    {{Return(val=footnote_actor_id)}}
{{/if}}

{{Set(name="external_id", value=Concat(prefix, "footnote_", GetActor(field="externalId")))}}

{{Set(name="existed_actors", value=Stringify(GetActors(personaId=userId, externalId=external_id, integrationIdn="system", connectorIdn=Concat(prefix, "footnote"))))}}

{{#if IsEmpty(text=existed_actors)}}
    {{!-- ? TODO: Remove after Platform fix? --}}
    {{!-- Check whether Actor is presented in another Persona --}}
    {{Set(name="existed_actors_in_all_personas", value=Stringify(GetActors(externalId=external_id, integrationIdn="system", connectorIdn=Concat(prefix, "footnote"))))}}
    {{!-- Ordinary case where Actor is not presented in another Persona --}}
    {{#if IsEmpty(text=existed_actors_in_all_personas)}}
        {{Set(name="created_actor", value=CreateActor(integrationIdn="system", connectorIdn=Concat(prefix, "footnote"), externalId=external_id, personaId=userId))}}
    {{!-- Case where existing Actor within another Persona is presented --}}
    {{else}}
        {{!-- Important note: Case where fallback External ID in another Persona is not handled --}}
        {{Set(name="external_id_fallback", value=Concat(external_id, "_", GetActor(field="integrationIdn")))}}
        {{Set(name="created_actor", value=CreateActor(integrationIdn="system", connectorIdn=Concat(prefix, "footnote"), externalId=external_id_fallback, personaId=userId))}}
    {{/if}}
    {{SetPersonaAttribute(id=userId, field=Concat(prefix, "footnote_actor_id"), value=created_actor)}}
    {{Return(val=created_actor)}}
{{/if}}

{{SetPersonaAttribute(id=userId, field=Concat(prefix, "footnote_actor_id"), value=existed_actors)}}

{{Return(val=existed_actors)}}
