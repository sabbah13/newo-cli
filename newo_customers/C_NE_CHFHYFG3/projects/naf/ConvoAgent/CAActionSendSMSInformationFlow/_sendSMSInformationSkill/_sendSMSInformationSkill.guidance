{{#if not IsEmpty(text=already_sent_information)}}{{already_sent_information}}{{else}}There are no information messages that have already been sent.{{/if}}
</AlreadySentInformation>

---

JSON object:{{~/system}}{{#assistant~}}{{Set(name="response", value=Gen(jsonSchema=schema, validateSchema="True", temperature=0.2, topP=0, skipFilter=True, max_tokens=4000, thinkingBudget=425))}}{{~/assistant}}

{{Set(name="provided_phone_number_with_country_code", value=_utilsPersonaAttributeGetWithDefaultsSkill(id=userId, field="provided_phone_number_with_country_code"))}}
{{Set(name="agent_must_send_information", value=Stringify(GetValueJSON(obj=response, key="agent_must_send_information")))}}
{{Set(name="agent_waits_user_reply", value=Stringify(GetValueJSON(obj=response, key="agent_waits_user_reply")))}}

{{!-- Agent must return with `urgent_message` in the following cases --}}
{{Set(name="convo_agent_promise", value=Stringify(GetValueJSON(obj=response, key="convo_agent_promise")))}}
{{!-- Agent promised to send an information but... --}}
{{#if IsSimilar(val1=convo_agent_promise, val2="true", threshold=0.7)}}
    {{!-- Phone number is not defined --}}
    {{#if IsSimilar(val1=provided_phone_number_with_country_code, val2="null", threshold=0.7)}}
        {{SendSystemEvent(
            eventIdn="urgent_message",
            connectorIdn="system",
            baseInstruction="You've just noticed that you can not send an message because you do not know user's phone number. Handle it according to your instructions.",
            callAnalyzeConversationSkill="False",
            callManageTaskSkill="False",
            uninterruptible="True"
        )}}
        {{Return()}}
    {{/if}}
    {{!-- Final decision is that Agent must not send an information --}}
    {{#if IsSimilar(val1=agent_must_send_information, val2="false", threshold=0.7)}}
        {{SendSystemEvent(
            eventIdn="urgent_message",
            connectorIdn="system",
            baseInstruction=Concat("You've just noticed that you can not send an message. Handle it according to your instructions.
Do not mention some internal information which must not be known by the User.
Technical details (pay additional attention on `explanation` field):
```json
", response, "
```"),
            callAnalyzeConversationSkill="False",
            callManageTaskSkill="False",
            uninterruptible="True"
        )}}
        {{Return()}}
    {{/if}}
{{/if}}

{{!-- Exit in the following cases --}}

{{#if IsSimilar(val1=provided_phone_number_with_country_code, val2="null", threshold=0.7)}}
    {{Return()}}
{{/if}}

{{#if IsSimilar(val1=agent_must_send_information, val2="false", threshold=0.7)}}
    {{Return()}}
{{/if}}

{{Set(name="information_is_allowed_to_be_sent", value=Stringify(GetValueJSON(obj=response, key="information_is_allowed_to_be_sent")))}}
{{#if IsSimilar(val1=information_is_allowed_to_be_sent, val2="false", threshold=0.7)}}
    {{Return()}}
{{/if}}

{{!-- Send an information --}}

{{Set(name="message_body", value=GetValueJSON(obj=response, key="message_body"))}}

{{!-- JSON unpack --}}
{{Set(name="message_body", value=message_body.replace("\n", "
"))}}
{{Set(name="message_body", value=message_body.replace('\"', '"'))}}
{{Set(name="message_body", value=Stringify(message_body))}}

{{!-- Information being sent -> User might need to reply something -> Urgent message --}}
{{!-- There is a change agent_speech_ended followup will be fired before user reaction --}}
{{!-- We also don't want to get followup reactivated on the urgent message. --}}
{{#if IsSimilar(val1=agent_waits_user_reply, val2="true", threshold=0.7)}}
  {{SendSystemEvent(
      eventIdn="convoagent_disable_follow_up",
      connectorIdn="system",
      reactivation_mode="manual"
  )}}
{{/if}}

{{SendSystemEvent(
    eventIdn="sms_worker_send_sms",
    connectorIdn="system",
    sms_text=message_body,
    phone_number=provided_phone_number_with_country_code,
    notify="true"
)}}

{{Set(name="already_sent_information", value=_prepareSentMessagesSkill(oldMessages=already_sent_information, newMessage=message_body))}}
{{SetPersonaAttribute(id=userId, field="already_sent_information", value=already_sent_information)}}
