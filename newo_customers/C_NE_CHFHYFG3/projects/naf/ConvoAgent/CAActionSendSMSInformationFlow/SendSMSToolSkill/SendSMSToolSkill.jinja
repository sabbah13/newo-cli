{% set act = GetTriggeredAct() %}
{% set memory = act.arguments.memory_without_latest_agent_answer %}
{% set agent_answer = act.arguments.latest_agent_answer %}
{% set user_id = GetUser().id | string %}
{% if GetPersonaAttribute(id=user_id, field="sms_subscribed") == "false" %}
    {% set agreed = _validateUserConsentSkill(memory=memory, agentAnswer=agent_answer) %}
    {% if agreed == "false" %}
        {{SendSystemEvent(
            eventIdn="urgent_message",
            connectorIdn="system",
            baseInstruction='The user previously rejected receiving SMS messages. SMS sending is not allowed without explicit permission.

You must ask the user for permission before sending an SMS.

Say something like:
"Just a heads-up — last time you asked not to receive SMS messages. Would it be okay if I send you one this time?"',
            callAnalyzeConversationSkill="False",
            callManageTaskSkill="False",
            uninterruptible="True"
        )}}
        {{Return()}}
    {% else %}
        {{SetPersonaAttribute(id=user_id, field="sms_subscribed", value="true")}}
    {% endif %}
{% endif %}
{{_sendSMSInformationSkill(userId=user_id, memory=memory, agentAnswer=agent_answer)}}
