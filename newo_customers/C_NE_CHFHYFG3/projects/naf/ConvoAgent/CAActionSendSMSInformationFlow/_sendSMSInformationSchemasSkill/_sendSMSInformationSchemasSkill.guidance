{{#if promiseSMSSchema == "True"}}
{{#system~}}
{
  "type": "object",
  "properties": {
    "promised": {
      "type": "boolean",
      "description": "Set to `true` if the agent explicitly states they themselves will send an SMS. Otherwise, set to `false`."
    }
  },
  "required": ["promised"]
}
{{~/system}}
  {{Return(val=GetCurrentPrompt())}}
{{/if}}

{{#if sendSMSInformationSchema == "True"}}
{{#system~}}
{
  "type": "object",
  "properties": {
    "user_phone_number_presence": {
      "type": "boolean",
      "description": "Must be `true` if the User's phone number is present either in <ConversationHistory> or under <UserInformation> at **user.provided_phone_number_with_country_code**"
    },
    "user_correctness_agreement": {
      "type": "boolean",
      "description": "Must be `true` if the User has explicitly stated in <ConversationHistory> that the phone number is correct by telling something like: \"Yes, you can use it, it's correct\", etc."
    },
    "convo_agent_promise": {
      "type": "boolean",
      "description": "Must be `true` if the ConvoAgent has explicitly stated that he **will** send or is **sending** a text message or the SMS."
    },
    "message_body": {
      "type": "string",
      "description": "You are the ConvoAgent communicating with the User through two channels: <ConversationHistory> is channel number 1 and SMS is channel number 2. In the field \"message_body\", you must compose your response for channel number 2 (SMS) or set it to \"Hi there\" if you don't know what to write. Newlines '\n' must be preserved. Translate to the language of the recent message from ConvoAgent."
    },
    "is_duplicate": {
      "type": "boolean",
      "description": "Must be `true` if the \"message_body\" or a text message with the similar content is already present in <AlreadySentInformation>"
    },
    "information_is_allowed_to_be_sent": {
      "type": "boolean",
      "description": "Indicates whether the content is explicitly listed in <SMSInformationAllowedToBeSent>."
    },
    "is_exception": {
      "type": "string",
      "description": "Must explain which exception is applicable or set to \"no exceptions\" if there are no exceptions"
    },
    "explanation": {
      "type": "string",
      "description": "Here you need to explain your decision."
    },
    "agent_must_send_information": {
      "type": "boolean",
      "description": "Indicates whether SMS must be sent."
    },
    "agent_waits_user_reply": {
      "type": "boolean",
      "description": "Return `true` ONLY when the agent clearly asks the user to reply to the SMS with specific information (e.g., 'Reply with your email address', 'Text back your full name', 'Reply YES to confirm'). Return `false` otherwise."
    }
  },
  "required": [
    "user_phone_number_presence",
    "user_correctness_agreement",
    "convo_agent_promise",
    "message_body",
    "is_duplicate",
    "information_is_allowed_to_be_sent",
    "is_exception",
    "explanation",
    "agent_must_send_information",
    "agent_waits_user_reply"
  ]
}
{{~/system}}
  {{Return(val=GetCurrentPrompt())}}
{{/if}}
