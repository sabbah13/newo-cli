{{#if GetCustomerAttribute(field="project_attributes_setting_timezone_reasoning_enabled") == "False"}}
    {{Return()}}
{{/if}}

{{Set(name="time_zone", value=GetCustomerAttribute(field="project_business_time_zone"))}}
{{Set(name="memory", value=GetTriggeredAct(fields="memory"))}}

{{!-- Generate thoughts --}}
{{Set(name="thoughts", value=_reasonTimeZoneSkill(memory=memory, timeZone=time_zone))}}
{{#if IsEmpty(text=thoughts)}}
    {{Return()}}
{{/if}}

{{!-- Respond --}}
{{SendSystemEvent(eventIdn="urgent_message", connectorIdn="system", baseInstruction=thoughts, uninterruptible="True")}}
