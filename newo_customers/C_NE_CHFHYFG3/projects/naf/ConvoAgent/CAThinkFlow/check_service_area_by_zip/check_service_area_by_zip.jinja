{# 
 Input parameters:
 - zip_code: The ZIP code to check.
 - served_zip_codes: A JSON string representing a list of served ZIP codes or ZIP code patterns.
#}

{% set zip_str = (zip_code or "") | string | trim | upper | replace(" ", "") %}
{% set served_zip_codes_trimmed = (served_zip_codes or "") | string | trim %}
{% set served_zip_codes_trimmed = re.sub("[–—−]", "-", served_zip_codes_trimmed) %}

{% if not served_zip_codes_trimmed
      or served_zip_codes_trimmed[0] != '['
      or served_zip_codes_trimmed[-1] != ']' %}
    {{SendSystemEvent(
        eventIdn='urgent_message',
        connectorIdn='system',
        baseInstruction='Tell the user that ' + zip_code + ' is within served area, and proceed with the next step of the main instruction',
        uninterruptible='True'
    )}}
    {{Return()}}
{% endif %}

{% set patterns = json.loads(served_zip_codes_trimmed) %}
{% set matched = False %}

{% for pattern in patterns %}
    {% set p = (pattern | string) | trim | upper | replace(" ", "") %}

    {% if '-' in p %}
        {% set parts = p.split('-') %}
        {% if parts|length == 2 %}
            {% set start = parts[0].strip() %}
            {% set end = parts[1].strip() %}

            {% if zip_str.isdigit() and start.isdigit() and end.isdigit() %}
                {% set zip_int = zip_str | int %}
                {% set start_int = start | int %}
                {% set end_int = end | int %}

                {% if start_int > end_int %}
                    {% set tmp = start_int %}
                    {% set start_int = end_int %}
                    {% set end_int = tmp %}
                {% endif %}

                {% if zip_int >= start_int and zip_int <= end_int %}
                    {% set matched = True %}
                {% endif %}
            {% endif %}
        {% endif %}

    {% elif p.endswith('*') and '*' not in p.rstrip('*') %}
        {% set prefix = p.rstrip('*') %}
        {% if zip_str.startswith(prefix) %}
            {% set matched = True %}
        {% endif %}

    {% else %}
        {% if zip_str == p %}
            {% set matched = True %}
        {% endif %}
    {% endif %}

    {# TODO: Add `break` when available in the runtime #}
{% endfor %}

{% if matched %}
    {{SendSystemEvent(
        eventIdn='urgent_message',
        connectorIdn='system',
        baseInstruction='Tell the user that ' + zip_code + ' is within served area, and proceed with the next step of the main instruction',
        uninterruptible='True'
    )}}
{% else %}
    {{SendSystemEvent(
        eventIdn='urgent_message',
        connectorIdn='system',
        baseInstruction='The ' + zip_code + ' zip code is not within area of service! Tell the user that you won\'t be able to help in this location.',
        uninterruptible='True'
    )}}
{% endif %}