{% if zip_code_city_schema == "True" %}
    {% set schema %}
{
  "type": "object",
  "properties": {
    "location_type": {
      "type": "string",
      "description": "Which type of location the user provided: ZIP code, user area (country, city, state/region), both, or none.",
      "enum": ["zip_code", "user_area", "both", "none"]
    },
    "zip_code_provided": {
      "type": "boolean",
      "description": "True if a ZIP code is mentioned anywhere in the conversation."
    },
    "zip_code_complete": {
      "type": "boolean",
      "description": "True if a full ZIP code (minimum 3 symbols) is provided. False if the ZIP code is incomplete (e.g. 2 or fewer digits)."
    },
    "zip_code": {
      "type": "string",
      "description": "ZIP code provided by the user (preserve original formatting), or an empty string if none."
    },
    "area_provided": {
      "type": "boolean",
      "description": "True if a user area (country, city, state/region) is clearly mentioned."
    },
    "area": {
      "type": "string",
      "description": "User area (country, city, state/region) provided by the user, or an empty string if none."
    }
  },
  "required": [
    "location_type",
    "zip_code_provided",
    "zip_code_complete",
    "zip_code",
    "area_provided",
    "area"
  ]
}
    {% endset %}
    {{Return(val=schema)}}
{% endif %}

{% if service_schema == "True" %}
    {% set schema %}
{
  "type": "object",
  "properties": {
    "hint": {
      "type": "string",
      "description": "A short explanation on your decision."
    },
    "service_provided": {
      "type": "boolean",
      "description": "Indicates whether the service is provided."
    }
  },
  "required": [
    "hint",
    "service_provided"
  ]
}
    {% endset %}
    {{Return(val=schema)}}
{% endif %}