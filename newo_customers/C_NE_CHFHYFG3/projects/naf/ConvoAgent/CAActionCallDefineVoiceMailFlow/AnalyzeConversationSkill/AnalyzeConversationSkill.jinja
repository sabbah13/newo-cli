{% set user_id = GetUser().id | string %}

{% if GetPersonaAttribute(id=user_id, field="voicemail_checked") == "True" %}
    {{Return()}}
{% endif %}

{% set actor_id = GetPersonaAttribute(id=user_id, field="last_convo_actor_id") %}

{# Exit if the conversation is no longer active #}
{% if not actor_id.strip() %}
    {{Return()}}
{% endif %}

{{_defineSpamOrVoiceMailSkill(userId=user_id, voiceMailRecheck="False", humanRecheck="False", actorId=actor_id)}}
