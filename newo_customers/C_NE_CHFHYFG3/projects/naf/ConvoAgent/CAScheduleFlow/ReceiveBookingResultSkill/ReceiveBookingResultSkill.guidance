{{#if GetCustomerAttribute(field="project_attributes_setting_booking_type") == "intercom"}}
    {{Set(name="target_action", value=GetTriggeredAct(fields=["targetAction"]))}}

    {{#if target_action != "book_slot"}}
        {{Return()}}
    {{/if}}

    {{Set(name="output", value=GetTriggeredAct(fields=["output"]))}}
{{else}}
    {{#if GetCustomerAttribute(field="project_attributes_setting_booking_type") == "project"}}
        {{Set(name="output", value=GetTriggeredAct(fields=["output"]))}}
        {{Set(name="target_action", value=Stringify(GetValueJSON(obj=output, key="targetAction")))}}

        {{#if target_action != "book_slot"}}
            {{Return()}}
        {{/if}}

        {{Set(name="output", value=GetValueJSON(obj=output, key="output"))}}
    {{else}}
        {{Set(name="command_act_id", value=GetTriggeredAct(fields="commandActId"))}}
        {{Set(name="target_action", value=GetAct(id=command_act_id, fields=["targetAction"]))}}

        {{#if target_action != "book_slot"}}
            {{#if GetCustomerAttribute(field="project_attributes_setting_test_mode") == "True"}}
                {{Set(name="target_action", value=Stringify(GetValueJSON(obj=GetTriggeredAct(fields="output"), key="targetAction")))}}
                {{#if target_action != "book_slot"}}
                    {{Return()}}
                {{/if}}
            {{else}}
                {{Return()}}
            {{/if}}
        {{/if}}

        {{#if GetActor(field="integrationIdn") == "magic_browser"}}
            {{SetState(name="retry_count", value="0")}}
            {{Set(name="output", value=GetTriggeredAct(fields=["output"]))}}
        {{else}}
            {{Set(name="code", value=GetTriggeredAct(fields=["statusCode"]))}}
            {{#if not IsEmpty(text=code)}}
                {{Set(name="code_success", value=_validateHttpStatusCode(code=code))}}
                {{#if code_success == "fail"}}
                    {{_notifyUserIssueSkill()}}
                    {{Return()}}
                {{/if}}
            {{/if}}
            {{Set(name="output", value=GetTriggeredAct(fields=["body"]))}}
        {{/if}}
    {{/if}}
{{/if}}

{{Set(name="user_id", value=GetUser(field="id"))}}


{{_utilsSendSystemLogSkill(message=Concat("The following booking result has been received: ", output))}}

{{Set(name="success", value=Stringify(GetValueJSON(obj=output, key="success")))}}
{{Set(name="payloads_meta", value=GetPersonaAttribute(id=user_id, field="user_booking_payloads"))}}
{{Set(name="last_payload_meta", value=GetItemsArrayByIndexesJSON(array=payloads_meta, indexes="-1"))}}

{{#if success == "false"}}
    {{Set(name="booking_log", value="The agent has sent a booking request and received a negative response from the booking system. The booking is not confirmed by the booking system and has not taken place!")}}
    {{Set(name="booking_log_advanced", value=Concat(booking_log, "
Response from the booking system:
", output))}}
    {{_utilsSendSystemLogSkill(message=booking_log_advanced)}}
    {{SetPersonaAttribute(id=user_id, field="action_state_booking_submitting", value=booking_log)}}
    {{#if GetCustomerAttribute(field="project_attributes_setting_booking_fallback_processing_type") == "custom"}}
        {{SendSystemEvent(eventIdn="process_booking_fallback_custom", connectorIdn="system", payloadMeta=last_payload_meta)}}
        {{Return()}}
    {{/if}}
    {{Set(name="industry", value=GetCustomerAttribute(field="project_business_industry"))}}
    {{#if industry == "restaurant_industry"}}
        {{!-- TODO: Define default behavior, potentially, "booking via Google" is not the optimal solution --}}
        {{Set(name="booking_details", value=_utilsGatherDetailsSkill(memory=Stringify(GetValueJSON(obj=last_payload_meta, key="memory")), agentAnswer=Stringify(GetValueJSON(obj=last_payload_meta, key="agentAnswer")), userId=user_id, industry=industry, schema=_schemasSkill(submittingBookingRestaurantSchema="True")))}}
        {{__bookRestaurantSkill(bookingDetails=booking_details, userId=user_id)}}
        {{Return()}}
    {{else}}
        {{_notifyUserIssueSkill()}}
        {{Set(name="booking_details", value=GetValueJSON(obj=last_payload_meta, key="bookingDetails"))}}
        {{Set(name="payload", value=GetValueJSON(obj=booking_details, key="payload"))}}
        {{SendSystemEvent(
            eventIdn="email_worker_send_email",
            connectorIdn="system",
            email=GetCustomerAttribute(field="project_business_manager_email"),
            cc=" ",
            subject="Failed to book, please proceed",
            body=_buildFallbackEmailBodySkill(payload=payload, userId=user_id),
            ignore_opt_out="true"
        )}}
    {{/if}}
    {{Return()}}
{{else}}
    {{Set(name="booking_log", value="The agent has sent a booking request and received a positive confirmation from the booking system. The booking is confirmed by the booking system and has successfully taken place!")}}
    {{Set(name="booking_log_advanced", value=Concat(booking_log, "
Response from the booking system:
", output))}}
    {{_utilsSendSystemLogSkill(message=booking_log_advanced)}}
    {{SetPersonaAttribute(id=user_id, field="action_state_booking_submitting", value=booking_log)}}
{{/if}}

{{#if GetCustomerAttribute(field="project_attributes_setting_booking_success_notification_on_email_enabled") == "True"}}
    {{Set(name="payload", value=GetValueJSON(obj=last_payload_meta, key="bookingDetails"))}}

    {{SendSystemEvent(
        eventIdn="email_worker_send_email",
        connectorIdn="system",
        email=GetCustomerAttribute(field="project_business_manager_email"),
        cc=" ",
        subject="Booking successful, please double-check the details",
        body=_buildSuccessEmailBodySkill(payload=payload, userId=user_id),
        ignore_opt_out="true"
    )}}
{{/if}}

{{#if GetCustomerAttribute(field="project_attributes_setting_booking_success_notification_on_sms_enabled") == "True"}}
    {{Set(name="manage_booking_url", value=Stringify(GetValueJSON(obj=output, key="manage_booking_url")))}}
    {{Set(name="manage_booking_url_postfix", value=" ")}}
    {{#if not IsEmpty(text=manage_booking_url)}}
        {{#if manage_booking_url != "null"}}
            {{Set(name="manage_booking_url_postfix", value=Concat("You can manage your booking using the following link: ", manage_booking_url))}}
        {{/if}}
    {{/if}}

    {{Set(name="booking_details", value=GetValueJSON(obj=last_payload_meta, key="bookingDetails"))}}
    {{Set(name="meta_fields", value=GetValueJSON(obj=booking_details, key="metaFields"))}}

    {{Set(name="sms_body_text", value=Stringify(GetValueJSON(obj=meta_fields, key="smsBodyText")))}}

    {{#if not IsEmpty(text=sms_body_text)}}
        {{Set(name="sms_body_text", value=Concat(sms_body_text, " ", manage_booking_url_postfix))}}
    {{else}}
        {{Set(name="sms_body_text", value=manage_booking_url_postfix)}}
    {{/if}}

    {{#if not IsEmpty(text=sms_body_text)}}
        {{SendSystemEvent(
            eventIdn="convoagent_send_notification_message",
            connectorIdn="system",
            message=sms_body_text,
            notify="true",
            subject="Your booking confirmation"
        )}}
    {{/if}}
{{/if}}

{{Set(name="booking_success_phrase", value=GetCustomerAttribute(field="project_attributes_setting_booking_phrase_template_on_booking_success"))}}
{{#if not IsEmpty(text=booking_success_phrase)}}
    {{SendSystemEvent(
        eventIdn="urgent_message",
        connectorIdn="system",
        baseInstruction=Concat("Inform the user: '", booking_success_phrase, "'. And proceed according to <ConvoAgentScenariosAndProcedures>."),
        uninterruptible="True"
    )}}
{{/if}}

{{_storeUserBookingSkill(payloadMeta=last_payload_meta, userId=user_id, bookingResult=output)}}
