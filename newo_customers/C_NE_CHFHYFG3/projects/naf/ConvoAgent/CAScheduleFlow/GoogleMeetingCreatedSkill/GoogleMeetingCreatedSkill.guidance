{{Set(name="meeting_log", value="The agent has sent a calendar invite creation request and received a positive confirmation. The calendar invite creation is now confirmed and has successfully taken place!")}}
{{Set(name="response_calendar_link", value=GetTriggeredAct(fields=["calendarLink"]))}}
{{Set(name="response_start_time", value=GetTriggeredAct(fields=["startTime"]))}}
{{Set(name="response_attendees", value=GetTriggeredAct(fields=["attendees"]))}}
{{Set(name="response_meet_link", value=GetTriggeredAct(fields=["meetLink"]))}}
{{Set(name="response_organizer", value=GetTriggeredAct(fields=["organizer"]))}}
{{Set(name="response_title", value=GetTriggeredAct(fields=["title"]))}}
{{Set(name="meeting_log_advanced", value=Concat(meeting_log, "
Response from the calendar system:
```
Calendar link: ", response_calendar_link, "
Start time: ", response_start_time, "
Attendees: ", response_attendees, "
Meet link: ", response_meet_link, "
Organizer: ", response_organizer, "
Title: ", response_title, "
```"))}}
{{_utilsSendSystemLogSkill(message=meeting_log_advanced)}}
{{SetPersonaAttribute(id=GetUser(field="id"), field="action_state_meeting_creating", value=meeting_log_advanced)}}

{{SendSystemEvent(
    eventIdn="urgent_message",
    connectorIdn="system", baseInstruction="You have just created a meeting. Ask the user to check their calendar and email, and let them know you'll stay on the line to ensure the invitation has been received.",
    callAnalyzeConversationSkill="True",
    callManageTaskSkill="True",
    uninterruptible="True"
)}}
