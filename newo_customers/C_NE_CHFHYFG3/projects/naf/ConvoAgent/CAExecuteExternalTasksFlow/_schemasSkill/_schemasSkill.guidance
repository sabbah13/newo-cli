
{{#if defineTasks == "True"}}
{{Set(name="available_tasks", value=AppendItemsArrayJSON(array=availableTasks, items=AsStringJSON(val="none")))}}
{{#system~}}
{
  "type": "object",
  "properties": {
    "tasks": {
      "type": "array",
      "description": "Add to the array tasks that, in your opinion, you can execute right now. Carefully check each task and its description to understand if you can execute. If you can't execute any task, put only 'none' in the array.",
      "items": {
        "type": "string",
        "enum": {{available_tasks}}
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "can_complete": {
      "type": "boolean",
      "description": "Set this field as true if at least one task can be completed."
    },
    "explanation": {
      "type": "string",
      "description": "Provide an explanation for your choice here. Analyze <InputTasks> and explain why you can or cannot execute a task based on <TaskDescriptions>."
    }
  },
  "required": [
    "tasks",
    "can_complete",
    "explanation"
  ]
}
{{~/system}}

{{Return(val=GetCurrentPrompt())}}

{{/if}}

{{#if sendSMS == "True"}}
{{#system~}}
{
  "type": "object",
  "properties": {
    "sms_text": {
      "type": "string",
      "description": "SMS body text that has to be sent."
    },
    "phone_number": {
      "type": "string",
      "description": "Set the value to the phone number provided in <InputTasks> without the plus sign at the beginning, but include the country code. Remove any dashes and spaces between the digits. Example: 16507045503."
    }
  },
  "required": [
    "sms_text",
    "phone_number"
  ]
}
{{~/system}}

{{Return(val=GetCurrentPrompt())}}

{{/if}}

{{#if sendEmail == "True"}}
{{#system~}}
{
  "type": "object",
  "properties": {
    "email_text": {
      "type": "string",
      "description": "Email body text that has to be sent. Pay attention that footer and header( initial greeting) already exist. So you have to generate content in line and it will past in the middle of the whole email body."
    },
    "email_address": {
      "type": "string",
      "description": "Set the value to the email address provided in <InputTasks>."
    },
    "subject": {
      "type": "string",
      "description": "Based on email text put short subject for the email"
    }
  },
  "required": [
    "email_text",
    "subject",
    "email_address"
  ]
}
{{~/system}}

{{Return(val=GetCurrentPrompt())}}

{{/if}}

{{#if makeCall == "True"}}
{{#system~}}
{
  "type": "object",
  "properties": {
    "first_name": {
      "type": "string",
      "description": "Put here user's first name mentioned in the <InputTasks>. If not mentioned, leave as empty string."
    },
    "last_name": {
      "type": "string",
      "description": "Put here user's last name mentioned in the <InputTasks>. If not mentioned, leave as empty string."
    },
    "phone_number": {
      "type": "string",
      "description": "Set the value to the phone number provided in <InputTasks> without the plus sign at the beginning, but include the country code. Remove any dashes and spaces between the digits. Example: 16507045503."
    }
  },
  "required": [
    "first_name",
    "last_name",
    "phone_number"
  ]
}
{{~/system}}

{{Return(val=GetCurrentPrompt())}}

{{/if}}

{{#if createMeeting == "True"}}
{{Set(name="timezone", value=GetCustomerAttribute(field="project_business_time_zone"))}}
{{#system~}}
{
    "type": "object",
    "properties": {
        "datetime": {
            "type": "string",
            "description": "User's preferred datetime with ISO 8601 format. Timezone {{timezone}}. Timezone required. Example: 2024-10-23T14:00:00+04:00."
        },
        "user_email": {
            "type": "string",
            "description": "Email from the <InputTasks>."
        },
        "summary": {
            "type": "string",
            "description": "Short summary for description of the meeting generated based on <InputTasks>."
        }
    },
    "required": [
        "datetime",
        "user_email",
        "summary"
    ]
}
{{~/system}}

{{Return(val=GetCurrentPrompt())}}

{{/if}}

{{#if phoneNumberExists == "True"}}
{{#system~}}
{
  "type": "object",
  "properties": {
    "phone_number_provided": {
      "type": "boolean",
      "description": "If any phone number provided in the <InputTasks>, set this field to true. If there is no any phone number in the <InputTasks> set to false."
    },
    "phone_number": {
      "type": "string",
      "description": "Set the value to the phone number provided in <InputTasks> without the plus sign at the beginning, but include the country code. Remove any dashes and spaces between the digits. Example: 16507045503. If there is no any phone number in the <InputTasks> set this field as \"Not provided\""
    }
  },
  "required": [
    "phone_number_provided",
    "phone_number"
  ]
}
{{~/system}}

{{Return(val=GetCurrentPrompt())}}

{{/if}}
