{{Set(name="content", value=GetTriggeredAct(fields=["content"]))}}
{{Set(name="newo_chat_external_id", value=GetTriggeredAct(fields=["newoChatExternalId"]))}}
{{Set(name="utms", value=GetTriggeredAct(fields="utms"))}}
{{Set(name="from_creator", value=GetTriggeredAct(fields="fromCreator"))}}

{{Set(name="phone_number_object", value=_getValuesSkill(inputTasks=content, schema=_schemasSkill(phoneNumberExists="True")))}}

{{Set(name="user_id", value=" ")}}
{{Set(name="existing_newo_chat_actor", value=" ")}}
{{Set(name="vapi_actor", value=" ")}}

{{#if GetValueJSON(obj=phone_number_object, key="phone_number_provided") == "true"}}
    {{Set(name="phone_number", value=Stringify(GetValueJSON(obj=phone_number_object, key="phone_number")))}}
    {{Set(name="user_id", value=_createActorsSkill(phoneNumber=phone_number, newoExternalChatId=newo_chat_external_id))}}
    {{Set(name="vapi_actor", value=GetActors(externalId=phone_number, integrationIdn="vapi", connectorIdn="vapi_caller"))}}
{{else}}
    {{#if not IsEmpty(text=newo_chat_external_id)}}
        {{Set(name="existing_newo_chat_actor", value=GetActors(externalId=newo_chat_external_id, integrationIdn="newo_chat", connectorIdn="newo_chat"))}}

        {{#if IsEmpty(text=existing_newo_chat_actor)}}

            {{!-- TODO: Potentially, refactor or remove, Persona and Actors creation must be centralized / consistent --}}
            {{Set(name="persona_id", value=CreatePersona(name="User"))}}

            {{Set(name="existing_newo_chat_actor", value=CreateActor(integrationIdn="newo_chat", connectorIdn="newo_chat", externalId=newo_chat_external_id, personaId=persona_id))}}

        {{/if}}
        {{Set(name="user_id", value=GetActor(field="personaId", id=Stringify(existing_newo_chat_actor)))}}
    {{else}}
        {{DUMMY("There is neither phone number or newo_chat_external_id. Skipping creating persona.")}}
    {{/if}}
{{/if}}


{{Set(name="tasks_to_execute", value=_defineTasksSkill(inputTasks=content))}}

{{#if not IsEmpty(text=user_id)}}
    {{#if not IsEmpty(text=from_creator)}}
        {{Set(name="utms", value=UpdateValueJSON(obj=utms, key="fromCreator", value="true"))}}
    {{/if}}

    {{SetPersonaAttribute(id=user_id, field="url_params", value=utms)}}

    {{#if IsEmpty(text=vapi_actor)}}
        {{SendSystemEvent(eventIdn="execute_tasks", connectorIdn="system", actorIds=existing_newo_chat_actor, inputTasks=content, tasksToExecute=tasks_to_execute)}}
    {{else}}
        {{SendSystemEvent(eventIdn="execute_tasks", connectorIdn="system", actorIds=vapi_actor, inputTasks=content, tasksToExecute=tasks_to_execute)}}
    {{/if}}

{{else}}
    {{_executeTasksWithoutPersonaSkill(tasksToExecute=tasks_to_execute, inputTasks=content)}}
{{/if}}
