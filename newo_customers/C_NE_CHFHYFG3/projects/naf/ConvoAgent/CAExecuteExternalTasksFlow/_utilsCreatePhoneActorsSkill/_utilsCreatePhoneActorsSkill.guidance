{{! Create Actor for `Twilio Messenger` }}
{{Set(name="existing_twilio_messenger_actors", value=GetActors(integrationIdn="twilio_messenger", connectorIdn="sms_connector", externalId=phoneNumber))}}
{{#if IsEmpty(text=existing_twilio_messenger_actors)}}
  {{CreateActor(integrationIdn="twilio_messenger", connectorIdn="sms_connector", externalId=phoneNumber, personaId=userId)}}
{{/if}}

