{% set after_action_options = {
    'llm_process_instructions': '',
} %}
{% if not after_action.options or not after_action.options.section_name %}
    {{utils_send_system_log(message="`set_prompt_section` after-action cannot be executed without `options.section_name`")}}
    {{Return()}}
{% endif %}
{{after_action_options.update(after_action.options)}}
{% if after_action_options.llm_process_instruction %}
    {% set input = generate_text_by_instruction(user_id=user_id, instruction=after_action_options.llm_process_instruction, input=input) %}
{% endif %}
{{SendSystemEvent(
    eventIdn="convoagent_update_custom_user_data",
    connectorIdn="system",
    sectionName=after_action_options.section_name,
    sectionValue=input
)}}
{{utils_send_system_log(message="```
" ~ input ~ "
``` was sent to `" ~ after_action.options.section_name ~ " user's prompt section")}}
