{{Set(name="data", value=GetTriggeredAct(fields=["data"]))}}
{{#if not IsEmpty(text=data)}}
    {{Set(name="needs_summary", value=GetCustomerAttribute(field="project_attributes_setting_data_injection_needs_summary"))}}
    {{#if IsSimilar(val1=needs_summary, val2="True", strategy="symbols")}}
        {{Set(name="data", value=_summarizeInjectedData(rawData=data))}}
    {{/if}}
    {{SetCustomerAttribute(
        field="project_attributes_private_data_injection_retrieved_data",
        value=data
    )}}
{{/if}}
