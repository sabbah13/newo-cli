{% set arguments = GetTriggeredAct().arguments %}
{% set section_name = arguments.sectionName %}
{% set section_value = arguments.sectionValue %}

{% set user_id = GetUser().id | string %}
{% set current_custom_prompt_section = GetPersonaAttribute(id=user_id, field="custom_prompt_section") %}

{% if section_name in current_custom_prompt_section %}
    {% set current_custom_prompt_section = re.sub('<' ~ section_name ~ '>.*?</' ~ section_name ~ '>\\s*---\\s*', '', current_custom_prompt_section, flags=re.DOTALL) %}
{% endif %}

{% set section = _buildCustomSectionSkill(sectionName=section_name, sectionValue=section_value) %}

{{SetPersonaAttribute(id=user_id, field="custom_prompt_section", value=custom_prompt_section ~ "\n\n" ~ section)}}
