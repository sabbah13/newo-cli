{% set tz_name = GetCustomerAttribute(field="project_business_time_zone") %}
{% set current_date_week_day = GetDateTime(format="date", timezone=tz_name, weekday=True) %}
{% set calendar_created_at = GetCustomerAttribute(field="project_attributes_private_dynamic_prompt_calendar_created_at") %}
{% if current_date_week_day == calendar_created_at %}
    {{Return()}}
{% endif %}

{# Move days_to_generate as setting to customer attributes? #}
{% set days_to_generate = 45 %}
{% set tz = zoneinfo.ZoneInfo(tz_name) %}
{% set now = datetime.datetime.now(tz) %}
{% set today = now.date() %}
{% set this_monday = today - datetime.timedelta(days=today.weekday()) %}

{# ------------------------------------------
# CALENDAR GENERATION
# ------------------------------------------ #}
{% set calendar_list = [] %}

{% for offset in range(days_to_generate) %}
    {# Current date #}
    {% set d = today + datetime.timedelta(days=offset) %}
    {% set weekday = d.strftime('%A') %}

    {# Marker: today / tomorrow / this / next (week) #}
    {% if offset == 0 %}
        {% set marker = 'today ' %}
    {% elif offset == 1 %}
        {% set marker = 'tomorrow ' %}
    {% else %}
        {% set delta_days = (d - this_monday).days %}
        {% set week_index = delta_days // 7 %}
        {% if week_index == 0 %}
            {% set marker = 'this ' %}
        {% elif week_index == 1 %}
            {% set marker = 'next ' %}
        {% else %}
            {% set marker = '' %}
        {% endif %}
    {% endif %}

    {# Ordinal day (1st, 2nd, 3rd, 4th, ...) #}
    {% set n = d.day %}
    {% set n_mod_100 = n % 100 %}
    {% if 11 <= n_mod_100 <= 13 %}
        {% set ordinal_suffix = 'th' %}
    {% else %}
        {% set n_mod_10 = n % 10 %}
        {% if n_mod_10 == 1 %}
            {% set ordinal_suffix = 'st' %}
        {% elif n_mod_10 == 2 %}
            {% set ordinal_suffix = 'nd' %}
        {% elif n_mod_10 == 3 %}
            {% set ordinal_suffix = 'rd' %}
        {% else %}
            {% set ordinal_suffix = 'th' %}
        {% endif %}
    {% endif %}
    {% set ordinal = n ~ ordinal_suffix %}

    {# Build line once and append #}
    {% set line = marker ~ weekday ~ " " ~ ordinal ~ " of " ~ d.strftime('%B') ~ " " ~ d.year ~ ", " ~ d.strftime('%Y-%m-%d') %}
    {{ calendar_list.append(line) }}
{% endfor %}

{% set compiled_calendar = "\n".join(calendar_list) %}

{{SetCustomerAttribute(field="project_attributes_private_dynamic_prompt_calendar", value=compiled_calendar.strip())}}
{{SetCustomerAttribute(field="project_attributes_private_dynamic_prompt_calendar_created_at", value=current_date_week_day)}}
