{{Set(name="is_data_injection_enabled", value=GetCustomerAttribute(field="project_attributes_setting_data_injection_is_enabled"))}}

{{#if is_data_injection_enabled == "False"}}
    {{_stopReceivingDataSkill()}}
    {{Return()}}
{{/if}}

{{Set(name="payload", value=GetCustomerAttribute(field="project_attributes_private_data_injection_payload"))}}

{{SendCommand(
    commandIdn="data_injection",
    integrationIdn="api",
    connectorIdn="webhook",
    payload=payload
)}}

{{Set(name="agent_id", value=GetAgentPersona(field="id"))}}
{{Set(name="update_period", value=GetCustomerAttribute(field="project_attributes_setting_data_injection_update_period"))}}
{{SetCustomerAttribute(field="project_attributes_private_data_injection_is_timer_running", value="True")}}

{{SendCommand(
    commandIdn="set_timer",
    integrationIdn="program_timer",
    connectorIdn="data_injection_timer",
    personaId=agent_id,
    timerName="data_injection_timer",
    interval=update_period,
    repeatable="false",
    enabled="true"
)}}
