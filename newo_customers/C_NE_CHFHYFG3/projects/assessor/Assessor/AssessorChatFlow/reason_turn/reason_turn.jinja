{{system}}
You are the middleman agent observing the conversation between ConvoAgent and Assessor. Your goal is to analyze the <Conversation> and trigger actions if needed according to your output schema.

<Conversation>
{{memory}}
</Conversation>
{{end}}
{% set response = json.loads(Gen(temperature=0.2, topP=0, jsonSchema=json.dumps({
    "type": "object",
    "properties": {
        "conversation_finished": {
            "type": "boolean",
            "description": "Set `true` if the conversation is concluded and the Assessor wants to finish it, `false` otherwise."
        }
    },
    "required": ["conversation_finished"]
}, ensure_ascii=False, indent=2), validateSchema="True", thinkingBudget=1024)) %}
{% set user_id = GetUser().id | string %}
{% if response.conversation_finished %}
    {{SetPersonaAttribute(id=user_id, field="assessor_chat_conversation_is_finished", value="True")}}
    {{SendCommand(
        commandIdn="set_timer",
        integrationIdn="program_timer",
        connectorIdn="session_timer",
        personaId=user_id,
        timerName="session_timer",
        interval="10",
        eventIdn="end_session"
    )}}

{% endif %}
