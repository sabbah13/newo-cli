{{!-- Entry point: triggered by place_order_tool event. Extract order from conversation, validate, build payload, submit to POS or ask for missing details. --}}
{{Set(name="memory", value=GetTriggeredAct(fields="memory"))}}
{{Set(name="agentAnswer", value=GetTriggeredAct(fields="agentAnswer"))}}
{{#if IsEmpty(text=agentAnswer)}}
    {{Set(name="agentAnswer", value=GetTriggeredAct(fields="latest_agent_answer"))}}
{{/if}}
{{Set(name="userId", value=GetUser(field="id"))}}

{{!-- LLM extracts order details from conversation --}}
{{Set(name="order_details", value=_extractOrderDetailsSkill(memory=memory, agentAnswer=agentAnswer))}}
{{!-- Pass order_details via persona so callee skills avoid parameter validation issues --}}
{{SetPersonaAttribute(id=userId, field="temp_order_details", value=order_details)}}
{{!-- Validate completeness (items, customerName, customerPhone) --}}
{{Set(name="validation", value=_validateOrderSkill())}}

{{Set(name="is_valid", value=GetValueJSON(obj=validation, key="isValid"))}}
{{Set(name="missing_fields", value=GetValueJSON(obj=validation, key="missingFields"))}}

{{#if is_valid == "true"}}
    {{!-- Build POS payload and submit --}}
    {{Set(name="order_payload", value=_buildOrderPayloadSkill())}}
    {{SetPersonaAttribute(id=userId, field="temp_order_payload", value=order_payload)}}
    {{_submitOrderSkill()}}
{{else}}
    {{!-- Ask agent to collect missing details --}}
    {{SendSystemEvent(
        eventIdn="urgent_message",
        connectorIdn="system",
        baseInstruction=Concat("Before placing the order, please collect: ", Stringify(missing_fields)),
        uninterruptible="True"
    )}}
{{/if}}
