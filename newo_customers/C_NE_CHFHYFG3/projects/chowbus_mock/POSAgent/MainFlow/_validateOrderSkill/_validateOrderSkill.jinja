{# Validates extracted order details: checks for at least one item, customerName, customerPhone. Reads order_details from persona temp_order_details. Outputs isValid and missingFields. #}
{% set user_id = GetUser(field="id") %}
{% set details = GetPersonaAttribute(id=user_id, field="temp_order_details") | default("") %}
{% set missing = [] %}
{% set valid = true %}
{% if details %}
    {% set parsed = json.loads(details) if details is string else details %}
    {% if parsed is mapping %}
        {% if not parsed.get("items") or parsed.items | length == 0 %}
            {% set missing = missing + ["at least one order item"] %}
            {% set valid = false %}
        {% endif %}
        {% if not parsed.get("customerName") or (parsed.customerName | default("") | trim | length == 0) %}
            {% set missing = missing + ["customer name"] %}
            {% set valid = false %}
        {% endif %}
        {% if not parsed.get("customerPhone") or (parsed.customerPhone | default("") | trim | length == 0) %}
            {% set missing = missing + ["customer phone"] %}
            {% set valid = false %}
        {% endif %}
    {% else %}
        {% set missing = ["valid order structure"] %}
        {% set valid = false %}
    {% endif %}
{% else %}
    {% set missing = ["order details"] %}
    {% set valid = false %}
{% endif %}
{{ Return(val=json.dumps({"isValid": valid, "missingFields": missing})) }}
