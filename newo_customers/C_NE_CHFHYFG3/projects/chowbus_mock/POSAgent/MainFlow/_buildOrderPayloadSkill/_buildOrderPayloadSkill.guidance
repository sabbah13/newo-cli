{{!-- Build POS API payload from extracted order details. Reads order_details from persona temp_order_details to avoid parameter validation. Output: {"order": { items, customer, fulfillment, payment, callerId, specialInstructions }} --}}
{{Set(name="userId", value=GetUser(field="id"))}}
{{Set(name="order_details", value=GetPersonaAttribute(id=userId, field="temp_order_details"))}}
{{Set(name="items", value=GetValueJSON(obj=order_details, key="items"))}}
{{Set(name="customerName", value=GetValueJSON(obj=order_details, key="customerName"))}}
{{Set(name="customerPhone", value=GetValueJSON(obj=order_details, key="customerPhone"))}}
{{Set(name="fulfillmentType", value=GetValueJSON(obj=order_details, key="fulfillmentType"))}}
{{Set(name="scheduledTime", value=GetValueJSON(obj=order_details, key="scheduledTime"))}}
{{Set(name="specialInstructions", value=GetValueJSON(obj=order_details, key="specialInstructions"))}}

{{!-- Build customer object --}}
{{Set(name="customer_obj", value=UpdateValueJSON(obj=UpdateValueJSON(obj="{}", key="name", value=customerName), key="phone", value=customerPhone))}}

{{!-- Build fulfillment object --}}
{{Set(name="fulfillment_obj", value=UpdateValueJSON(obj=UpdateValueJSON(obj="{}", key="type", value=fulfillmentType), key="scheduledTime", value=scheduledTime))}}

{{!-- Build payment object --}}
{{Set(name="payment_obj", value=UpdateValueJSON(obj="{}", key="method", value="pay_link"))}}

{{!-- Build inner order object: items, customer, fulfillment, payment, callerId, specialInstructions --}}
{{Set(name="order_inner", value=UpdateValueJSON(obj="{}", key="items", value=items))}}
{{Set(name="order_inner", value=UpdateValueJSON(obj=order_inner, key="customer", value=customer_obj))}}
{{Set(name="order_inner", value=UpdateValueJSON(obj=order_inner, key="fulfillment", value=fulfillment_obj))}}
{{Set(name="order_inner", value=UpdateValueJSON(obj=order_inner, key="payment", value=payment_obj))}}
{{Set(name="order_inner", value=UpdateValueJSON(obj=order_inner, key="callerId", value=AsStringJSON(val=userId)))}}
{{Set(name="order_inner", value=UpdateValueJSON(obj=order_inner, key="specialInstructions", value=specialInstructions))}}

{{!-- Wrap in "order" key for POST body --}}
{{Set(name="order_payload", value=UpdateValueJSON(obj="{}", key="order", value=order_inner))}}
{{Return(val=order_payload)}}
