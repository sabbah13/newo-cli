{{!-- HTTP callback: result_success from http_connector after POST /api/orders. Correlate by commandActId/targetAction; validate status; parse formUrl/orderId; notify agent with payment link. --}}
{{Set(name="command_act_id", value=GetTriggeredAct(fields="commandActId"))}}
{{Set(name="target_action", value=GetAct(id=command_act_id, fields=["targetAction"]))}}

{{#if target_action != "place_order"}}
    {{Return()}}
{{/if}}

{{Set(name="status_code", value=GetTriggeredAct(fields="statusCode"))}}
{{Set(name="code_result", value=_validateHttpStatusCode(code=status_code))}}

{{#if code_result == "fail"}}
    {{SendSystemEvent(
        eventIdn="urgent_message",
        connectorIdn="system",
        baseInstruction="I apologize, there was an issue submitting your order. Let me try again.",
        uninterruptible="True"
    )}}
    {{Return()}}
{{/if}}

{{Set(name="response_body", value=GetTriggeredAct(fields="body"))}}
{{Set(name="form_url", value=GetValueJSON(obj=response_body, key="formUrl"))}}
{{Set(name="order_id", value=GetValueJSON(obj=response_body, key="orderId"))}}

{{!-- Store order ID for tracking --}}
{{Set(name="user_id", value=GetUser(field="id"))}}
{{SetPersonaAttribute(id=user_id, field="current_order_id", value=order_id)}}

{{!-- Notify agent to tell customer about payment link --}}
{{SendSystemEvent(
    eventIdn="urgent_message",
    connectorIdn="system",
    baseInstruction=Concat("Great news! Your order has been submitted. I'm sending a payment link to your phone now. The link is: ", form_url),
    uninterruptible="True"
)}}
