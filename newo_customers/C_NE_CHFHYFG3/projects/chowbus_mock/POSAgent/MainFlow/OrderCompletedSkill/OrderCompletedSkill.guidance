{{!-- Callback: order_completed from api/pos_integration when payment is complete. Get pickupEta, orderTotal; format confirmation; send urgent_message to agent. --}}
{{Set(name="caller_id", value=GetTriggeredAct(fields="callerId"))}}
{{Set(name="eta", value=GetTriggeredAct(fields="pickupEta"))}}
{{Set(name="order_total", value=GetTriggeredAct(fields="orderTotal"))}}

{{Set(name="confirmation", value=_formatOrderConfirmationSkill(eta=eta, orderTotal=order_total))}}

{{SendSystemEvent(
    eventIdn="urgent_message",
    connectorIdn="system",
    baseInstruction=confirmation,
    uninterruptible="True"
)}}
